ull,"$$ 0 = 9z^2 - 6z $$":null,"$$ A = 9, >> B = -6, >> C = 0 $$":null,"$$ D = B^2 - 4AC = (-6)^2 - 4 \\cdot 9 \\cdot 0 = 36 $$":null,"$$ z_{1,2} = \\frac{-B \\pm \\sqrt{D}}{2A} = \\frac{-(-6) \\pm \\sqrt{36}}{2 \\cdot 9} = \\frac{6 \\pm 6}{18} $$":null,"$$ z_1 = \\frac{6 + 6}{18} = \\frac{12}{18} = \\frac{2}{3} \\\\ \\boxed{z_1 = \\frac{2}{3}} >> z_2 = \\frac{6 - 6}{18} = 0 \\\\ \\boxed{z_2 = 0} $$":null,"$$ -t^2 + 10t - 9 = 0 $$":null,"$$ \\boxed{t_1 = 1} >> \\boxed{t_2 = 9} $$":null,"$$ A = -1, >> B = 10, >> C = -9 $$":null,"$$ D = B^2 - 4AC = 10^2 - 4 \\cdot (-1) \\cdot (-9) = 100 - 36 = 64 $$":null,"$$ t_{1,2} = \\frac{-B \\pm \\sqrt{D}}{2A} = \\frac{-10 \\pm \\sqrt{64}}{2 \\cdot (-1)} = \\frac{-10 \\pm 8}{-2} $$":null,"$$ t_1 = \\frac{-10 + 8}{-2} = 1 \\\\ \\boxed{t_1 = 1} >> t_2 = \\frac{-10 - 8}{-2} = 9 \\\\ \\boxed{t_2 = 9} $$":null,"$$ 16v^2 = 100 $$":null,"$$ \\boxed{v_1 = -\\frac{5}{2}} >> \\boxed{v_2 = \\frac{5}{2}} $$":null,"$ 100 $":null,"$$ 16v^2 - 100 = 0 $$":null,"$$ A = 16, >> B = 0, >> C = -100 $$":null,"$$ D = B^2 - 4AC = 0^2 - 4 \\cdot 16 \\cdot (-100) = 6400 $$":null,"$$ v_{1,2} = \\frac{-B \\pm \\sqrt{D}}{2A} = \\frac{-0 \\pm \\sqrt{6400}}{2 \\cdot 16} = \\frac{\\pm 80}{32} $$":null,"$$ v_1 = \\frac{80}{32} = \\frac{5}{2} \\\\ \\boxed{v_1 = \\frac{5}{2}} >> v_2 = \\frac{-80}{32} = -\\frac{5}{2} \\\\ \\boxed{v_2 = -\\frac{5}{2}} $$":null,"$$ (2k-7)^2 = 0 $$":null,"$$ \\boxed{k = \\frac{7}{2}} $$":null,"$$ (2k-7)^2 = 0 \\\\ (2k-7)(2k-7) = 0 \\\\ 4k^2 - 14k - 14k + 49 = 0 \\\\ 4k^2 - 28k + 49 = 0 $$":null,"$$ A = 4, >> B = -28, >> C = 49 $$":null,"$$ D = B^2 - 4AC = (-28)^2 - 4 \\cdot 4 \\cdot 49 = 784 - 784 = 0 $$":null,"$$ k = \\frac{-B}{2A} = \\frac{-(-28)}{2 \\cdot 4} = \\frac{28}{8} = \\boxed{\\frac{7}{2}} $$":null}}