2,"value":46},"Ключевые элементы",{"type":22,"value":48},"Статистика",{"type":22,"value":50},"Темная",{"type":22,"value":30},{"type":22,"value":53},"Языки",{"type":22,"value":55},"Системная",{"type":22,"value":57},"Статья",{"type":22,"value":59},"Настройки",{"type":22,"value":61},"Собрано",{"type":22,"value":63},"Конспект",{"type":22,"value":65},"Контент",{"type":22,"value":67},"Практика",{"type":22,"value":69},"Erudit",{"type":22,"value":71},"Вы собираетесь перейти на страницу контента:",{"type":22,"value":73},"Добавить перевод",{"type":22,"value":75},"Главная страница",{"type":22,"value":77},"Авторы",{"type":22,"value":79},"Спонсоры",{"type":22,"value":81},"Поиск по сайту...",{"type":22,"value":83},"Ищем еще...",{"type":22,"value":85},"Ничего не найдено",{"type":22,"value":87},"Больше результатов нет",{"type":22,"value":89},"Контента нет.",{"type":22,"value":91},"К оглавлению",{"type":22,"value":93},"Об учебнике",{"type":22,"value":95},"Разработка",{"type":22,"value":97},"Профиль",{"type":22,"value":99},"Дополнение",{"type":22,"value":101},"Список людей, которые внесли вклад в материалы проекта: предложили ценные идеи, вносили корректировки в существующий материал или же написали собственный!",{"type":22,"value":103},"Вы тоже можете помочь проекту, внести свой вклад и попасть на эту страницу!",{"type":22,"value":105},"Стать автором",{"type":22,"value":107},"Пока что авторов нет. Вы можете стать первым!",{"type":22,"value":109},"Вклад",{"type":22,"value":111},"Список людей и организаций, которые поддерживают проект финансово. Благодаря им проект может существовать и развиваться. Если вы хотите помочь проекту, то тоже можете стать спонсором и попасть на эту страницу!",{"type":22,"value":113},"Редактор",{"type":22,"value":115},"Стать спонсором",{"type":22,"value":117},"Пока что спонсоров нет. Вы можете стать первым!",{"type":27,"value":119},"(name) => `Персональная страница автора \"${name}\" с данными о вкладе в проект.`",{"type":22,"value":121},"Начать изучение!",{"type":22,"value":123},"Связи",{"type":22,"value":125},"Собственные",{"type":22,"value":127},"Из",{"type":22,"value":129},"Надо знать",{"type":22,"value":131},"Зависит от",{"type":22,"value":133},"Используется в",{"type":22,"value":135},"Внешние",{"m":137},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":139,"mainContent":140},"book/basics/",{"fullId":5,"shortId":5,"contentRelativePath":141,"title":15,"bookTitle":15,"breadcrumbs":142,"description":143,"stats":144,"connections":149,"contributions":165,"type":14,"children":178},"01-basics",[],"\n    Все стартовые и самые полезные темы, формулы и понятия, на основе которых строится вся математика.\n    Идеальная стартовая точка, если полный чайник в математике.\n    Предварительных знаний не требуется.\n    Всё расписано простым и понятным языком.\n  ",{"materials":145,"elements":146},5,{"accent_term":147,"accent_statement":145,"accent_important":147,"problem":148},9,73,{"externals":150},[151],{"type":152,"items":153},"own",[154,160],{"type":155,"title":156,"info":157,"link":158,"reason":159},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https://math.libretexts.org/","Большое количество материалов и много типовых задач на отработку.",{"type":161,"title":162,"info":163,"reason":164},"physical","Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[166,170,174],{"contributorId":167,"name":168,"avatarUrl":169},"gwynerva","Пётр Радько","/file/contributors/gwynerva/avatar.png",{"contributorId":171,"name":172,"avatarUrl":173},"nagibin","Николай Нагибин","/file/contributors/nagibin/avatar.jpg",{"contributorId":175,"name":176,"avatarUrl":177},"igor-radko","Игорь Радько","/file/contributors/igor-radko/avatar.jpg",[179],{"type":180,"link":181,"title":182,"description":183,"stats":184},"group","/group/basics/equations/","Уравнения","\n    Разбор самых популярных уравнений: элементарных, квадратных, систем и т.д.\n    Вы поймёте, зачем их вообще нужно решать и как с их помощью можно описывать процессы в реальной жизни.\n    Разберем и нюансы: преобразования, ОДЗ, \"потеря\" и появление \"лишних\" корней и многие другие.\n  ",{"materials":145,"elements":185},{"accent_term":147,"accent_statement":145,"accent_important":147,"problem":148},{"contributorsCount":187,"sponsorsCount":145},7,{"shortBookId":5,"frontNav":189},{"type":14,"shortId":5,"title":15,"flags":190,"link":17,"children":191},{},[192],{"type":180,"separator":193,"shortId":194,"title":182,"flags":195,"link":181,"children":196},true,"basics/equations",{},[197,207],{"type":198,"shortId":199,"title":200,"flags":201,"link":202,"parts":203},"topic","basics/equations/elementary","Элементарные уравнения",{},"/article/basics/equations/elementary/",[204,205,206],"article","summary","practice",{"type":180,"separator":208,"shortId":209,"title":210,"flags":211,"link":212,"children":213},false,"basics/equations/quadratic","Квадратные уравнения",{},"/group/basics/equations/quadratic/",[214,220,226,232],{"type":198,"shortId":215,"title":216,"flags":217,"link":218,"parts":219},"basics/equations/quadratic/what-is-it","Что это такое?",{},"/article/basics/equations/quadratic/what-is-it/",[204,205,206],{"type":198,"shortId":221,"title":222,"flags":223,"link":224,"parts":225},"basics/equations/quadratic/incomplete","Неполная форма",{},"/article/basics/equations/quadratic/incomplete/",[204,205,206],{"type":198,"shortId":227,"title":228,"flags":229,"link":230,"parts":231},"basics/equations/quadratic/completing-the-square","Полный квадрат",{},"/article/basics/equations/quadratic/completing-the-square/",[204,205,206],{"type":198,"shortId":233,"title":234,"flags":235,"link":236,"parts":237},"basics/equa