2,"value":46},"Ключевые элементы",{"type":22,"value":48},"Статистика",{"type":22,"value":50},"Темная",{"type":22,"value":30},{"type":22,"value":53},"Языки",{"type":22,"value":55},"Системная",{"type":22,"value":57},"Статья",{"type":22,"value":59},"Настройки",{"type":22,"value":61},"Собрано",{"type":22,"value":63},"Конспект",{"type":22,"value":65},"Контент",{"type":22,"value":67},"Практика",{"type":22,"value":69},"Erudit",{"type":22,"value":71},"Вы собираетесь перейти на страницу контента:",{"type":22,"value":73},"Добавить перевод",{"type":22,"value":75},"Главная страница",{"type":22,"value":77},"Авторы",{"type":22,"value":79},"Спонсоры",{"type":22,"value":81},"Поиск по сайту...",{"type":22,"value":83},"Ищем еще...",{"type":22,"value":85},"Ничего не найдено",{"type":22,"value":87},"Больше результатов нет",{"type":22,"value":89},"Контента нет.",{"type":22,"value":91},"К оглавлению",{"type":22,"value":93},"Об учебнике",{"type":22,"value":95},"Разработка",{"type":22,"value":97},"Профиль",{"type":22,"value":99},"Дополнение",{"type":22,"value":101},"Список людей, которые внесли вклад в материалы проекта: предложили ценные идеи, вносили корректировки в существующий материал или же написали собственный!",{"type":22,"value":103},"Вы тоже можете помочь проекту, внести свой вклад и попасть на эту страницу!",{"type":22,"value":105},"Стать автором",{"type":22,"value":107},"Пока что авторов нет. Вы можете стать первым!",{"type":22,"value":109},"Вклад",{"type":22,"value":111},"Редактор",{"type":22,"value":113},"Список людей и организаций, которые поддерживают проект финансово. Благодаря им проект может существовать и развиваться. Если вы хотите помочь проекту, то тоже можете стать спонсором и попасть на эту страницу!",{"type":22,"value":115},"Стать спонсором",{"type":27,"value":117},"(name) => `Персональная страница автора \"${name}\" с данными о вкладе в проект.`",{"type":22,"value":119},"Пока что спонсоров нет. Вы можете стать первым!",{"type":22,"value":121},"Начать изучение!",{"type":22,"value":123},"Связи",{"type":22,"value":125},"Собственные",{"type":22,"value":127},"Из",{"type":22,"value":129},"Надо знать",{"type":22,"value":131},"Зависит от",{"type":22,"value":133},"Используется в",{"type":22,"value":135},"Внешние",{"m":137},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":139,"mainContent":140},"book/basics/",{"fullId":5,"shortId":5,"contentRelativePath":141,"title":15,"bookTitle":15,"breadcrumbs":142,"description":143,"stats":144,"connections":150,"contributions":166,"type":14,"children":179},"01-basics",[],"\n    Все стартовые и самые полезные темы, формулы и понятия, на основе которых строится вся математика.\n    Идеальная стартовая точка, если полный чайник в математике.\n    Предварительных знаний не требуется.\n    Всё расписано простым и понятным языком.\n  ",{"materials":145,"elements":146},6,{"accent_term":147,"accent_statement":145,"accent_important":148,"problem":149},9,10,82,{"externals":151},[152],{"type":153,"items":154},"own",[155,161],{"type":156,"title":157,"info":158,"link":159,"reason":160},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https://math.libretexts.org/","Большое количество материалов и много типовых задач на отработку.",{"type":162,"title":163,"info":164,"reason":165},"physical","Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[167,171,175],{"contributorId":168,"name":169,"avatarUrl":170},"gwynerva","Пётр Радько","/file/contributors/gwynerva/avatar.png",{"contributorId":172,"name":173,"avatarUrl":174},"nagibin","Николай Нагибин","/file/contributors/nagibin/avatar.jpg",{"contributorId":176,"name":177,"avatarUrl":178},"igor-radko","Игорь Радько","/file/contributors/igor-radko/avatar.jpg",[180],{"type":181,"link":182,"title":183,"description":184,"stats":185},"group","/group/basics/equations/","Уравнения","\n    Разбор самых популярных уравнений: элементарных, квадратных, систем и т.д.\n    Вы поймёте, зачем их вообще нужно решать и как с их помощью можно описывать процессы в реальной жизни.\n    Разберем и нюансы: преобразования, ОДЗ, \"потеря\" и появление \"лишних\" корней и многие другие.\n  ",{"materials":145,"elements":186},{"accent_term":147,"accent_statement":145,"accent_important":148,"problem":149},{"contributorsCount":188,"sponsorsCount":189},7,5,{"shortBookId":5,"frontNav":191},{"type":14,"shortId":5,"title":15,"flags":192,"link":17,"children":193},{},[194],{"type":181,"separator":195,"shortId":196,"title":183,"flags":197,"link":182,"children":198},true,"basics/equations",{},[199,209],{"type":200,"shortId":201,"title":202,"flags":203,"link":204,"parts":205},"topic","basics/equations/elementary","Элементарные уравнения",{},"/article/basics/equations/elementary/",[206,207,208],"article","summary","practice",{"type":181,"separator":210,"shortId":211,"title":212,"flags":213,"link":214,"children":215},false,"basics/equations/quadratic","Квадратные уравнения",{},"/group/basics/equations/quadratic/",[216,222,228,234,240],{"type":200,"shortId":217,"title":218,"flags":219,"link":220,"parts":221},"basics/equations/quadratic/what-is-it","Что это такое?",{},"/article/basics/equations/quadratic/what-is-it/",[206,207,208],{"type":200,"shortId":223,"title":224,"flags":225,"link":226,"parts":227},"basics/equations/quadratic/incomplete","Неполная форма",{},"/article/basics/equations/quadratic/incomplete/",[206,207,208],{"type":200,"shortId":229,"title":230,"flags":231,"link":232,"parts":233},"basics/equations/quadratic/completing-the-square","Полный квадрат",{},"/article/basics/equations/quadratic/completing-the-square/",[206,207,208],{"type":200,"shortId":235,"title":236,"flags":237,"link":238,"parts":239},"ba