роект.`",{"type":22,"value":121},"Путь",{"type":22,"value":123},"Начать изучение!",{"type":22,"value":125},"Связи",{"type":22,"value":127},"Обновлено",{"type":22,"value":129},"Собственные",{"type":22,"value":131},"Из",{"type":22,"value":133},"Надо знать",{"type":22,"value":135},"Зависит от",{"type":22,"value":137},"Используется в",{"type":22,"value":139},"Внешние",{"m":141},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":143,"mainContent":144},"book\u002Ffoundations\u002F",{"fullId":5,"shortId":5,"contentRelativePath":145,"title":15,"bookTitle":15,"breadcrumbs":146,"lastmod":147,"description":148,"stats":149,"connections":156,"contributions":172,"type":14,"children":185},"01-foundations",[],"2026-04-04T10:42:24+03:00","\n    Все стартовые и самые полезные темы, формулы и понятия, на основе которых строится вся математика.\n    Идеальная стартовая точка, если вы полный чайник в математике.\n    Предварительных знаний не требуется.\n    Всё расписано простым и понятным языком.\n  ",{"materials":150,"elements":151},10,{"accent_term":152,"accent_statement":153,"accent_important":154,"problem":155},9,12,16,119,{"externals":157},[158],{"type":159,"items":160},"own",[161,167],{"type":162,"title":163,"info":164,"link":165,"reason":166},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":168,"title":169,"info":170,"reason":171},"physical","Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[173,177,181],{"contributorId":174,"name":175,"avatarUrl":176},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributor