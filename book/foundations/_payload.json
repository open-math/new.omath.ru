pe":22,"value":44},"Материалы",{"type":22,"value":46},"Ключевые элементы",{"type":22,"value":48},"Статистика",{"type":22,"value":50},"Темная",{"type":22,"value":30},{"type":22,"value":53},"Языки",{"type":22,"value":55},"Системная",{"type":22,"value":57},"Статья",{"type":22,"value":59},"Настройки",{"type":22,"value":61},"Собрано",{"type":22,"value":63},"Конспект",{"type":22,"value":65},"Контент",{"type":22,"value":67},"Практика",{"type":22,"value":69},"Erudit",{"type":22,"value":71},"Вы собираетесь перейти на страницу контента:",{"type":22,"value":73},"Добавить перевод",{"type":22,"value":75},"Главная страница",{"type":22,"value":77},"Авторы",{"type":22,"value":79},"Спонсоры",{"type":22,"value":81},"Поиск по сайту...",{"type":22,"value":83},"Ищем еще...",{"type":22,"value":85},"Ничего не найдено",{"type":22,"value":87},"Больше результатов нет",{"type":22,"value":89},"Контента нет.",{"type":22,"value":91},"К оглавлению",{"type":22,"value":93},"Об учебнике",{"type":22,"value":95},"Разработка",{"type":22,"value":97},"Профиль",{"type":22,"value":99},"Дополнение",{"type":22,"value":101},"Список людей, которые внесли вклад в материалы проекта: предложили ценные идеи, вносили корректировки в существующий материал или же написали собственный!",{"type":22,"value":103},"Вы тоже можете помочь проекту, внести свой вклад и попасть на эту страницу!",{"type":22,"value":105},"Список людей и организаций, которые поддерживают проект финансово. Благодаря им проект может существовать и развиваться. Если вы хотите помочь проекту, то тоже можете стать спонсором и попасть на эту страницу!",{"type":22,"value":107},"Стать автором",{"type":22,"value":109},"Стать спонсором",{"type":22,"value":111},"Пока что авторов нет. Вы можете стать первым!",{"type":22,"value":113},"Пока что спонсоров нет. Вы можете стать первым!",{"type":22,"value":115},"Редактор",{"type":22,"value":117},"Вклад",{"type":27,"value":119},"(name) => `Персональная страница автора \"${name}\" с данными о вкладе в проект.`",{"ty