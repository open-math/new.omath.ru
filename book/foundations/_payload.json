,"Поиск",{"type":22,"value":44},"Материалы",{"type":22,"value":46},"Ключевые элементы",{"type":22,"value":48},"Статистика",{"type":22,"value":50},"Темная",{"type":22,"value":30},{"type":22,"value":53},"Языки",{"type":22,"value":55},"Системная",{"type":22,"value":57},"Статья",{"type":22,"value":59},"Настройки",{"type":22,"value":61},"Собрано",{"type":22,"value":63},"Конспект",{"type":22,"value":65},"Контент",{"type":22,"value":67},"Задачи",{"type":22,"value":69},"Erudit",{"type":22,"value":71},"Вы собираетесь перейти на страницу контента:",{"type":22,"value":73},"Добавить перевод",{"type":22,"value":75},"Главная страница",{"type":22,"value":77},"Авторы",{"type":22,"value":79},"Спонсоры",{"type":22,"value":81},"Поиск по сайту...",{"type":22,"value":83},"Ищем еще...",{"type":22,"value":85},"Ничего не найдено",{"type":22,"value":87},"Больше результатов нет",{"type":22,"value":89},"Контента нет.",{"type":22,"value":91},"К оглавлению",{"type":22,"value":93},"Об учебнике",{"type":22,"value":95},"Разработка",{"type":22,"value":97},"Профиль",{"type":22,"value":99},"Дополнение",{"type":22,"value":101},"Список людей, которые внесли вклад в материалы проекта: предложили ценные идеи, вносили корректировки в существующий материал или же написали собственный!",{"type":22,"value":103},"Вы тоже можете помочь проекту, внести свой вклад и попасть на эту страницу!",{"type":22,"value":105},"Стать автором",{"type":22,"value":107},"Список людей и организаций, которые поддерживают проект финансово. Благодаря им проект может существовать и развиваться. Если вы хотите помочь проекту, то тоже можете стать спонсором и попасть на эту страницу!",{"type":22,"value":109},"Пока что авторов нет. Вы можете стать первым!",{"type":22,"value":111},"Стать спонсором",{"type":22,"value":113},"Вклад",{"type":22,"value":115},"Пока что спонсоров нет. Вы можете стать первым!",{"type":22,"value":117},"Редактор",{"type":27,"value":119},"(name) => `Персональная страница автора \"${name}\" с данными о вкладе в проект.`",{"type":22,"value":121},"Путь",{"type":22,"value":123},"Начать изучение!",{"type":22,"value":125},"Связи",{"type":22,"value":127},"Обновлено",{"type":22,"value":129},"Собственные",{"type":22,"value":131},"Из",{"type":22,"value":133},"Надо знать",{"type":22,"value":135},"Зависит от",{"type":22,"value":137},"Используется в",{"type":22,"value":139},"Внешние",{"m":141},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":143,"mainContent":144},"book\u002Ffoundations\u002F",{"fullId":5,"shortId":5,"contentRelativePath":145,"title":15,"bookTitle":15,"breadcrumbs":146,"lastmod":147,"description":148,"stats":149,"connections":155,"contributions":171,"type":14,"children":184},"01-foundations",[],"2026-05-01T18:59:52+03:00","\n    Все стартовые и самые полезные темы, формулы и понятия, на основе которых строится вся математика.\n    Идеальная стартовая точка, если вы полный чайник в математике.\n    Предварительных знаний не требуется.\n    Всё расписано простым и понятным языком.\n  ",{"materials":150,"elements":151},12,{"accent_term":152,"accent_statement":153,"accent_important":153,"problem":154},10,18,173,{"externals":156},[157],{"type":158,"items":159},"own",[160,166],{"type":161,"title":162,"info":163,"link":164,"reason":165},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":167,"title":168,"info":169,"reason":170},"physical","Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[172,176,180],{"contributorId":173,"name":174,"avatarUrl":175},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png",{"contributorId":177,"name":178,"avatarUrl":179},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg",{"contributorId":181,"name":182,"avatarUrl":183},"igor-radko","Игорь Радько","\u002Ffile\u002Fcontributors\u002Figor-radko\u002Favatar.jpg",[185,196],{"type":186,"link":187,"title":188,"description":189,"stats":190},"group","\u002Fgroup\u002Ffoundations\u002Fpolynomials\u002F","Многочлены","\n    Базовые знания об основных алгебраических понятиях -- одночленах и многочленах.\n    Научимся приводить их к стандартной форме, преобразовывать, раскладывать на множители и выполнять другие операции.\n  ",{"materials":191,"elements":192},1,{"accent_term":191,"accent_statement":193,"accent_important":194,"problem":195},5,2,28,{"type":186,"link":197,"title":198,"description":199,"stats":200},"\u002Fgroup\u002Ffoundations\u002Fequations\u002F","Уравнения","\n    Разбор самых популярных уравнений: элементарных, квадратных, систем и т.д.\n    Вы поймёте, зачем их вообще нужно решать и как с их помощью можно описывать процессы в реальной жизни.\n    Разберем и нюансы: преобразования, ОДЗ, \"потеря\" и появление \"лишних\" корней и многие другие.\n  ",{"materials":201,"elements":202},11,{"accent_term":203,"accent_statement":204,"accent_important":205,"problem":206},9,13,16,145,{"contributorsCount":208,"sponsorsCount":193},7,{"shortBookId":5,"frontNav":210},{"type":14,"shortId":5,"title":15,"flags":211,"link":17,"children":212},{},[213,228],{"type":186,"separator":214,"shortId":215,"title":188,"flags":216,"link":187,"children":217},true,"foundations\u002Fpolynomials",{},[218],{"type":219,"shortId":220,"title":221,"flags":222,"link":223,"parts":224},"topic","foundations\u002Fpolynomials\u002Fspecial-products","Формулы сокращенного умножения",{},"\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F",[225,226,227],"article","summary","practice",{"type":186,"separator":214,"shortId":229,"title":198,"