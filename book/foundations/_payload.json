,"Поиск",{"type":22,"value":44},"Материалы",{"type":22,"value":46},"Ключевые элементы",{"type":22,"value":48},"Статистика",{"type":22,"value":50},"Темная",{"type":22,"value":30},{"type":22,"value":53},"Языки",{"type":22,"value":55},"Системная",{"type":22,"value":57},"Статья",{"type":22,"value":59},"Настройки",{"type":22,"value":61},"Собрано",{"type":22,"value":63},"Конспект",{"type":22,"value":65},"Контент",{"type":22,"value":67},"Практика",{"type":22,"value":69},"Erudit",{"type":22,"value":71},"Вы собираетесь перейти на страницу контента:",{"type":22,"value":73},"Добавить перевод",{"type":22,"value":75},"Главная страница",{"type":22,"value":77},"Авторы",{"type":22,"value":79},"Спонсоры",{"type":22,"value":81},"Поиск по сайту...",{"type":22,"value":83},"Ищем еще...",{"type":22,"value":85},"Ничего не найдено",{"type":22,"value":87},"Больше результатов нет",{"type":22,"value":89},"Контента нет.",{"type":22,"value":91},"К оглавлению",{"type":22,"value":93},"Об учебнике",{"type":22,"value":95},"Разработка",{"type":22,"value":97},"Профиль",{"type":22,"value":99},"Дополнение",{"type":22,"value":101},"Список людей и организаций, которые поддерживают проект финансово. Благодаря им проект может существовать и развиваться. Если вы хотите помочь проекту, то тоже можете стать спонсором и попасть на эту страницу!",{"type":22,"value":103},"Список людей, которые внесли вклад в материалы проекта: предложили ценные идеи, вносили корректировки в существующий материал или же написали собственный!",{"type":22,"value":105},"Стать спонсором",{"type":22,"value":107},"Вы тоже можете помочь проекту, внести свой вклад и попасть на эту страницу!",{"type":22,"value":109},"Пока что спонсоров нет. Вы можете стать первым!",{"type":22,"value":111},"Стать автором",{"type":22,"value":113},"Пока что авторов нет. Вы можете стать первым!",{"type":22,"value":115},"Вклад",{"type":22,"value":117},"Редактор",{"type":27,"value":119},"(name) => `Персональная страница автора \"${name}\" с данными о вкладе в проект.`",{"type":22,"value":121},"Путь",{"type":22,"value":123},"Начать изучение!",{"type":22,"value":125},"Связи",{"type":22,"value":127},"Обновлено",{"type":22,"value":129},"Собственные",{"type":22,"value":131},"Из",{"type":22,"value":133},"Надо знать",{"type":22,"value":135},"Зависит от",{"type":22,"value":137},"Используется в",{"type":22,"value":139},"Внешние",{"m":141},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":143,"mainContent":144},"book\u002Ffoundations\u002F",{"fullId":5,"shortId":5,"contentRelativePath":145,"title":15,"bookTitle":15,"breadcrumbs":146,"lastmod":147,"description":148,"stats":149,"connections":155,"contributions":171,"type":14,"children":184},"01-foundations",[],"2026-03-30T15:21:58+03:00","\n    Все стартовые и самые полезные темы, формулы и понятия, на основе которых строится вся математика.\n    Идеальная стартовая точка, если вы полный чайник в математике.\n    Предварительных знаний не требуется.\n    Всё расписано простым и понятным языком.\n  ",{"materials":150,"elements":151},9,{"accent_term":150,"accent_statement":152,"accent_important":153,"problem":154},12,15,106,{"externals":156},[157],{"type":158,"items":159},"own",[160,166],{"type":161,"title":162,"info":163,"link":164,"reason":165},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":167,"title":168,"info":169,"reason":170},"physical","Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[172,176,180],{"contributorId":173,"name":174,"avatarUrl":175},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png",{"contributorId":177,"name":178,"avatarUrl":179},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg",{"contributorId":181,"name":182,"avatarUrl":183},"igor-radko","Игорь Радько","\u002Ffile\u002Fcontributors\u002Figor-radko\u002Favatar.jpg",[185],{"type":186,"link":187,"title":188,"description":189,"stats":190},"group","\u002Fgroup\u002Ffoundations\u002Fequations\u002F","Уравнения","\n    Разбор самых популярных уравнений: элементарных, квадратных, систем и т.д.\n    Вы поймёте, зачем их вообще нужно решать и как с их помощью можно описывать процессы в реальной жизни.\n    Разберем и нюансы: преобразования, ОДЗ, \"потеря\" и появление \"лишних\" корней и многие другие.\n  ",{"materials":150,"elements":191},{"accent_term":150,"accent_statement":152,"accent_important":153,"problem":154},{"contributorsCount":193,"sponsorsCount":194},7,5,{"shortBookId":5,"frontNav":196},{"type":14,"shortId":5,"title":15,"flags":197,"link":17,"children":198},{},[199],{"type":186,"separator":200,"shortId":201,"title":188,"flags":202,"link":187,"children":203},true,"foundations\u002Fequations",{},[204,214,219],{"type":205,"shortId":206,"title":207,"flags":208,"link":209,"parts":210},"topic","foundations\u002Fequations\u002Felementary","Элементарные уравнения",{},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F",[211,212,213],"article","summary","practice",{"type":8,"shortId":215,"title":216,"flags":217,"link":218},"foundations\u002Fequations\u002Fzero-product-property","Нулевые множители",{},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F",{"type":186,"separator":220,"shortId":221,"title":222,"flags":223,"link":224,"children":225},false,"foundations\u002Fequations\u002Fquadratic","Квадратные уравнения",{},"\u002Fgroup\u002Ffoundations\u002Fequations\u002Fquadratic\u002F",[226,232,238,244,250,256,262],{"type":205,"shortId":227,"title":228,"flags":229,"link":230,"parts":231},"fo