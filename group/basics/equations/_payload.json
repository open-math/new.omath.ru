2,"value":46},"Ключевые элементы",{"type":22,"value":48},"Статистика",{"type":22,"value":50},"Темная",{"type":22,"value":30},{"type":22,"value":53},"Языки",{"type":22,"value":55},"Системная",{"type":22,"value":57},"Статья",{"type":22,"value":59},"Настройки",{"type":22,"value":61},"Собрано",{"type":22,"value":63},"Конспект",{"type":22,"value":65},"Контент",{"type":22,"value":67},"Практика",{"type":22,"value":69},"Erudit",{"type":22,"value":71},"Вы собираетесь перейти на страницу контента:",{"type":22,"value":73},"Добавить перевод",{"type":22,"value":75},"Главная страница",{"type":22,"value":77},"Авторы",{"type":22,"value":79},"Спонсоры",{"type":22,"value":81},"Поиск по сайту...",{"type":22,"value":83},"Ищем еще...",{"type":22,"value":85},"Ничего не найдено",{"type":22,"value":87},"Больше результатов нет",{"type":22,"value":89},"Контента нет.",{"type":22,"value":91},"К оглавлению",{"type":22,"value":93},"Об учебнике",{"type":22,"value":95},"Разработка",{"type":22,"value":97},"Профиль",{"type":22,"value":99},"Дополнение",{"type":22,"value":101},"Список людей, которые внесли вклад в материалы проекта: предложили ценные идеи, вносили корректировки в существующий материал или же написали собственный!",{"type":22,"value":103},"Вы тоже можете помочь проекту, внести свой вклад и попасть на эту страницу!",{"type":22,"value":105},"Список людей и организаций, которые поддерживают проект финансово. Благодаря им проект может существовать и развиваться. Если вы хотите помочь проекту, то тоже можете стать спонсором и попасть на эту страницу!",{"type":22,"value":107},"Стать автором",{"type":22,"value":109},"Стать спонсором",{"type":22,"value":111},"Пока что авторов нет. Вы можете стать первым!",{"type":22,"value":113},"Пока что спонсоров нет. Вы можете стать первым!",{"type":22,"value":115},"Вклад",{"type":22,"value":117},"Редактор",{"type":27,"value":119},"(name) => `Персональная страница автора \"${name}\" с данными о вкладе в проект.`",{"type":22,"value":121},"Начать изучение!",{"type":22,"value":123},"Связи",{"type":22,"value":125},"Собственные",{"type":22,"value":127},"Из",{"type":22,"value":129},"Надо знать",{"type":22,"value":131},"Зависит от",{"type":22,"value":133},"Используется в",{"type":22,"value":135},"Внешние",{"m":137},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":139,"mainContent":140},"group/basics/equations/",{"fullId":141,"shortId":141,"contentRelativePath":142,"title":143,"bookTitle":15,"breadcrumbs":144,"description":147,"stats":148,"connections":153,"contributions":177,"type":190,"children":191},"basics/equations","01-basics/02-equations","Уравнения",[145],{"icon":146,"title":15,"link":17},"book-outline","\n    Разбор самых популярных уравнений: элементарных, квадратных, систем и т.д.\n    Вы поймёте, зачем их вообще нужно решать и как с их помощью можно описывать процессы в реальной жизни.\n    Разберем и нюансы: преобразования, ОДЗ, \"потеря\" и появление \"лишних\" корней и многие другие.\n  ",{"materials":149,"elements":150},5,{"accent_term":151,"accent_statement":149,"accent_important":151,"problem":152},9,73,{"externals":154},[155,164],{"type":156,"items":157},"own",[158],{"type":159,"title":160,"info":161,"link":162,"reason":163},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https://ddpu.edu.ua/fmk/studentam/3em/10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":165,"title":15,"items":166},"parent",[167,173],{"type":168,"title":169,"info":170,"link":171,"reason":172},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https://math.libretexts.org/","Большое количество материалов и много типовых задач на отработку.",{"type":159,"title":174,"info":175,"reason":176},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[178,182,186],{"contributorId":179,"name":180,"avatarUrl":181},"gwynerva","Пётр Радько","/file/contributors/gwynerva/avatar.png",{"contributorId":183,"name":184,"avatarUrl":185},"nagibin","Николай Нагибин","/file/contributors/nagibin/avatar.jpg",{"contributorId":187,"name":188,"avatarUrl":189},"igor-radko","Игорь Радько","/file/contributors/igor-radko/avatar.jpg","group",[192,276],{"type":193,"link":194,"title":195,"description":196,"keyLinks":197,"stats":270},"topic","/article/basics/equations/elementary/","Элементарные уравнения","\n    Научимся решать простейшие уравнения и преобразовывать равенства.\n    Просто, наглядно, с примерами и без заучивания наизусть кучи странных правил.\n    Это ключевой и необходимый навык в математике и всех остальных точных науках.\n  ",[198,206,213,220,227,234,242,249,256,263],{"link":199,"schemaName":200,"title":201,"key":202,"seo":203,"description":205},"/article/basics/equations/elementary/?element=equality","accent_term","Равенство",{},{"title":204},"Что такое равенство?","Два выражения, между которыми стоит знак равно \"=\". Равенство может быть истинным (2 = 2) или ложным (2 = 0).",{"link":207,"schemaName":208,"title":209,"key":210,"seo":211,"description":212},"/article/basics/equations/elementary/?element=equality-false-true","diagram","Верное и ложное равенство",{},{},"Если по бокам от знака = стоят одинаковые объекты, то равенство верное. Если разные — ложное.",{"link":214,"schemaName":200,"title":215,"key":216,"seo":217,"description":219},"/article/basics/equations/elementary/?element=equation","Уравнение",{},{"title":218},"Что такое уравнение?","Равенство, в котором есть одна или несколько неизвестных или переменных.",{"link":221,"schemaName":200,"title":222,"key":223,"seo":224,"description":226},"/article/basics/equations/elementary/?element=equation-solution","Решение уравнения",{},{"title":225},"Что значит решить уравнение?","\"Решения\" или \"корни\" уравнения — числа, которые при подстановке вместо неизвестных превращают его в истинное равенство.\n          \"Решить уравнение\" — значит найти все его корни и доказать, что других корней нет.",{"link":228,"schemaName":229,"title":230,"key":231,"seo":232,"description":233},"/article/basics/equations/elementary/?element=same-action-rule","accent_statement","Правило одинакового действия",{},{},"Если над обеими частями истинного равенства совершить одно и то же действие, то полученное равенство тоже будет истинным.",{"link":235,"schemaName":236,"title":237,"key":238,"seo":239,"description":241},"/article/basics/equations/elementary/?element=common-mistakes","list","Ошибки при решении уравнений",{},{"title":240},"Типовые ошибки при решении уравнений","Список типовых ошибок, которые новички совершают при решении уравнений.",{"link":243,"schemaName":244,"title":245,"key":246,"seo":247,"description":248},"/article/basics/equations/elementary/?element=zachem-reshat-uravneniya","heading","Зачем решать уравнения?",{},{},"Набор примеров, для работы с которыми требуется умение решать уравнения.",{"link":250,"schemaName":244,"title":251,"key":252,"seo":253,"description":255},"/article/basics/equations/elementary/?element=treugolnik-idiota","Треугольник формул",{},{"title":254},"Магический треугольник формул","Мнемоническая техника для запоминания простых формул.",{"link":257,"schemaName":244,"title":258,"key":259,"seo":260,"description":262},"/article/basics/equations/elementary/?element=uravneniya-v-zhizni","Уравнения в жизни",{},{"title":261},"Где используют уравнения в жизни?","Подборка проблем и ситуаций из реальной жизни, которые можно решить, если перевести их в уравнения.",{"link":264,"schemaName":265,"title":266,"key":267,"seo":268,"description":269},"/practice/basics/equations/elementary/?element=linear-root","problems","Формула линейных уравнений",{},{},"Формула, по которой можно очень быстро найти корень любого уравнения вида Ax + B = 0.",{"elements":271},{"accent_term":272,"accent_statement":273,"accent_important":274,"problem":275},3,1,4,36,{"type":190,"link":277,"title":278,"description":279,"stats":280},"/group/basics/equations/quadratic/","Квадратные уравнения","\n    Полный разбор квадратных уравнений: квадратные трехчлены, выделение полного квадрата, дискриминант, формулы Виета, разложение на множители, применения в реальной жизни и даже решение в уме!\n  ",{"materials":274,"elements":281},{"accent_term":282,"accent_statement":274,"accent_important":149,"problem":283},6,37,{"contributorsCount":285,"sponsorsCount":149},7,{"shortBookId":5,"frontNav":287},{"type":14,"shortId":5,"title":15,"flags":288,"link":17,"children":289},{},[290],{"type":190,"separator":291,"shortId":141,"title":143,"flags":292,"link":293,"children":294},true,{},"/group/basics/equations/",[295,302],{"type":193,"shortId":296,"title":195,"flags":297,"link":194,"parts":298},"basics/equations/elementary",{},[299,300,301],"article","summary","practice",{"type":190,"separator":303,"shortId":304,"title":278,"flags":305,"link":277,"children":306},false,"basics/equations/quadratic",{},[307,313,319,325],{"type":193,"shortId":308,"title":309,"flags":310,"link":311,"parts":312},"basics/equations/quadratic/what-is-it","Что это такое?",{},"/article/basics/equations/quadratic/what-is-it/",[299,300,301],{"type":193,"shortId":314,"title":315,"flags":316,"link":317,"parts":318},"basics/equations/quadratic/incomplete","Неполная форма",{},"/article/basics/equations/quadratic/incomplete/",[299,300,301],{"type":193,"shortId":320,"title":321,"flags":322,"link":323,"parts":324},"basics/equations/quadratic/completing-the-square","Полный квадрат",{},"/article/basics/equations/quadratic/completing-the-square/",[299,300,301],{"type":193,"shortId":326,"title":327,"flags":328,"link":329,"parts":330},"basics/equations/quadratic/quadratic-formula","Формула корней",{},"/artic