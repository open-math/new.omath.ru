lue":121},"Начать изучение!",{"type":22,"value":123},"Связи",{"type":22,"value":125},"Собственные",{"type":22,"value":127},"Из",{"type":22,"value":129},"Надо знать",{"type":22,"value":131},"Зависит от",{"type":22,"value":133},"Используется в",{"type":22,"value":135},"Внешние",{"m":137},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":139,"mainContent":140},"group\u002Fbasics\u002Fequations\u002F",{"fullId":141,"shortId":141,"contentRelativePath":142,"title":143,"bookTitle":15,"breadcrumbs":144,"description":147,"stats":148,"connections":154,"contributions":178,"type":191,"children":192},"basics\u002Fequations","01-basics\u002F02-equations","Уравнения",[145],{"icon":146,"title":15,"link":17},"book-outline","\n    Разбор самых популярных уравнений: элементарных, квадратных, систем и т.д.\n    Вы поймёте, зачем их вообще нужно решать и как с их помощью можно описывать процессы в реальной жизни.\n    Разберем и нюансы: преобразования, ОДЗ, \"потеря\" и появление \"лишних\" корней и многие другие.\n  ",{"materials":149,"elements":150},7,{"accent_term":151,"accent_statement":149,"accent_important":152,"problem":153},9,10,82,{"externals":155},[156,165],{"type":157,"items":158},"own",[159],{"type":160,"title":161,"info":162,"link":163,"reason":164},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https:\u002F\u002Fddpu.edu.ua\u002Ffmk\u002Fstudentam\u002F3em\u002F10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":166,"title":15,"items":167},"parent",[168,174],{"type":169,"title":170,"info":171,"link":172,"reason":173},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":160,"title":175,"info":176,"reason":177},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[179,183,187],{"contributorId":180,"name":181,"avatarUrl":182},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png",{"contributorId":184,"name":185,"avatarUrl":186},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg",{"contributorId":188,"name":189,"avatarUrl":190},"igor-radko","Игорь Радько","\u002Ffile\u002Fcontributors\u002Figor-radko\u002Favatar.jpg","group",[193,277,297],{"type":194,"link":195,"title":196,"description":197,"keyLinks":198,"stats":271},"topic","\u002Farticle\u002Fbasics\u002Fequations\u002Felementary\u002F","Элементарные уравнения","\n    Научимся решать простейшие уравнения и преобразовывать равенства.\n    Просто, наглядно, с примерами и без заучивания наизусть кучи странных правил.\n    Это ключевой и необходимый навык в математике и всех остальных точных науках.\n  ",[199,207,214,221,228,235,243,250,257,264],{"link":200,"schemaName":201,"title":202,"key":203,"seo":204,"description":206},"\u002Farticle\u002Fbasics\u002Fequations\u002Felementary\u002F?element=equality","accent_term","Равенство",{},{"title":205},"Что такое равенство?","Два выражения, между которыми стоит знак равно \"=\". Равенство может быть истинным (2 = 2) или ложным (2 = 0).",{"link":208,"schemaName":209,"title":210,"key":211,"seo":212,"description":213},"\u002Farticle\u002Fbasics\u002Fequations\u002Felementary\u002F?element=equality-false-true","diagram","Верное и ложное равенство",{},{},"Если по бокам от знака = стоят одинаковые объекты, то равенство верное. Если разные — ложное.",{"link":215,"schemaName":201,"title":216,"key":217,"seo":218,"description":220},"\u002Farticle\u002Fbasics\u002Fequations\u002Felementary\u002F?element=equation","Уравнение",{},{"title":219},"Что такое уравнение?","Равенство, в котором есть одна или несколько неизвестных или переменных.",{"link":222,"schemaName":201,"title":223,"key":224,"seo":225,"description":227},"\u002Farticle\u002Fbasics\u002Fequations\u002Felementary\u002F?element=equation-solution","Решение уравнения",{},{"title":226},"Что значит решить уравнение?","\"Решения\" или \"корни\" уравнения — числа, которые при подстановке вместо неизвестных превращают его в истинное равенство.\n          \"Решить уравнение\" — значит найти все его корни и доказать, что других корней нет.",{"link":229,"schemaName":230,"title":231,"key":232,"seo":233,"description":234},"\u002Farticle\u002Fbasics\u002Fequations\u002Felementary\u002F?element=same-action-rule","accent_statement","Правило одинакового действия",{},{},"Если над обеими частями истинного равенства совершить одно и то же действие, то полученное равенство тоже будет истинным.",{"link":236,"schemaName":237,"title":238,"key":239,"seo":240,"description":242},"\u002Farticle\u002Fbasics\u002Fequations\u002Felementary\u002F?element=common-mistakes","list","Ошибки при решении уравнений",{},{"title":241},"Типовые ошибки при решении уравнений","Список типовых ошибок, которые новички совершают при решении уравнений.",{"link":244,"schemaName":245,"title":246,"key":247,"seo":248,"description":249},"\u002Farticle\u002Fbasics\u002Fequations\u002Felementary\u002F?element=zachem-reshat-uravneniya","heading","Зачем решать уравнения?",{},{},"Набор примеров, для работы с которыми требуется умение решать уравнения.",{"link":251,"schemaName":245,"title":252,"key":253,"seo":254,"description":256},"\u002Farticle\u002Fbasics\u002Fequations\u002Felementary\u002F?element=treugolnik-idiota","Треугольник формул",{},{"title":255},"Магический треугольник формул","Мнемоническая техника для запоминания простых формул.",{"link":258,"schemaName":245,"title":259,"key":260,"seo":261,"description":263},"\u002Farticle\u002Fbasics\u002Fequations\u002Felementary\u002F?element=uravneniya-v-zhizni","Уравнения в жизни",{},{"title":262},"Где используют уравнения в жизни?","Подборка проблем и ситуаций из реальной жизни, которые можно решить, если перевести их в уравнения.",{"link":265,"schemaName":266,"title":267,"key":268,"seo":269,"description":270},"\u002Fpractice\u002Fbasics\u002Fequations\u002Felementary\u002F?element=linear-root","problems","Формула линейных уравнений",{},{},"Формула, по которой можно очень быстро найти корень любого уравнения вида Ax + B = 0.",{"elements":272},{"accent_term":273,"accent_statement":274,"accent_important":275,"problem":276},3,1,4,35,{"type":8,"link":278,"title":279,"description":280,"keyLinks":281,"stats":295},"\u002Fpage\u002Fbasics\u002Fequations\u002Fzero-product-property\u002F","Нулевые множители","\n    Простой и крайне эффективный способ решать уравнения, состоящие из набора множителей (скобок), произведение которых равно нулю.\n    Этот метод надо знать, так как очень много разных типов уравнений сводится к этому виду.\n  ",[282,288],{"link":283,"schemaName":230,"title":284,"key":285,"seo":286,"description":287},"\u002Fpage\u002Fbasics\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-method","Метод нулевых множителей",{},{},"Удобный способ быстро решать уравнения в виде набора множителей, произведение которых равно нулю.",{"link":289,"schemaName":266,"title":290,"key":291,"seo":293,"description":294},"\u002Fpage\u002Fbasics\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-examples","Отработка метода нулевых множителей",{"title":292},"Отработка метода",{},"Задачи на отработку метода нулевых множителей с подробными решениями.",{"elements":296},{"accent_statement":274,"problem":274},{"type":191,"link":298,"title":299,"description":300,"stats":301},"\u002Fgroup\u002Fbasics\u002Fequations\u002Fquadratic\u002F","Квадратные уравнения","\n    Полный разбор квадратных уравнений: квадратные трехчлены, выделение полного квадрата, дискриминант, формулы Виета, разложение на множители, применения в реальной жизни и даже решение в уме!\n  ",{"materials":302,"elements":303},5,{"accent_term":304,"accent_statement":302,"accent_important":304,"problem":305},6,46,{"contributorsCount":149,"sponsorsCount":302},{"shortBookId":5,"frontNav":308},{"type":14,"shortId":5,"title":15,"flags":309,"link":17,"children":310},{},[311],{"type":191,"separator":312,"shortId":141,"title":143,"flags":313,"link":314,"children":315},true,{},"\u002Fgroup\u002Fbasics\u002Fequations\u002F",[316,323,326],{"type":194,"shortId":317,"title":196,"flags":318,"link":195,"parts":319},"basics\u002Fequations\u002Felementary",{},[320,321,322],"article","summary","practice",{"type":8,"shortId":324,"title":279,"flags":325,"link":278},"basics\u002Fequations\u002Fzero-product-property",{},{"type":191,"separator":327,"shortId":328,"title":299,"flags":329,"link":298,"children":330},false,"basics\u002Fequations\u002Fquadratic",{},[331,337,343,349,355],{"type":194,"shortId":332,"title":333,"flags":334,"link":335,"parts":336},"basics\u002Fequations\u002Fquadratic\u002Fwhat-is-it","Что это такое?",{},"\u002Farticle\u002Fbasics\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F",[320,321,322],{"type":194,"shortId":338,"title":339,"flags":340,"link":341,"parts":342},"basics\u002Fequations\u002Fquadratic\u002Fincomplete","Неполная форма",{},"\u002Farticle\u002Fbasics\u002Fequations\u002Fquadratic\u002Fincomplete\u002F",[320,321,322],{"type":194,"shortId":344,"title":345,"flags":346,"link":347,"parts":348},"basics\u002Fequations\u002Fquadratic\u002Fcompleting-the-square","Полный квадрат",{},"\u002Farticle\u002Fbasics\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F",[320,321,322],{"type":194,"shortId":350,"title":351,"flags":352,"link":353,"parts":354},"basics\u002Fequations\u002Fquadratic\u002Fquadratic-formula","Формула корней",{},"\u002Farticle\u002Fbasics\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F",[320,321