"type":22,"value":123},"Связи",{"type":22,"value":125},"Собственные",{"type":22,"value":127},"Из",{"type":22,"value":129},"Надо знать",{"type":22,"value":131},"Зависит от",{"type":22,"value":133},"Используется в",{"type":22,"value":135},"Внешние",{"m":137},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":139,"mainContent":140},"group/basics/equations/",{"fullId":141,"shortId":141,"contentRelativePath":142,"title":143,"bookTitle":15,"breadcrumbs":144,"description":147,"stats":148,"connections":154,"contributions":178,"type":191,"children":192},"basics/equations","01-basics/02-equations","Уравнения",[145],{"icon":146,"title":15,"link":17},"book-outline","\n    Разбор самых популярных уравнений: элементарных, квадратных, систем и т.д.\n    Вы поймёте, зачем их вообще нужно решать и как с их помощью можно описывать процессы в реальной жизни.\n    Разберем и нюансы: преобразования, ОДЗ, \"потеря\" и появление \"лишних\" корней и многие другие.\n  ",{"materials":149,"elements":150},6,{"accent_term":151,"accent_statement":149,"accent_important":152,"problem":153},9,10,82,{"externals":155},[156,165],{"type":157,"items":158},"own",[159],{"type":160,"title":161,"info":162,"link":163,"reason":164},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https://ddpu.edu.ua/fmk/studentam/3em/10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":166,"title":15,"items":167},"parent",[168,174],{"type":169,"title":170,"info":171,"link":172,"reason":173},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https://math.libretexts.org/","Большое количество материалов и много типовых задач на отработку.",{"type":160,"title":175,"info":176,"reason":177},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[179,183,187],{"contributorId":180,"name":181,"avatarUrl":182},"gwynerva","Пётр Радько","/file/contributors/gwynerva/avatar.png",{"contributorId":184,"name":185,"avatarUrl":186},"nagibin","Николай Нагибин","/file/contributors/nagibin/avatar.jpg",{"contributorId":188,"name":189,"avatarUrl":190},"igor-radko","Игорь Радько","/file/contributors/igor-radko/avatar.jpg","group",[193,283],{"type":194,"link":195,"title":196,"description":197,"keyLinks":198,"stats":277},"topic","/article/basics/equations/elementary/","Элементарные уравнения","\n    Научимся решать простейшие уравнения и преобразовывать равенства.\n    Просто, наглядно, с примерами и без заучивания наизусть кучи странных правил.\n    Это ключевой и необходимый навык в математике и всех остальных точных науках.\n  ",[199,207,214,221,228,235,243,250,257,264,271],{"link":200,"schemaName":201,"title":202,"key":203,"seo":204,"description":206},"/article/basics/equations/elementary/?element=equality","accent_term","Равенство",{},{"title":205},"Что такое равенство?","Два выражения, между которыми стоит знак равно \"=\". Равенство может быть истинным (2 = 2) или ложным (2 = 0).",{"link":208,"schemaName":209,"title":210,"key":211,"seo":212,"description":213},"/article/basics/equations/elementary/?element=equality-false-true","diagram","Верное и ложное равенство",{},{},"Если по бокам от знака = стоят одинаковые объекты, то равенство верное. Если разные — ложное.",{"link":215,"schemaName":201,"title":216,"key":217,"seo":218,"description":220},"/article/basics/equations/elementary/?element=equation","Уравнение",{},{"title":219},"Что такое уравнение?","Равенство, в котором есть одна или несколько неизвестных или переменных.",{"link":222,"schemaName":201,"title":223,"key":224,"seo":225,"description":227},"/article/basics/equations/elementary/?element=equation-solution","Решение уравнения",{},{"title":226},"Что значит решить уравнение?","\"Решения\" или \"корни\" уравнения — числа, которые при подстановке вместо неизвестных превращают его в истинное равенство.\n          \"Решить уравнение\" — значит найти все его корни и доказать, что других корней нет.",{"link":229,"schemaName":230,"title":231,"key":232,"seo":233,"description":234},"/article/basics/equations/elementary/?element=same-action-rule","accent_statement","Правило одинакового действия",{},{},"Если над обеими частями истинного равенства совершить одно и то же действие, то полученное равенство тоже будет истинным.",{"link":236,"schemaName":237,"title":238,"key":239,"seo":240,"description":242},"/article/basics/equations/elementary/?element=common-mistakes","list","Ошибки при решении уравнений",{},{"title":241},"Типовые ошибки при решении уравнений","Список типовых ошибок, которые новички совершают при решении уравнений.",{"link":244,"schemaName":245,"title":246,"key":247,"seo":248,"description":249},"/article/basics/equations/elementary/?element=zachem-reshat-uravneniya","heading","Зачем решать уравнения?",{},{},"Набор примеров, для работы с которыми требуется умение решать уравнения.",{"link":251,"schemaName":245,"title":252,"key":253,"seo":254,"description":256},"/article/basics/equations/elementary/?element=treugolnik-idiota","Треугольник формул",{},{"title":255},"Магический треугольник формул","Мнемоническая техника для запоминания простых формул.",{"link":258,"schemaName":245,"title":259,"key":260,"seo":261,"description":263},"/article/basics/equations/elementary/?element=uravneniya-v-zhizni","Уравнения в жизни",{},{"title":262},"Где используют уравнения в жизни?","Подборка проблем и ситуаций из реальной жизни, которые можно решить, если перевести их в уравнения.",{"link":265,"schemaName":266,"title":267,"key":268,"seo":269,"description":270},"/practice/basics/equations/elementary/?element=linear-root","problems","Формула линейных уравнений",{},{},"Формула, по которой можно очень быстро найти корень любого уравнения вида Ax + B = 0.",{"link":272,"schemaName":266,"title":273,"key":274,"seo":275,"description":276},"/practice/basics/equations/elementary/?element=zero-factors","Нулевые множители",{},{},"Элементарно решаемые уравнения, которые целиком сводятся к произведению множителей, равному нулю.",{"elements":278},{"accent_term":279,"accent_statement":280,"accent_important":281,"problem":282},3,1,4,36,{"type":191,"link":284,"title":285,"description":286,"stats":287},"/group/basics/equations/quadratic/","Квадратные уравнения","\n    Полный разбор квадратных уравнений: квадратные трехчлены, выделение полного квадрата, дискриминант, формулы Виета, разложение на множители, применения в реальной жизни и даже решение в уме!\n  ",{"materials":288,"elements":289},5,{"accent_term":149,"accent_statement":288,"accent_important":149,"problem":290},46,{"contributorsCount":292,"sponsorsCount":288},7,{"shortBookId":5,"frontNav":294},{"type":14,"shortId":5,"title":15,"flags":295,"link":17,"children":296},{},[297],{"type":191,"separator":298,"shortId":141,"title":143,"flags":299,"link":300,"children":301},true,{},"/group/basics/equations/",[302,309],{"type":194,"shortId":303,"title":196,"flags":304,"link":195,"parts":305},"basics/equations/elementary",{},[306,307,308],"article","summary","practice",{"type":191,"separator":310,"shortId":311,"title":285,"flags":312,"link":284,"children":313},false,"basics/equations/quadratic",{},[314,320,326,332,338],{"type":194,"shortId":315,"title":316,"flags":317,"link":318,"parts":319},"basics/equations/quadratic/what-is-it","Что это такое?",{},"/article/basics/equations/quadratic/what-is-it/",[306,307,308],{"type":194,"shortId":321,"title":322,"flags":323,"link":324,"parts":325},"basics/equations/quadratic/incomplete","Неполная форма",{},"/article/basics/equations/quadratic/incomplete/",[306,307,308],{"type":194,"shortId":327,"title":328,"flags":329,"link":330,"parts":331},"basics/equatio