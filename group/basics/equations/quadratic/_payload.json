2,"value":46},"Ключевые элементы",{"type":22,"value":48},"Статистика",{"type":22,"value":50},"Темная",{"type":22,"value":30},{"type":22,"value":53},"Языки",{"type":22,"value":55},"Системная",{"type":22,"value":57},"Статья",{"type":22,"value":59},"Настройки",{"type":22,"value":61},"Собрано",{"type":22,"value":63},"Конспект",{"type":22,"value":65},"Контент",{"type":22,"value":67},"Практика",{"type":22,"value":69},"Erudit",{"type":22,"value":71},"Вы собираетесь перейти на страницу контента:",{"type":22,"value":73},"Добавить перевод",{"type":22,"value":75},"Главная страница",{"type":22,"value":77},"Авторы",{"type":22,"value":79},"Спонсоры",{"type":22,"value":81},"Поиск по сайту...",{"type":22,"value":83},"Ищем еще...",{"type":22,"value":85},"Ничего не найдено",{"type":22,"value":87},"Больше результатов нет",{"type":22,"value":89},"Контента нет.",{"type":22,"value":91},"К оглавлению",{"type":22,"value":93},"Об учебнике",{"type":22,"value":95},"Разработка",{"type":22,"value":97},"Профиль",{"type":22,"value":99},"Дополнение",{"type":22,"value":101},"Список людей, которые внесли вклад в материалы проекта: предложили ценные идеи, вносили корректировки в существующий материал или же написали собственный!",{"type":22,"value":103},"Вы тоже можете помочь проекту, внести свой вклад и попасть на эту страницу!",{"type":22,"value":105},"Стать автором",{"type":22,"value":107},"Пока что авторов нет. Вы можете стать первым!",{"type":22,"value":109},"Вклад",{"type":22,"value":111},"Список людей и организаций, которые поддерживают проект финансово. Благодаря им проект может существовать и развиваться. Если вы хотите помочь проекту, то тоже можете стать спонсором и попасть на эту страницу!",{"type":22,"value":113},"Редактор",{"type":22,"value":115},"Стать спонсором",{"type":22,"value":117},"Пока что спонсоров нет. Вы можете стать первым!",{"type":27,"value":119},"(name) => `Персональная страница автора \"${name}\" с данными о вкладе в проект.`",{"type":22,"value":121},"Начать изучение!",{"type":22,"value":123},"Связи",{"type":22,"value":125},"Собственные",{"type":22,"value":127},"Из",{"type":22,"value":129},"Надо знать",{"type":22,"value":131},"Зависит от",{"type":22,"value":133},"Используется в",{"type":22,"value":135},"Внешние",{"m":137},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":139,"mainContent":140},"group/basics/equations/quadratic/",{"fullId":141,"shortId":141,"contentRelativePath":142,"title":143,"bookTitle":15,"breadcrumbs":144,"description":151,"decoration":152,"stats":153,"connections":159,"contributions":189,"type":194,"children":195},"basics/equations/quadratic","01-basics/02-equations/02-quadratic","Квадратные уравнения",[145,147],{"icon":146,"title":15,"link":17},"book-outline",{"icon":148,"title":149,"link":150},"folder-open","Уравнения","/group/basics/equations/","\n    Полный разбор квадратных уравнений: квадратные трехчлены, выделение полного квадрата, дискриминант, формулы Виета, разложение на множители, применения в реальной жизни и даже решение в уме!\n  ","content/01-basics/02-equations/02-quadratic/decoration.svg",{"materials":154,"elements":155},4,{"accent_term":156,"accent_statement":154,"accent_important":157,"problem":158},6,5,37,{"hardDependencies":160,"externals":167},[161],{"type":162,"reason":163,"contentType":164,"title":165,"link":166},"hard","Перед решением квадратных уравнений вы должны уметь решать элементарные. Иначе никак. Даже не пытайтесь.","topic","Элементарные уравнения","/article/basics/equations/elementary/",[168,177],{"type":169,"title":149,"items":170},"parent",[171],{"type":172,"title":173,"info":174,"link":175,"reason":176},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https://ddpu.edu.ua/fmk/studentam/3em/10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":169,"title":15,"items":178},[179,185],{"type":180,"title":181,"info":182,"link":183,"reason":184},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https://math.libretexts.org/","Большое количество материалов и много типовых задач на отработку.",{"type":172,"title":186,"info":187,"reason":188},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[190],{"contributorId":191,"name":192,"avatarUrl":193},"gwynerva","Пётр Радько","/file/contributors/gwynerva/avatar.png","group",[196,226,259,297],{"type":164,"link":197,"title":198,"description":199,"keyLinks":200,"stats":222},"/article/basics/equations/quadratic/what-is-it/","Что это такое?","\n    Разберемся, что вообще такое квадратное уравнение и квадратный трехчлен.\n    Как эти термины появились, чем они похожи, а чем отличаются.\n    Научимся определять, является ли уравнение квадратным.\n  ",[201,208,216],{"link":202,"schemaName":203,"title":204,"key":205,"seo":206,"description":207},"/article/basics/equations/quadratic/what-is-it/?element=problematic-equations","problems","Квадратные уравнения в жизни",{},{},"Примеры разнообразных жизненных ситуаций, которые сводятся к квадратным уравнениям.\n          Так станет понятно, почему вообще нужно уметь их решать.",{"link":209,"schemaName":210,"title":211,"key":212,"seo":213,"description":215},"/article/basics/equations/quadratic/what-is-it/?element=quadratic-polynomial","accent_term","Квадратный трёхчлен",{},{"title":214},"Что такое квадратный трёхчлен?","Многочлен с максимальной степенью неизвестной, равной двум.\n          Выступает \"шаблоном\" или \"общим видом\" для всех квадратных уравнений.",{"link":217,"schemaName":210,"title":218,"key":219,"seo":220,"description":221},"/article/basics/equations/quadratic/what-is-it/?element=quadratic-equation","Квадратное уравнение",{},{},"Любое уравнение, которое преобразованиями без потери корней можно привести к виду квадратного трёхчлена.",{"elements":223},{"accent_term":224,"accent_important":225,"problem":157},2,1,{"type":164,"link":227,"title":228,"description":229,"keyLinks":230,"stats":255},"/article/basics/equations/quadratic/incomplete/","Неполная форма","\n    Неполные квадратные уравнения — простейшие формы квадратных уравнений, в которых отсутствуют коэффициент B, C или оба сразу.\n    Разберемся, как их правильно решать в каждом отдельном случае.\n  ",[231,238,246],{"link":232,"schemaName":210,"title":233,"key":234,"seo":235,"description":237},"/article/basics/equations/quadratic/incomplete/?element=quadratic-missing-terms","Неполное квадратное уравнение",{},{"title":236},"Что такое неполное квадратное уравнение?","Квадратное уравнение, у которого равен нулю коэффициент B или C или оба сразу.",{"link":239,"schemaName":240,"title":241,"key":242,"seo":243,"description":245},"/article/basics/equations/quadratic/incomplete/?element=reshenie-nepolnykh-kvadratnykh-uravneniy","heading","Решение таких уравнений",{},{"title":244},"Как решать неполные квадратные уравнения?","Подробный разбор решения всех видов неполных квадратных уравнений с выводом общих формул.",{"link":247,"schemaName":248,"title":249,"key":250,"seo":252,"description":254},"/summary/basics/equations/quadratic/incomplete/?element=all-formulas","diagram","Общие формулы неполных квадратных уравнений",{"title":251},"Общие формулы",{"title":253},"Общие формулы для решения неполных квадратных уравнений","Формулы для всех трёх типов неполных квадратных уравнений:\n          когда \"B\" и \"C\" равны нулю, когда \"C\" равен нулю и когда \"B\" равен нулю.",{"elements":256},{"accent_term":225,"accent_statement":257,"accent_important":225,"problem":258},3,7,{"type":164,"link":260,"title":261,"description":262,"keyLinks":263,"stats":294},"/article/basics/equations/quadratic/completing-the-square/","Полный квадрат","\n    Процесс \"запаковки\" развёрнутого выражения в короткую скобку в квадрате.\n    С его помощью можно решить любое квадратное уравнение!\n    Разберёмся, как его проводить на подробных и наглядных примерах с визуализацией.\n  ",[264,271,278,286],{"link":265,"schemaName":210,"title":266,"key":267,"seo":268,"description":270},"/article/basics/equations/quadratic/completing-the-square/?element=what-is-it","Выделение полного квадрата",{"title":198},{"title":269},"Что такое выделение полного квадрата?","\"Запаковка\" развёрнутого выражения в скобку в квадрате.",{"link":272,"schemaName":240,"title":273,"key":274,"seo":275,"description":277},"/article/basics/equations/quadratic/completing-the-square/?element=zachem-etim-zanimatsya","Зачем это делать?",{},{"title":276},"Зачем выделять полный квадрат?","Выделение полного квадрата -- мощный инструмент для преобразования выражения и решения квадратных уравнений.",{"link":279,"schemaName":240,"title":280,"key":281,"seo":283,"description":285},"/article/basics/equations/quadratic/completing-the-square/?element=reshenie-kvadratnykh-uravneniy","Решение квадратных уравнений",{"title":282},"Решение уравнений",{"title":284},"Решение квадратных уравнений через выделение полного квадрата","Выделение полного квадрата -- ключ к решению абсолютно любых квадратных уравнений.",{"link":287,"schemaName":288,"title":289,"key":290,"seo":291,"description":293},"/summary/basics/equations/quadratic/completing-the-square/?element=vizualizatsiya-protsessa","image","Визуализация процесса",{},{"title":292},"Визуализация выделения полного квадрата","Как в прямом смысле из фигур поменьше собирают или \"выделяют\" большой квадрат.",{"elements":295},{"accent_term":225,"accent_important":225,"problem":296},11,{"type":164,"link":298,"title":299,"description":300,"keyLinks":301,"stats":386},"/article/basics/equations/quadratic/quadratic-formula/","Формула корней","\n    Понятный вывод общей формулы корней квадратного уравнения с подробными объяснениями каждого шага.\n    Пояснение, что такое дискриминант, откуда он взялся и почему по нему можно узнать количество корней.\n  ",[302,310,317,325,332,339,347,355,362,370,378],{"link":303,"schemaName":304,"title":305,"key":306,"seo":307,"description":309},"/article/basics/equations/quadratic/quadratic-formula/?element=general-formulas","accent_important","Общие формулы корней",{},{"title":308},"Общие формулы корней уравнений","Общие формулы корней позволяют очень быстро решать сложные виды уравнений.",{"link":311,"schemaName":210,"title":312,"key":313,"seo":314,"description":316},"/article/basics/equations/quadratic/quadratic-formula/?element=discriminant","Дискриминант",{},{"title":315},"Дискриминант квадратного уравнения","Особое число, высчитываемое через коэффициенты квадратного уравнения, которое позволяет понять, сколько корней имеет это уравнение.",{"link":318,"schemaName":319,"title":320,"key":321,"seo":323,"description":324},"/article/basics/equations/quadratic/quadratic-formula/?element=formula","accent_statement","Формула корней квадратного уравнения",{"title":322},"Корни квадратного уравнения",{},"Общая формула, которая позволяет найти корни любого квадратного уравнения, если подставить в неё конкретные числа вместо буквенных коэффициентов.",{"link":326,"schemaName":210,"title":327,"key":328,"seo":329,"description":331},"/article/basics/equations/quadratic/quadratic-formula/?element=biquadratic","Биквадратное уравнение",{},{"title":330},"Что такое биквадратное уравнение?","Особый вид уравнений четвёртой степени, которые можно решить сведением к квадратному уравнению.",{"link":333,"schemaName":304,"title":334,"key":335,"seo":337,"description":338},"/article/basics/equations/quadratic/quadratic-formula/?element=nerazreshimost-uravneniy-vysshikh-stepeney","Пределы общих формул корней",{"title":336},"Пределы общих формул",{},"Для уравнений выше четвёртой степени не существует общих формул корней.",{"link":340,"schemaName":248,"title":341,"key":342,"seo":344,"description":346},"/summary/basics/equations/quadratic/quadratic-formula/?element=algorithm","Алгоритм решения квадратного уравнения",{"title":343},"Алгоритм решения",{"title":345},"Алгоритм решения квадратных уравнений","Диаграмма, которая показывает, как решить абсолютно любое квадратное уравнение.",{"link":348,"schemaName":349,"title":350,"key":351,"seo":352,"description":354},"/summary/basics/equations/quadratic/quadratic-formula/?element=vyvod-formuly-korney","table","Вывод формулы корней",{},{"title":353},"Вывод формулы корней квадратного уравнения","Пошаговый вывод формулы корней квадратного уравнения с пояснениями.",{"link":356,"schemaName":203,"title":357,"key":358,"seo":359,"description":361},"/practice/basics/equations/quadratic/quadratic-formula/?element=chetnyy-koeffitsient","Чётный коэффициент",{},{"title":360},"Квадратное уравнение с чётным коэффициентом","Общая и более простая формула корней квадратного уравнения с чётным коэффициентом B.",{"link":363,"schemaName":364,"title":365,"key":366,"seo":367,"description":369},"/practice/basics/equations/quadratic/quadratic-formula/?element=sridharas-method","problem","Метод Сридхары",{},{"title":368},"Формула корней квадратного уравнения по методу Сридхары","Более простой способ вывести формулу корней квадратного уравнения, но с небольшим трюком.",{"link":371,"schemaName":203,"title":372,"key":373,"seo":374,"description":377},"/practice/basics/equations/quadratic/quadratic-formula/?element=quadratic-in-f","Трёхчленное уравнение",{},{"title":375,"description":376},"Что такое трёхчленное уравнение?","Определение трёхчленных уравнений и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений из трёх членов с одинаковой \"неизвестной функцией\" в разных степенях, которые могут быть сведены к квадратному уравнению.",{"link":379,"schemaName":203,"title":380,"key":381,"seo":382,"description":385},"/practice/basics/equations/quadratic/quadratic-formula/?element=palindromials","Возвратное уравнение",{},{"title":383,"description":384},"Что такое возвратное уравнение?","Определение возвратных уравнений (уравнений палиндромов) и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений, в которых коэффициенты повторяются зеркально относительно \"центра\" уравнения.",{"elements":387},{"accent_term":224,"accent_statement":225,"accent_important":224,"problem":388},14,{"contributorsCount":258,"sponsorsCount":157},{"shortBookId":5,"frontNav":391},{"type":14,"shortId":5,"title":15,"flags":392,"link":17,"children":393},{},[394],{"type":194,"separator":395,"shortId":396,"title":149,"flags":397,"link":150,"children":398},true,"basics/equations",{},[399,406],{"type":164,"shortId":400,"title":165,"flags":401,"link":166,"parts":402},"basics/equations/elementary",{},[403,404,405],"article","summary","practice",{"type":194,"separator":407,"shortId":141,"title":143,"flags":408,"link":409,"children":410},false,{},"/group/basics/equations/quadratic/",[411,415,419,423],{"type":164,"shortId":412,"title":198,"flags":413,"link":197,"parts":414},"basics/equations/quadratic/what-is-it",{},[403,404,405],{"type":164,"shortId":416,"title":228,"flags":417,"link":227,"parts":418},"basics/equations/quadratic/incomplete",{},[403,404,405],{"type":164,"shortId":420,"title":261,"flags":421,"link":260,"parts":422},"basics/equations/quadratic/completing-the-square",{},[403,404,405],{"type":164,"shortId":424,"title":299,"flags":425,"link":298,"parts":426},"basics/equations/quadratic/quadratic-formula",{},[403,404,405],1772696730083]