2,"value":46},"Ключевые элементы",{"type":22,"value":48},"Статистика",{"type":22,"value":50},"Темная",{"type":22,"value":30},{"type":22,"value":53},"Языки",{"type":22,"value":55},"Системная",{"type":22,"value":57},"Статья",{"type":22,"value":59},"Настройки",{"type":22,"value":61},"Собрано",{"type":22,"value":63},"Конспект",{"type":22,"value":65},"Контент",{"type":22,"value":67},"Практика",{"type":22,"value":69},"Erudit",{"type":22,"value":71},"Вы собираетесь перейти на страницу контента:",{"type":22,"value":73},"Добавить перевод",{"type":22,"value":75},"Главная страница",{"type":22,"value":77},"Авторы",{"type":22,"value":79},"Спонсоры",{"type":22,"value":81},"Поиск по сайту...",{"type":22,"value":83},"Ищем еще...",{"type":22,"value":85},"Ничего не найдено",{"type":22,"value":87},"Больше результатов нет",{"type":22,"value":89},"Контента нет.",{"type":22,"value":91},"К оглавлению",{"type":22,"value":93},"Об учебнике",{"type":22,"value":95},"Разработка",{"type":22,"value":97},"Профиль",{"type":22,"value":99},"Дополнение",{"type":22,"value":101},"Список людей, которые внесли вклад в материалы проекта: предложили ценные идеи, вносили корректировки в существующий материал или же написали собственный!",{"type":22,"value":103},"Вы тоже можете помочь проекту, внести свой вклад и попасть на эту страницу!",{"type":22,"value":105},"Стать автором",{"type":22,"value":107},"Пока что авторов нет. Вы можете стать первым!",{"type":22,"value":109},"Вклад",{"type":22,"value":111},"Редактор",{"type":22,"value":113},"Список людей и организаций, которые поддерживают проект финансово. Благодаря им проект может существовать и развиваться. Если вы хотите помочь проекту, то тоже можете стать спонсором и попасть на эту страницу!",{"type":22,"value":115},"Стать спонсором",{"type":27,"value":117},"(name) => `Персональная страница автора \"${name}\" с данными о вкладе в проект.`",{"type":22,"value":119},"Пока что спонсоров нет. Вы можете стать первым!",{"type":22,"value":121},"Начать изучение!",{"type":22,"value":123},"Связи",{"type":22,"value":125},"Собственные",{"type":22,"value":127},"Из",{"type":22,"value":129},"Надо знать",{"type":22,"value":131},"Зависит от",{"type":22,"value":133},"Используется в",{"type":22,"value":135},"Внешние",{"m":137},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":139,"mainContent":140},"group/basics/equations/quadratic/",{"fullId":141,"shortId":141,"contentRelativePath":142,"title":143,"bookTitle":15,"breadcrumbs":144,"description":151,"decoration":152,"stats":153,"connections":158,"contributions":188,"type":193,"children":194},"basics/equations/quadratic","01-basics/02-equations/02-quadratic","Квадратные уравнения",[145,147],{"icon":146,"title":15,"link":17},"book-outline",{"icon":148,"title":149,"link":150},"folder-open","Уравнения","/group/basics/equations/","\n    Полный разбор квадратных уравнений: квадратные трехчлены, выделение полного квадрата, дискриминант, формулы Виета, разложение на множители, применения в реальной жизни и даже решение в уме!\n  ","content/01-basics/02-equations/02-quadratic/decoration.svg",{"materials":154,"elements":155},5,{"accent_term":156,"accent_statement":154,"accent_important":156,"problem":157},6,46,{"hardDependencies":159,"externals":166},[160],{"type":161,"reason":162,"contentType":163,"title":164,"link":165},"hard","Перед решением квадратных уравнений вы должны уметь решать элементарные. Иначе никак. Даже не пытайтесь.","topic","Элементарные уравнения","/article/basics/equations/elementary/",[167,176],{"type":168,"title":149,"items":169},"parent",[170],{"type":171,"title":172,"info":173,"link":174,"reason":175},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https://ddpu.edu.ua/fmk/studentam/3em/10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":168,"title":15,"items":177},[178,184],{"type":179,"title":180,"info":181,"link":182,"reason":183},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https://math.libretexts.org/","Большое количество материалов и много типовых задач на отработку.",{"type":171,"title":185,"info":186,"reason":187},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[189],{"contributorId":190,"name":191,"avatarUrl":192},"gwynerva","Пётр Радько","/file/contributors/gwynerva/avatar.png","group",[195,225,258,296,388],{"type":163,"link":196,"title":197,"description":198,"keyLinks":199,"stats":221},"/article/basics/equations/quadratic/what-is-it/","Что это такое?","\n    Разберемся, что вообще такое квадратное уравнение и квадратный трехчлен.\n    Как эти термины появились, чем они похожи, а чем отличаются.\n    Научимся определять, является ли уравнение квадратным.\n  ",[200,207,215],{"link":201,"schemaName":202,"title":203,"key":204,"seo":205,"description":206},"/article/basics/equations/quadratic/what-is-it/?element=problematic-equations","problems","Квадратные уравнения в жизни",{},{},"Примеры разнообразных жизненных ситуаций, которые сводятся к квадратным уравнениям.\n          Так станет понятно, почему вообще нужно уметь их решать.",{"link":208,"schemaName":209,"title":210,"key":211,"seo":212,"description":214},"/article/basics/equations/quadratic/what-is-it/?element=quadratic-polynomial","accent_term","Квадратный трёхчлен",{},{"title":213},"Что такое квадратный трёхчлен?","Многочлен с максимальной степенью неизвестной, равной двум.\n          Выступает \"шаблоном\" или \"общим видом\" для всех квадратных уравнений.",{"link":216,"schemaName":209,"title":217,"key":218,"seo":219,"description":220},"/article/basics/equations/quadratic/what-is-it/?element=quadratic-equation","Квадратное уравнение",{},{},"Любое уравнение, которое преобразованиями без потери корней можно привести к виду квадратного трёхчлена.",{"elements":222},{"accent_term":223,"accent_important":224,"problem":154},2,1,{"type":163,"link":226,"title":227,"description":228,"keyLinks":229,"stats":254},"/article/basics/equations/quadratic/incomplete/","Неполная форма","\n    Неполные квадратные уравнения — простейшие формы квадратных уравнений, в которых отсутствуют коэффициент B, C или оба сразу.\n    Разберемся, как их правильно решать в каждом отдельном случае.\n  ",[230,237,245],{"link":231,"schemaName":209,"title":232,"key":233,"seo":234,"description":236},"/article/basics/equations/quadratic/incomplete/?element=quadratic-missing-terms","Неполное квадратное уравнение",{},{"title":235},"Что такое неполное квадратное уравнение?","Квадратное уравнение, у которого равен нулю коэффициент B или C или оба сразу.",{"link":238,"schemaName":239,"title":240,"key":241,"seo":242,"description":244},"/article/basics/equations/quadratic/incomplete/?element=reshenie-nepolnykh-kvadratnykh-uravneniy","heading","Решение таких уравнений",{},{"title":243},"Как решать неполные квадратные уравнения?","Подробный разбор решения всех видов неполных квадратных уравнений с выводом общих формул.",{"link":246,"schemaName":247,"title":248,"key":249,"seo":251,"description":253},"/summary/basics/equations/quadratic/incomplete/?element=all-formulas","diagram","Общие формулы неполных квадратных уравнений",{"title":250},"Общие формулы",{"title":252},"Общие формулы для решения неполных квадратных уравнений","Формулы для всех трёх типов неполных квадратных уравнений:\n          когда \"B\" и \"C\" равны нулю, когда \"C\" равен нулю и когда \"B\" равен нулю.",{"elements":255},{"accent_term":224,"accent_statement":256,"accent_important":224,"problem":257},3,7,{"type":163,"link":259,"title":260,"description":261,"keyLinks":262,"stats":293},"/article/basics/equations/quadratic/completing-the-square/","Полный квадрат","\n    Процесс \"запаковки\" развёрнутого выражения в короткую скобку в квадрате.\n    С его помощью можно решить любое квадратное уравнение!\n    Разберёмся, как его проводить на подробных и наглядных примерах с визуализацией.\n  ",[263,270,277,285],{"link":264,"schemaName":209,"title":265,"key":266,"seo":267,"description":269},"/article/basics/equations/quadratic/completing-the-square/?element=what-is-it","Выделение полного квадрата",{"title":197},{"title":268},"Что такое выделение полного квадрата?","\"Запаковка\" развёрнутого выражения в скобку в квадрате.",{"link":271,"schemaName":239,"title":272,"key":273,"seo":274,"description":276},"/article/basics/equations/quadratic/completing-the-square/?element=zachem-etim-zanimatsya","Зачем это делать?",{},{"title":275},"Зачем выделять полный квадрат?","Выделение полного квадрата -- мощный инструмент для преобразования выражения и решения квадратных уравнений.",{"link":278,"schemaName":239,"title":279,"key":280,"seo":282,"description":284},"/article/basics/equations/quadratic/completing-the-square/?element=reshenie-kvadratnykh-uravneniy","Решение квадратных уравнений",{"title":281},"Решение уравнений",{"title":283},"Решение квадратных уравнений через выделение полного квадрата","Выделение полного квадрата -- ключ к решению абсолютно любых квадратных уравнений.",{"link":286,"schemaName":287,"title":288,"key":289,"seo":290,"description":292},"/summary/basics/equations/quadratic/completing-the-square/?element=vizualizatsiya-protsessa","image","Визуализация процесса",{},{"title":291},"Визуализация выделения полного квадрата","Как в прямом смысле из фигур поменьше собирают или \"выделяют\" большой квадрат.",{"elements":294},{"accent_term":224,"accent_important":224,"problem":295},11,{"type":163,"link":297,"title":298,"description":299,"keyLinks":300,"stats":385},"/article/basics/equations/quadratic/quadratic-formula/","Формула корней","\n    Понятный вывод общей формулы корней квадратного уравнения с подробными объяснениями каждого шага.\n    Пояснение, что такое дискриминант, откуда он взялся и почему по нему можно узнать количество корней.\n  ",[301,309,316,324,331,338,346,354,361,369,377],{"link":302,"schemaName":303,"title":304,"key":305,"seo":306,"description":308},"/article/basics/equations/quadratic/quadratic-formula/?element=general-formulas","accent_important","Общие формулы корней",{},{"title":307},"Общие формулы корней уравнений","Общие формулы корней позволяют очень быстро решать сложные виды уравнений.",{"link":310,"schemaName":209,"title":311,"key":312,"seo":313,"description":315},"/article/basics/equations/quadratic/quadratic-formula/?element=discriminant","Дискриминант",{},{"title":314},"Дискриминант квадратного уравнения","Особое число, высчитываемое через коэффициенты квадратного уравнения, которое позволяет понять, сколько корней имеет это уравнение.",{"link":317,"schemaName":318,"title":319,"key":320,"seo":322,"description":323},"/article/basics/equations/quadratic/quadratic-formula/?element=formula","accent_statement","Формула корней квадратного уравнения",{"title":321},"Корни квадратного уравнения",{},"Общая формула, которая позволяет найти корни любого квадратного уравнения, если подставить в неё конкретные числа вместо буквенных коэффициентов.",{"link":325,"schemaName":209,"title":326,"key":327,"seo":328,"description":330},"/article/basics/equations/quadratic/quadratic-formula/?element=biquadratic","Биквадратное уравнение",{},{"title":329},"Что такое биквадратное уравнение?","Особый вид уравнений четвёртой степени, которые можно решить сведением к квадратному уравнению.",{"link":332,"schemaName":303,"title":333,"key":334,"seo":336,"description":337},"/article/basics/equations/quadratic/quadratic-formula/?element=nerazreshimost-uravneniy-vysshikh-stepeney","Пределы общих формул корней",{"title":335},"Пределы общих формул",{},"Для уравнений выше четвёртой степени не существует общих формул корней.",{"link":339,"schemaName":247,"title":340,"key":341,"seo":343,"description":345},"/summary/basics/equations/quadratic/quadratic-formula/?element=algorithm","Алгоритм решения квадратного уравнения",{"title":342},"Алгоритм решения",{"title":344},"Алгоритм решения квадратных уравнений","Диаграмма, которая показывает, как решить абсолютно любое квадратное уравнение.",{"link":347,"schemaName":348,"title":349,"key":350,"seo":351,"description":353},"/summary/basics/equations/quadratic/quadratic-formula/?element=vyvod-formuly-korney","table","Вывод формулы корней",{},{"title":352},"Вывод формулы корней квадратного уравнения","Пошаговый вывод формулы корней квадратного уравнения с пояснениями.",{"link":355,"schemaName":202,"title":356,"key":357,"seo":358,"description":360},"/practice/basics/equations/quadratic/quadratic-formula/?element=chetnyy-koeffitsient","Чётный коэффициент",{},{"title":359},"Квадратное уравнение с чётным коэффициентом","Общая и более простая формула корней квадратного уравнения с чётным коэффициентом B.",{"link":362,"schemaName":363,"title":364,"key":365,"seo":366,"description":368},"/practice/basics/equations/quadratic/quadratic-formula/?element=sridharas-method","problem","Метод Сридхары",{},{"title":367},"Формула корней квадратного уравнения по методу Сридхары","Более простой способ вывести формулу корней квадратного уравнения, но с небольшим трюком.",{"link":370,"schemaName":202,"title":371,"key":372,"seo":373,"description":376},"/practice/basics/equations/quadratic/quadratic-formula/?element=quadratic-in-f","Трёхчленное уравнение",{},{"title":374,"description":375},"Что такое трёхчленное уравнение?","Определение трёхчленных уравнений и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений из трёх членов с одинаковой \"неизвестной функцией\" в разных степенях, которые могут быть сведены к квадратному уравнению.",{"link":378,"schemaName":202,"title":379,"key":380,"seo":381,"description":384},"/practice/basics/equations/quadratic/quadratic-formula/?element=palindromials","Возвратное уравнение",{},{"title":382,"description":383},"Что такое возвратное уравнение?","Определение возвратных уравнений (уравнений палиндромов) и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений, в которых коэффициенты повторяются зеркально относительно \"центра\" уравнения.",{"elements":386},{"accent_term":223,"accent_statement":224,"accent_important":223,"problem":387},14,{"type":163,"link":389,"title":390,"description":391,"keyLinks":392,"stats":434},"/article/basics/equations/quadratic/factoring/","Разложение на множители","\n    Запись квадратных трехчленов и квадратных уравнений в виде произведения множителей, а не суммы слагаемых.\n    Помогает быстро решать уравнения, упрощать сложные выражения и сразу видеть корни.\n  ",[393,399,407,413,420,426],{"link":394,"schemaName":303,"title":395,"key":396,"seo":397,"description":398},"/article/basics/equations/quadratic/factoring/?element=i-plyus-i-umnozhenie-vazhny","И плюс, и умножение важны!",{},{},"В разных ситуациях надо уметь записывать выражения и через сумму, и через произведение множителей.",{"link":400,"schemaName":401,"title":402,"key":403,"seo":404,"description":406},"/article/basics/equations/quadratic/factoring/?element=why-factoring","list","Зачем это нужно?",{},{"title":405},"Чем полезно разложение квадратного трёхчлена на множители?","Разложение квадратных трёхчленов на множители позволяет упрощать выражения, сразу видеть их корни и даёт альтернативный способ решать квадратные уравнения.",{"link":408,"schemaName":239,"title":409,"key":410,"seo":411,"description":412},"/article/basics/equations/quadratic/factoring/?element=razlozhenie-vruchnuyu","Разложение \"вручную\"",{},{},"Методика разложения \"простых\" квадратных трёхчленов на множители вручную.",{"link":414,"schemaName":318,"title":415,"key":416,"seo":417,"description":419},"/article/basics/equations/quadratic/factoring/?element=general-factoring","Разложение в общем виде",{},{"title":418},"Формула разложения квадратного трёхчлена на множители","Если у квадратного трёхчлена есть корни, то его всегда можно разложить на множители с участием этих корней.",{"link":421,"schemaName":247,"title":422,"key":423,"seo":424,"description":425},"/summary/basics/equations/quadratic/factoring/?element=varianty-razlozheniya","Варианты разложения",{},{},"Все возможные варианты разложения квадратного трёхчлена на множители.",{"link":427,"schemaName":202,"title":428,"key":429,"seo":431,"description":433},"/practice/basics/equations/quadratic/factoring/?element=razlozhenie-bikvadratnykh-trekhchlenov","Разложение биквадратных трёхчленов",{"title":430},"Разложение биквадратных",{"title":432},"Разложение биквадратного трёхчлена на множители","Задачи на отработку разложения биквадратных трёхчленов на множители через промежуточную подстановку.",{"elements":435},{"accent_statement":224,"accent_important":224,"problem":436},9,{"contributorsCount":257,"sponsorsCount":154},{"shortBookId":5,"frontNav":439},{"type":14,"shortId":5,"title":15,"flags":440,"link":17,"children":441},{},[442],{"type":193,"separator":443,"shortId":444,"title":149,"flags":445,"link":150,"children":446},true,"basics/equations",{},[447,454],{"type":163,"shortId":448,"title":164,"flags":449,"link":165,"parts":450},"basics/equations/elementary",{},[451,452,453],"article","summary","practice",{"type":193,"separator":455,"shortId":141,"title":143,"flags":456,"link":457,"children":458},false,{},"/group/basics/equations/quadratic/",[459,463,467,471,475],{"type":163,"shortId":460,"title":197,"flags":461,"link":196,"parts":462},"basics/equations/quadratic/what-is-it",{},[451,452,453],{"type":163,"shortId":464,"title":227,"flags":465,"link":226,"parts":466},"basics/equations/quadratic/incomplete",{},[451,452,453],{"type":163,"shortId":468,"title":260,"flags":469,"link":259,"parts":470},"basics/equations/quadratic/completing-the-square",{},[451,452,453],{"type":163,"shortId":472,"title"