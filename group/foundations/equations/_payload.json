роект.`",{"type":22,"value":121},"Путь",{"type":22,"value":123},"Начать изучение!",{"type":22,"value":125},"Связи",{"type":22,"value":127},"Обновлено",{"type":22,"value":129},"Собственные",{"type":22,"value":131},"Из",{"type":22,"value":133},"Надо знать",{"type":22,"value":135},"Зависит от",{"type":22,"value":137},"Используется в",{"type":22,"value":139},"Внешние",{"m":141},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":143,"mainContent":144},"group\u002Ffoundations\u002Fequations\u002F",{"fullId":145,"shortId":145,"contentRelativePath":146,"title":147,"bookTitle":15,"breadcrumbs":148,"lastmod":151,"description":152,"stats":153,"connections":159,"contributions":183,"type":196,"children":197},"foundations\u002Fequations","01-foundations\u002F02-equations","Уравнения",[149],{"icon":150,"title":15,"link":17},"book-outline","2026-03-30T15:21:58+03:00","\n    Разбор самых популярных уравнений: элементарных, квадратных, систем и т.д.\n    Вы поймёте, зачем их вообще нужно решать и как с их помощью можно описывать процессы в реальной жизни.\n    Разберем и нюансы: преобразования, ОДЗ, \"потеря\" и появление \"лишних\" корней и многие другие.\n  ",{"materials":154,"elements":155},9,{"accent_term":154,"accent_statement":156,"accent_important":157,"problem":158},12,15,106,{"externals":160},[161,170],{"type":162,"items":163},"own",[164],{"type":165,"title":166,"info":167,"link":168,"reason":169},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https:\u002F\u002Fddpu.edu.ua\u002Ffmk\u002Fstudentam\u002F3em\u002F10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":171,"title":15,"items":172},"parent",[173,179],{"type":174,"title":175,"info":176,"link":177,"reason":178},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":165,"title":180,"info":181,"reason":182},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[184,188,192],{"contributorId":185,"name":186,"avatarUrl":187},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png",{"contributorId":189,"name":190,"avatarUrl":191},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg",{"contributorId":193,"name":194,"avatarUrl":195},"igor-radko","Игорь Радько","\u002Ffile\u002Fcontributors\u002Figor-radko\u002Favatar.jpg","group",[198,282,302],{"type":199,"link":200,"title":201,"description":202,"keyLinks":203,"stats":276},"topic","\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F","Элементарные уравнения","\n    Научимся решать простейшие уравнения и преобразовывать равенства.\n    Просто, наглядно, с примерами и без заучивания наизусть кучи странных правил.\n    Это ключевой и необходимый навык в математике и всех остальных точных науках.\n  ",[204,212,219,226,233,240,248,255,262,269],{"link":205,"schemaName":206,"title":207,"key":208,"seo":209,"description":211},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equality","accent_term","Равенство",{},{"title":210},"Что такое равенство?","Два выражения, между которыми стоит знак равно \"=\". Равенство может быть истинным (2 = 2) или ложным (2 = 0).",{"link":213,"schemaName":214,"title":215,"key":216,"seo":217,"description":218},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equality-false-true","diagram","Верное и ложное равенство",{},{},"Если по бокам от знака = стоят одинаковые объекты, то равенство верное. Если разные — ложное.",{"link":220,"schemaName":206,"title":221,"key":222,"seo":223,"description":225},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equation","Уравнение",{},{"title":224},"Что такое уравнение?","Равенство, в котором есть одна или несколько неизвестных или переменных.",{"link":227,"schemaName":206,"title":228,"key":229,"seo":230,"description":232},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equation-solution","Решение уравнения",{},{"title":231},"Что значит решить уравнение?","\"Решения\" или \"корни\" уравнения — числа, которые при подстановке вместо неизвестных превращают его в истинное равенство.\n          \"Решить уравнение\" — значит найти все его корни и доказать, что других корней нет.",{"link":234,"schemaName":235,"title":236,"key":237,"seo":238,"description":239},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=same-action-rule","accent_statement","Правило одинакового действия",{},{},"Если над обеими частями истинного равенства совершить одно и то же действие, то полученное равенство тоже будет истинным.",{"link":241,"schemaName":242,"title":243,"key":244,"seo":245,"description":247},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=common-mistakes","list","Ошибки при решении уравнений",{},{"title":246},"Типовые ошибки при решении уравнений","Список типовых ошибок, которые новички совершают при решении уравнений.",{"link":249,"schemaName":250,"title":251,"key":252,"seo":253,"description":254},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=zachem-reshat-uravneniya","heading","Зачем решать уравнения?",{},{},"Набор примеров, для работы с которыми требуется умение решать уравнения.",{"link":256,"schemaName":250,"title":257,"key":258,"seo":259,"description":261},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=treugolnik-idiota","Треугольник формул",{},{"title":260},"Магический треугольник формул","Мнемоническая техника для запоминания простых формул.",{"link":263,"schemaName":250,"title":264,"key":265,"seo":266,"description":268},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=uravneniya-v-zhizni","Уравнения в жизни",{},{"title":267},"Где используют уравнения в жизни?","Подборка проблем и ситуаций из реальной жизни, которые можно решить, если перевести их в уравнения.",{"link":270,"schemaName":271,"title":272,"key":273,"seo":274,"description":275},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=linear-root","problems","Формула линейных уравнений",{},{},"Формула, по которой можно очень быстро найти корень любого уравнения вида Ax + B = 0.",{"elements":277},{"accent_term":278,"accent_statement":279,"accent_important":280,"problem":281},3,1,4,35,{"type":8,"link":283,"title":284,"description":285,"keyLinks":286,"stats":300},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F","Нулевые множители","\n    Простой и крайне эффективный способ решать уравнения, состоящие из набора множителей (скобок), произведение которых равно нулю.\n    Этот метод надо знать, так как очень много разных типов уравнений сводится к этому виду.\n  ",[287,293],{"link":288,"schemaName":235,"title":289,"key":290,"seo":291,"description":292},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-method","Метод нулевых множителей",{},{},"Удобный способ быстро решать уравнения в виде набора множителей, произведение которых равно нулю.",{"link":294,"schemaName":271,"title":295,"key":296,"seo":298,"description":299},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-examples","Отработка метода нулевых множителей",{"title":297},"Отработка метода",{},"Задачи на отработку метода нулевых множителей с подробными решениями.",{"elements":301},{"accent_statement":279,"problem":279},{"type":196,"link