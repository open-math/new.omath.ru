,"Поиск",{"type":22,"value":44},"Материалы",{"type":22,"value":46},"Ключевые элементы",{"type":22,"value":48},"Статистика",{"type":22,"value":50},"Темная",{"type":22,"value":30},{"type":22,"value":53},"Языки",{"type":22,"value":55},"Системная",{"type":22,"value":57},"Статья",{"type":22,"value":59},"Настройки",{"type":22,"value":61},"Собрано",{"type":22,"value":63},"Конспект",{"type":22,"value":65},"Контент",{"type":22,"value":67},"Практика",{"type":22,"value":69},"Erudit",{"type":22,"value":71},"Вы собираетесь перейти на страницу контента:",{"type":22,"value":73},"Добавить перевод",{"type":22,"value":75},"Главная страница",{"type":22,"value":77},"Авторы",{"type":22,"value":79},"Спонсоры",{"type":22,"value":81},"Поиск по сайту...",{"type":22,"value":83},"Ищем еще...",{"type":22,"value":85},"Ничего не найдено",{"type":22,"value":87},"Больше результатов нет",{"type":22,"value":89},"Контента нет.",{"type":22,"value":91},"К оглавлению",{"type":22,"value":93},"Об учебнике",{"type":22,"value":95},"Разработка",{"type":22,"value":97},"Профиль",{"type":22,"value":99},"Дополнение",{"type":22,"value":101},"Список людей, которые внесли вклад в материалы проекта: предложили ценные идеи, вносили корректировки в существующий материал или же написали собственный!",{"type":22,"value":103},"Вы тоже можете помочь проекту, внести свой вклад и попасть на эту страницу!",{"type":22,"value":105},"Стать автором",{"type":22,"value":107},"Список людей и организаций, которые поддерживают проект финансово. Благодаря им проект может существовать и развиваться. Если вы хотите помочь проекту, то тоже можете стать спонсором и попасть на эту страницу!",{"type":22,"value":109},"Пока что авторов нет. Вы можете стать первым!",{"type":22,"value":111},"Стать спонсором",{"type":22,"value":113},"Вклад",{"type":22,"value":115},"Пока что спонсоров нет. Вы можете стать первым!",{"type":22,"value":117},"Редактор",{"type":27,"value":119},"(name) => `Персональная страница автора \"${name}\" с данными о вкладе в проект.`",{"type":22,"value":121},"Путь",{"type":22,"value":123},"Начать изучение!",{"type":22,"value":125},"Связи",{"type":22,"value":127},"Обновлено",{"type":22,"value":129},"Собственные",{"type":22,"value":131},"Из",{"type":22,"value":133},"Надо знать",{"type":22,"value":135},"Зависит от",{"type":22,"value":137},"Используется в",{"type":22,"value":139},"Внешние",{"m":141},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":143,"mainContent":144},"group\u002Ffoundations\u002Fequations\u002F",{"fullId":145,"shortId":145,"contentRelativePath":146,"title":147,"bookTitle":15,"breadcrumbs":148,"lastmod":151,"description":152,"stats":153,"connections":160,"contributions":184,"type":197,"children":198},"foundations\u002Fequations","01-foundations\u002F02-equations","Уравнения",[149],{"icon":150,"title":15,"link":17},"book-outline","2026-04-12T16:49:40+03:00","\n    Разбор самых популярных уравнений: элементарных, квадратных, систем и т.д.\n    Вы поймёте, зачем их вообще нужно решать и как с их помощью можно описывать процессы в реальной жизни.\n    Разберем и нюансы: преобразования, ОДЗ, \"потеря\" и появление \"лишних\" корней и многие другие.\n  ",{"materials":154,"elements":155},11,{"accent_term":156,"accent_statement":157,"accent_important":158,"problem":159},9,13,16,145,{"externals":161},[162,171],{"type":163,"items":164},"own",[165],{"type":166,"title":167,"info":168,"link":169,"reason":170},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https:\u002F\u002Fddpu.edu.ua\u002Ffmk\u002Fstudentam\u002F3em\u002F10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":172,"title":15,"items":173},"parent",[174,180],{"type":175,"title":176,"info":177,"link":178,"reason":179},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":166,"title":181,"info":182,"reason":183},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[185,189,193],{"contributorId":186,"name":187,"avatarUrl":188},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png",{"contributorId":190,"name":191,"avatarUrl":192},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg",{"contributorId":194,"name":195,"avatarUrl":196},"igor-radko","Игорь Радько","\u002Ffile\u002Fcontributors\u002Figor-radko\u002Favatar.jpg","group",[199,284,305],{"type":200,"link":201,"title":202,"description":203,"decoration":204,"keyLinks":205,"stats":278},"topic","\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F","Элементарные уравнения","\n    Научимся решать простейшие уравнения и преобразовывать равенства.\n    Просто, наглядно, с примерами и без заучивания наизусть кучи странных правил.\n    Это ключевой и необходимый навык в математике и всех остальных точных науках.\n  ","content\u002F01-foundations\u002F02-equations\u002F01-elementary\u002Fdecoration.svg",[206,214,221,228,235,242,250,257,264,271],{"link":207,"schemaName":208,"title":209,"key":210,"seo":211,"description":213},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equality","accent_term","Равенство",{},{"title":212},"Что такое равенство?","Два выражения, между которыми стоит знак равно \"=\". Равенство может быть истинным (2 = 2) или ложным (2 = 0).",{"link":215,"schemaName":216,"title":217,"key":218,"seo":219,"description":220},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equality-false-true","diagram","Верное и ложное равенство",{},{},"Если по бокам от знака = стоят одинаковые объекты, то равенство верное. Если разные — ложное.",{"link":222,"schemaName":208,"title":223,"key":224,"seo":225,"description":227},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equation","Уравнение",{},{"title":226},"Что такое уравнение?","Равенство, в котором есть одна или несколько неизвестных или переменных.",{"link":229,"schemaName":208,"title":230,"key":231,"seo":232,"description":234},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equation-solution","Решение уравнения",{},{"title":233},"Что значит решить уравнение?","\"Решения\" или \"корни\" уравнения — числа, которые при подстановке вместо неизвестных превращают его в истинное равенство.\n          \"Решить уравнение\" — значит найти все его корни и доказать, что других корней нет.",{"link":236,"schemaName":237,"title":238,"key":239,"seo":240,"description":241},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=same-action-rule","accent_statement","Правило одинакового действия",{},{},"Если над обеими частями истинного равенства совершить одно и то же действие, то полученное равенство тоже будет истинным.",{"link":243,"schemaName":244,"title":245,"key":246,"seo":247,"description":249},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=common-mistakes","list","Ошибки при решении уравнений",{},{"title":248},"Типовые ошибки при решении уравнений","Список типовых ошибок, которые новички совершают при решении уравнений.",{"link":251,"schemaName":252,"title":253,"key":254,"seo":255,"description":256},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=zachem-reshat-uravneniya","heading","Зачем решать уравнения?",{},{},"Набор примеров, для работы с которыми требуется умение решать уравнения.",{"link":258,"schemaName":252,"title":259,"key":260,"seo":261,"description":263},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=treugolnik-idiota","Треугольник формул",{},{"title":262},"Магический треугольник формул","Мнемоническая техника для запоминания простых формул.",{"link":265,"schemaName":252,"title":266,"key":267,"seo":268,"description":270},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=uravneniya-v-zhizni","Уравнения в жизни",{},{"title":269},"Где используют уравнения в жизни?","Подборка проблем и ситуаций из реальной жизни, которые можно решить, если перевести их в уравнения.",{"link":272,"schemaName":273,"title":274,"key":275,"seo":276,"description":277},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=linear-root","problems","Формула линейных уравнений",{},{},"Формула, по которой можно очень быстро найти корень любого уравнения вида Ax + B = 0.",{"elements":279},{"accent_term":280,"accent_statement":281,"accent_important":282,"problem":283},3,1,4,35,{"type":8,"link":285,"title":286,"description":287,"decoration":288,"keyLinks":289,"stats":303},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F","Нулевые множители","\n    Простой и крайне эффективный способ решать уравнения, состоящие из набора множителей (скобок), произведение которых равно нулю.\n    Этот метод надо знать, так как очень много разных типов уравнений сводится к этому виду.\n  ","content\u002F01-foundations\u002F02-equations\u002F02-zero-product-property\u002Fdecoration.svg",[290,296],{"link":291,"schemaName":237,"title":292,"key":293,"seo":294,"description":295},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-method","Метод нулевых множителей",{},{},"Удобный способ быстро решать уравнения в виде набора множителей, произведение которых равно нулю.",{"link":297,"schemaName":273,"title":298,"key":299,"seo":301,"description":302},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-example