22,"value":44},"Материалы",{"type":22,"value":46},"Ключевые элементы",{"type":22,"value":48},"Статистика",{"type":22,"value":50},"Темная",{"type":22,"value":30},{"type":22,"value":53},"Языки",{"type":22,"value":55},"Системная",{"type":22,"value":57},"Статья",{"type":22,"value":59},"Настройки",{"type":22,"value":61},"Собрано",{"type":22,"value":63},"Конспект",{"type":22,"value":65},"Контент",{"type":22,"value":67},"Практика",{"type":22,"value":69},"Erudit",{"type":22,"value":71},"Вы собираетесь перейти на страницу контента:",{"type":22,"value":73},"Добавить перевод",{"type":22,"value":75},"Главная страница",{"type":22,"value":77},"Авторы",{"type":22,"value":79},"Спонсоры",{"type":22,"value":81},"Поиск по сайту...",{"type":22,"value":83},"Ищем еще...",{"type":22,"value":85},"Ничего не найдено",{"type":22,"value":87},"Больше результатов нет",{"type":22,"value":89},"Контента нет.",{"type":22,"value":91},"К оглавлению",{"type":22,"value":93},"Об учебнике",{"type":22,"value":95},"Разработка",{"type":22,"value":97},"Профиль",{"type":22,"value":99},"Дополнение",{"type":22,"value":101},"Список людей, которые внесли вклад в материалы проекта: предложили ценные идеи, вносили корректировки в существующий материал или же написали собственный!",{"type":22,"value":103},"Вы тоже можете помочь проекту, внести свой вклад и попасть на эту страницу!",{"type":22,"value":105},"Стать автором",{"type":22,"value":107},"Список людей и организаций, которые поддерживают проект финансово. Благодаря им проект может существовать и развиваться. Если вы хотите помочь проекту, то тоже можете стать спонсором и попасть на эту страницу!",{"type":22,"value":109},"Пока что авторов нет. Вы можете стать первым!",{"type":22,"value":111},"Стать спонсором",{"type":22,"value":113},"Вклад",{"type":22,"value":115},"Пока что спонсоров нет. Вы можете стать первым!",{"type":22,"value":117},"Редактор",{"type":27,"value":119},"(name) => `Персональная страница автора \"${name}\" с данными о вкладе в проект.`",{"type":22,"value":121},"Начать изучение!",{"type":22,"value":123},"Связи",{"type":22,"value":125},"Обновлено",{"type":22,"value":127},"Собственные",{"type":22,"value":129},"Из",{"type":22,"value":131},"Надо знать",{"type":22,"value":133},"Зависит от",{"type":22,"value":135},"Используется в",{"type":22,"value":137},"Внешние",{"m":139},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":141,"mainContent":142},"group\u002Ffoundations\u002Fequations\u002F",{"fullId":143,"shortId":143,"contentRelativePath":144,"title":145,"bookTitle":15,"breadcrumbs":146,"lastmod":149,"description":150,"stats":151,"connections":157,"contributions":181,"type":194,"children":195},"foundations\u002Fequations","01-foundations\u002F02-equations","Уравнения",[147],{"icon":148,"title":15,"link":17},"book-outline","2026-03-23T16:31:52+03:00","\n    Разбор самых популярных уравнений: элементарных, квадратных, систем и т.д.\n    Вы поймёте, зачем их вообще нужно решать и как с их помощью можно описывать процессы в реальной жизни.\n    Разберем и нюансы: преобразования, ОДЗ, \"потеря\" и появление \"лишних\" корней и многие другие.\n  ",{"materials":152,"elements":153},8,{"accent_term":154,"accent_statement":152,"accent_important":155,"problem":156},9,14,101,{"externals":158},[159,168],{"type":160,"items":161},"own",[162],{"type":163,"title":164,"info":165,"link":166,"reason":167},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https:\u002F\u002Fddpu.edu.ua\u002Ffmk\u002Fstudentam\u002F3em\u002F10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":169,"title":15,"items":170},"parent",[171,177],{"type":172,"title":173,"info":174,"link":175,"reason":176},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":163,"title":178,"info":179,"reason":180},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[182,186,190],{"contributorId":183,"name":184,"avatarUrl":185},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png",{"contributorId":187,"name":188,"avatarUrl":189},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg",{"contributorId":191,"name":192,"avatarUrl":193},"igor-radko","Игорь Радько","\u002Ffile\u002Fcontributors\u002Figor-radko\u002Favatar.jpg","group",[196,280,300],{"type":197,"link":198,"title":199,"description":200,"keyLinks":201,"stats":274},"topic","\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F","Элементарные уравнения","\n    Научимся решать простейшие уравнения и преобразовывать равенства.\n    Просто, наглядно, с примерами и без заучивания наизусть кучи странных правил.\n    Это ключевой и необходимый навык в математике и всех остальных точных науках.\n  ",[202,210,217,224,231,238,246,253,260,267],{"link":203,"schemaName":204,"title":205,"key":206,"seo":207,"description":209},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equality","accent_term","Равенство",{},{"title":208},"Что такое равенство?","Два выражения, между которыми стоит знак равно \"=\". Равенство может быть истинным (2 = 2) или ложным (2 = 0).",{"link":211,"schemaName":212,"title":213,"key":214,"seo":215,"description":216},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equality-false-true","diagram","Верное и ложное равенство",{},{},"Если по бокам от знака = стоят одинаковые объекты, то равенство верное. Если разные — ложное.",{"link":218,"schemaName":204,"title":219,"key":220,"seo":221,"description":223},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equation","Уравнение",{},{"title":222},"Что такое уравнение?","Равенство, в котором есть одна или несколько неизвестных или переменных.",{"link":225,"schemaName":204,"title":226,"key":227,"seo":228,"description":230},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equation-solution","Решение уравнения",{},{"title":229},"Что значит решить уравнение?","\"Решения\" или \"корни\" уравнения — числа, которые при подстановке вместо неизвестных превращают его в истинное равенство.\n          \"Решить уравнение\" — значит найти все его корни и доказать, что других корней нет.",{"link":232,"schemaName":233,"title":234,"key":235,"seo":236,"description":237},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=same-action-rule","accent_statement","Правило одинакового действия",{},{},"Если над обеими частями истинного равенства совершить одно и то же действие, то полученное равенство тоже будет истинным.",{"link":239,"schemaName":240,"title":241,"key":242,"seo":243,"description":245},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=common-mistakes","list","Ошибки при решении уравнений",{},{"title":244},"Типовые ошибки при решении уравнений","Список типовых ошибок, которые новички совершают при решении уравнений.",{"link":247,"schemaName":248,"title":249,"key":250,"seo":251,"description":252},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=zachem-reshat-uravneniya","heading","Зачем решать уравнения?",{},{},"Набор примеров, для работы с которыми требуется умение решать уравнения.",{"link":254,"schemaName":248,"title":255,"key":256,"seo":257,"description":259},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=treugolnik-idiota","Треугольник формул",{},{"title":258},"Магический треугольник формул","Мнемоническая техника для запоминания простых формул.",{"link":261,"schemaName":248,"title":262,"key":263,"seo":264,"description":266},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=uravneniya-v-zhizni","Уравнения в жизни",{},{"title":265},"Где используют уравнения в жизни?","Подборка проблем и ситуаций из реальной жизни, которые можно решить, если перевести их в уравнения.",{"link":268,"schemaName":269,"title":270,"key":271,"seo":272,"description":273},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=linear-root","problems","Формула линейных уравнений",{},{},"Формула, по которой можно очень быстро найти корень любого уравнения вида Ax + B = 0.",{"elements":275},{"accent_term":276,"accent_statement":277,"accent_important":278,"problem":279},3,1,4,35,{"type":8,"link":281,"title":282,"description":283,"keyLinks":284,"stats":298},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F","Нулевые множители","\n    Простой и крайне эффективный способ решать уравнения, состоящие из набора множителей (скобок), произведение которых равно нулю.\n    Этот метод надо знать, так как очень много разных типов уравнений сводится к этому виду.\n  ",[285,291],{"link":286,"schemaName":233,"title":287,"key":288,"seo":289,"description":290},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-method","Метод нулевых множителей",{},{},"Удобный способ быстро решать уравнения в виде набора множителей, произведение которых равно нулю.",{"link":292,"schemaName":269,"title":293,"key":294,"seo":296,"description":297},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-examples","Отработка метода нулевых множителей",{"title":295},"Отработка метода",{},"Задачи на отработку метода нулевых множителей с подробными решениями.",{"elements":299},{"accent_statement":277,"problem":277},{"type":194,"link":301,"title":302,"description":303,"stats":304},