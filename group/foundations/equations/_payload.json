ект.`",{"type":22,"value":121},"Путь",{"type":22,"value":123},"Начать изучение!",{"type":22,"value":125},"Связи",{"type":22,"value":127},"Обновлено",{"type":22,"value":129},"Собственные",{"type":22,"value":131},"Из",{"type":22,"value":133},"Надо знать",{"type":22,"value":135},"Зависит от",{"type":22,"value":137},"Используется в",{"type":22,"value":139},"Внешние",{"m":141},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":143,"mainContent":144},"group\u002Ffoundations\u002Fequations\u002F",{"fullId":145,"shortId":145,"contentRelativePath":146,"title":147,"bookTitle":15,"breadcrumbs":148,"lastmod":151,"description":152,"stats":153,"connections":160,"contributions":201,"type":214,"children":215},"foundations\u002Fequations","01-foundations\u002F02-equations","Уравнения",[149],{"icon":150,"title":15,"link":17},"book-outline","2026-05-01T18:59:52+03:00","\n    Разбор самых популярных уравнений: элементарных, квадратных, систем и т.д.\n    Вы поймёте, зачем их вообще нужно решать и как с их помощью можно описывать процессы в реальной жизни.\n    Разберем и нюансы: преобразования, ОДЗ, \"потеря\" и появление \"лишних\" корней и многие другие.\n  ",{"materials":154,"elements":155},11,{"accent_term":156,"accent_statement":157,"accent_important":158,"problem":159},9,13,16,145,{"hardDependencies":161,"externals":178},[162],{"type":163,"reason":164,"contentType":165,"title":166,"link":167,"uniques":168},"hard","\n        Выделение полного квадрата заключается в \"запаковке\" квадратного трёхчлена либо в квадрат суммы, либо в квадрат разности.\n        Для понимания этого процесса нужно уметь пользоваться этими формулами!\n      ","topic","Формулы сокращенного умножения","\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F",[169,174],{"name":170,"title":171,"link":172,"schemaName":173},"squareSum","Формула квадрата суммы","\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F?element=square-sum","accent_statement",{"name":175,"title":176,"link":177,"schemaName":173},"squareDiff","Формула квадрата разности","\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F?element=square-diff",[179,188],{"type":180,"items":181},"own",[182],{"type":183,"title":184,"info":185,"link":186,"reason":187},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https:\u002F\u002Fddpu.edu.ua\u002Ffmk\u002Fstudentam\u002F3em\u002F10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":189,"title":15,"items":190},"parent",[191,197],{"type":192,"title":193,"info":194,"link":195,"reason":196},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":183,"title":198,"info":199,"reason":200},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[202,206,210],{"contributorId":203,"name":204,"avatarUrl":205},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png",{"contributorId":207,"name":208,"avatarUrl":209},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg",{"contributorId":211,"name":212,"avatarUrl":213},"igor-radko","Игорь Радько","\u002Ffile\u002Fcontributors\u002Figor-radko\u002Favatar.jpg","group",[216,299,320],{"type":165,"link":217,"title":218,"description":219,"decoration":220,"keyLinks":221,"stats":293},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F","Элементарные уравнения","\n    Научимся решать простейшие уравнения и преобразовывать равенства.\n    Просто, наглядно, с примерами и без заучивания наизусть кучи странных правил.\n    Это ключевой и необходимый навык в математике и всех остальных точных науках.\n  ","content\u002F01-foundations\u002F02-equations\u002F01-elementary\u002Fdecoration.svg",[222,230,237,244,251,257,265,272,279,286],{"link":223,"schemaName":224,"title":225,"key":226,"seo":227,"description":229},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equality","accent_term","Равенство",{},{"title":228},"Что такое равенство?","Два выражения, между которыми стоит знак равно \"=\". Равенство может быть истинным (2 = 2) или ложным (2 = 0).",{"link":231,"schemaName":232,"title":233,"key":234,"seo":235,"description":236},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equality-false-true","diagram","Верное и ложное равенство",{},{},"Если по бокам от знака = стоят одинаковые объекты, то равенство верное. Если разные -- ложное.",{"link":238,"schemaName":224,"title":239,"key":240,"seo":241,"description":243},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equation","Уравнение",{},{"title":242},"Что такое уравнение?","Равенство, в котором есть одна или несколько неизвестных или переменных.",{"link":245,"schemaName":224,"title":246,"key":247,"seo":248,"description":250},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equation-solution","Решение уравнения",{},{"title":249},"Что значит решить уравнение?","\"Решения\" или \"корни\" уравнения -- числа, которые при подстановке вместо неизвестных превращают его в истинное равенство.\n          \"Решить уравнение\" -- значит найти все его корни и доказать, что других корней нет.",{"link":252,"schemaName":173,"title":253,"key":254,"seo":255,"description":256},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=same-action-rule","Правило одинакового действия",{},{},"Если над обеими частями истинного равенства совершить одно и то же действие, то полученное равенство тоже будет истинным.",{"link":258,"schemaName":259,"title":260,"key":261,"seo":262,"description":264},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=common-mistakes","list","Ошибки при решении уравнений",{},{"title":263},"Типовые ошибки при решении уравнений","Список типовых ошибок, которые новички совершают при решении уравнений.",{"link":266,"schemaName":267,"title":268,"key":269,"seo":270,"description":271},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=zachem-reshat-uravneniya","heading","Зачем решать уравнения?",{},{},"Набор примеров, для работы с которыми требуется умение решать уравнения.",{"link":273,"schemaName":267,"title":274,"key":275,"seo":276,"description":278},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=treugolnik-idiota","Треугольник формул",{},{"title":277},"Магический треугольник формул","Мнемоническая техника для запоминания простых формул.",{"link":280,"schemaName":267,"title":281,"key":282,"seo":283,"description":285},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=uravneniya-v-zhizni","Уравнения в жизни",{},{"title":284},"Где используют уравнения в жизни?","Подборка проблем и ситуаций из реальной жизни, которые можно решить, если перевести их в уравнения.",{"link":287,"schemaName":288,"title":289,"key":290,"seo":291,"description":292},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=linear-root","problems","Формула линейных уравнений",{},{},"Формула, по которой можно очень быстро найти корень любого уравнения вида Ax + B = 0.",{"elements":294},{"accent_term":295,"accent_statement":296,"accent_important":297,"problem":298},3,1,4,35,{"type":8,"link":300,"title":301,"description":302,"decoration":303,"keyLinks":304,"stats":318},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F","Нулевые множители","\n    Простой и крайне эффективный способ решать уравнения, состоящие из набора множителей (скобок), произведение которых равно нулю.\n    Этот метод надо знать, так как очень много разных типов уравнений сводится к этому виду.\n  ","content\u002F01-foundations\u002F02-equations\u002F02-zero-product-property\u002Fdecoration.svg",[305,311],{"link":306,"schemaName":173,"title":307,"key":308,"seo":309,"description":310},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-method","Метод нулевых множителей",{},{},"Удобный способ быстро решать уравнения в виде набора множителей, произведение которых равно нулю.",{"link":312,"schemaName":288,"title":313,"key":314,"seo":316,"description":317},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-examples","Отработка метода нулевых множителей",{"title":315},"Отработка метода",{},"Задачи на отработку метода нулевых множителей с подробными решениями.",{"elements":319},{"accent_statement":296,"problem":296},{"type":214,"link":321,"title":322,"description":323,"decoration":324,"stats":325},"\u002Fgroup\u002Ffoundations\u002Fequations\u002Fquadratic\u002F","Квадратные уравнения","\n    Полный разбор квадратных уравнений: квадратные трехчлены, выделение полного квадрата, дискриминант, формулы Виета, разложение на множители, применения в реальной жизни и даже решение в уме!\n  ","content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002Fdecoration.svg",{"materials":156,"elements":326},{"accent_term":327,"accent_statement":154,"accent_important":328,"problem":329},6,12,109,{"contributorsCount":331,"sponsorsCount":332},7,5,{"shortBookId":5,"frontNav":334},{"type":14,"shortId":5,"title":15,"flags":335,"link":17,"children":336},{},[337,351],{"type":214,"separator":338,"shortId":339,"title":340,"flags":341,"link":342,"children":343},true,"foundations\u002Fpolynomials","Многочлены",{},"\u002Fgroup\u002Ffoundations\u002Fpolynomials\u002F",[34