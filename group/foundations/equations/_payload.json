роект.`",{"type":22,"value":121},"Путь",{"type":22,"value":123},"Начать изучение!",{"type":22,"value":125},"Связи",{"type":22,"value":127},"Обновлено",{"type":22,"value":129},"Собственные",{"type":22,"value":131},"Из",{"type":22,"value":133},"Надо знать",{"type":22,"value":135},"Зависит от",{"type":22,"value":137},"Используется в",{"type":22,"value":139},"Внешние",{"m":141},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":143,"mainContent":144},"group\u002Ffoundations\u002Fequations\u002F",{"fullId":145,"shortId":145,"contentRelativePath":146,"title":147,"bookTitle":15,"breadcrumbs":148,"lastmod":151,"description":152,"stats":153,"connections":160,"contributions":184,"type":197,"children":198},"foundations\u002Fequations","01-foundations\u002F02-equations","Уравнения",[149],{"icon":150,"title":15,"link":17},"book-outline","2026-04-04T10:42:24+03:00","\n    Разбор самых популярных уравнений: элементарных, квадратных, систем и т.д.\n    Вы поймёте, зачем их вообще нужно решать и как с их помощью можно описывать процессы в реальной жизни.\n    Разберем и нюансы: преобразования, ОДЗ, \"потеря\" и появление \"лишних\" корней и многие другие.\n  ",{"materials":154,"elements":155},10,{"accent_term":156,"accent_statement":157,"accent_important":158,"problem":159},9,12,16,119,{"externals":161},[162,171],{"type":163,"items":164},"own",[165],{"type":166,"title":167,"info":168,"link":169,"reason":170},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https:\u002F\u002Fddpu.edu.ua\u002Ffmk\u002Fstudentam\u002F3em\u002F10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":172,"title":15,"items":173},"parent",[174,180],{"type":175,"title":176,"info":177,"link":178,"reason":179},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":166,"title":181,"info":182,"reason":183},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[185,189,193],{"contributorId":186,"name":187,"avatarUrl":188},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png",{"contributorId":190,"name":191,"avatarUrl":192},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg",{"contributorId":194,"name":195,"avatarUrl":196},"igor-radko","Игорь Радько","\u002Ffile\u002Fcontributors\u002Figor-radko\u002Favatar.jpg","group",[199,283,303],{"type":200,"link":201,"title":202,"description":203,"keyLinks":204,"stats":277},"topic","\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F","Элементарные уравнения","\n    Научимся решать простейшие уравнения и преобразовывать равенства.\n    Просто, наглядно, с примерами и без заучивания наизусть кучи странных правил.\n    Это ключевой и необходимый навык в математике и всех остальных точных науках.\n  ",[205,213,220,227,234,241,249,256,263,270],{"link":206,"schemaName":207,"title":208,"key":209,"seo":210,"description":212},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equality","accent_term","Равенство",{},{"title":211},"Что такое равенство?","Два выражения, между которыми стоит знак равно \"=\". Равенство может быть истинным (2 = 2) или ложным (2 = 0).",{"link":214,"schemaName":215,"title":216,"key":217,"seo":218,"description":219},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equality-false-true","diagram","Верное и ложное равенство",{},{},"Если по бокам от знака = стоят одинаковые объекты, то равенство верное. Если разные — ложное.",{"link":221,"schemaName":207,"title":222,"key":223,"seo":224,"description":226},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equation","Уравнение",{},{"title":225},"Что такое уравнение?","Равенство, в котором есть одна или несколько неизвестных или переменных.",{"link":228,"schemaName":207,"title":229,"key":230,"seo":231,"description":233},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equation-solution","Решение уравнения",{},{"title":232},"Что значит решить уравнение?","\"Решения\" или \"корни\" уравнения — числа, которые при подстановке вместо неизвестных превращают его в истинное равенство.\n          \"Решить уравнение\" — значит найти все его корни и доказать, что других корней нет.",{"link":235,"schemaName":236,"title":237,"key":238,"seo":239,"description":240},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=same-action-rule","accent_statement","Правило одинакового действия",{},{},"Если над обеими частями истинного равенства совершить одно и то же действие, то полученное равенство тоже будет истинным.",{"link":242,"schemaName":243,"title":244,"key":245,"seo":246,"description":248},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=common-mistakes","list","Ошибки при решении уравнений",{},{"title":247},"Типовые ошибки при решении уравнений","Список типовых ошибок, которые новички совершают при решении уравнений.",{"link":250,"schemaName":251,"title":252,"key":253,"seo":254,"description":255},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=zachem-reshat-uravneniya","heading","Зачем решать уравнения?",{},{},"Набор примеров, для работы с которыми требуется умение решать уравнения.",{"link":257,"schemaName":251,"title":258,"key":259,"seo":260,"description":262},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=treugolnik-idiota","Треугольник формул",{},{"title":261},"Магический треугольник формул","Мнемоническая техника для запоминания простых формул.",{"link":264,"schemaName":251,"title":265,"key":266,"seo":267,"description":269},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=uravneniya-v-zhizni","Уравнения в жизни",{},{"title":268},"Где используют уравнения в жизни?","Подборка проблем и ситуаций из реальной жизни, которые можно решить, если перевести их в уравнения.",{"link":271,"schemaName":272,"title":273,"key":274,"seo":275,"description":276},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=linear-root","problems","Формула линейных уравнений",{},{},"Формула, по которой можно очень быстро найти корень любого уравнения вида Ax + B = 0.",{"elements":278},{"accent_term":279,"accent_statement":280,"accent_important":281,"problem":282},3,1,4,35,{"type":8,"link":284,"title":285,"description":286,"keyLinks":287,"stats":301},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F","Нулевые множители","\n    Простой и крайне эффективный способ решать уравнения, состоящие из набора множителей (скобок), произведение которых равно нулю.\n    Этот метод надо знать, так как очень много разных типов уравнений сводится к этому виду.\n  ",[288,294],{"link":289,"schemaName":236,"title":290,"key":291,"seo":292,"description":293},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-method","Метод нулевых множителей",{},{},"Удобный способ быстро решать уравнения в виде набора множителей, произведение которых равно нулю.",{"link":295,"schemaName":272,"title":296,"key":297,"seo":299,"description":300},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-examples","Отработка метода нулевых множителей",{"title":298},"Отработка метода",{},"Задачи на отработку метода нулевых множителей с подробными решениями.",{"elements":302},{"accent_statement":280,"problem":280},{"type":197,"l