,"Поиск",{"type":22,"value":44},"Материалы",{"type":22,"value":46},"Ключевые элементы",{"type":22,"value":48},"Статистика",{"type":22,"value":50},"Темная",{"type":22,"value":30},{"type":22,"value":53},"Языки",{"type":22,"value":55},"Системная",{"type":22,"value":57},"Статья",{"type":22,"value":59},"Настройки",{"type":22,"value":61},"Собрано",{"type":22,"value":63},"Конспект",{"type":22,"value":65},"Контент",{"type":22,"value":67},"Задачи",{"type":22,"value":69},"Erudit",{"type":22,"value":71},"Вы собираетесь перейти на страницу контента:",{"type":22,"value":73},"Добавить перевод",{"type":22,"value":75},"Главная страница",{"type":22,"value":77},"Авторы",{"type":22,"value":79},"Спонсоры",{"type":22,"value":81},"Поиск по сайту...",{"type":22,"value":83},"Ищем еще...",{"type":22,"value":85},"Ничего не найдено",{"type":22,"value":87},"Больше результатов нет",{"type":22,"value":89},"Контента нет.",{"type":22,"value":91},"К оглавлению",{"type":22,"value":93},"Об учебнике",{"type":22,"value":95},"Разработка",{"type":22,"value":97},"Профиль",{"type":22,"value":99},"Дополнение",{"type":22,"value":101},"Список людей, которые внесли вклад в материалы проекта: предложили ценные идеи, вносили корректировки в существующий материал или же написали собственный!",{"type":22,"value":103},"Вы тоже можете помочь проекту, внести свой вклад и попасть на эту страницу!",{"type":22,"value":105},"Стать автором",{"type":22,"value":107},"Список людей и организаций, которые поддерживают проект финансово. Благодаря им проект может существовать и развиваться. Если вы хотите помочь проекту, то тоже можете стать спонсором и попасть на эту страницу!",{"type":22,"value":109},"Пока что авторов нет. Вы можете стать первым!",{"type":22,"value":111},"Стать спонсором",{"type":22,"value":113},"Вклад",{"type":22,"value":115},"Пока что спонсоров нет. Вы можете стать первым!",{"type":22,"value":117},"Редактор",{"type":27,"value":119},"(name) => `Персональная страница автора \"${name}\" с данными о вкладе в проект.`",{"type":22,"value":121},"Путь",{"type":22,"value":123},"Начать изучение!",{"type":22,"value":125},"Связи",{"type":22,"value":127},"Обновлено",{"type":22,"value":129},"Собственные",{"type":22,"value":131},"Из",{"type":22,"value":133},"Надо знать",{"type":22,"value":135},"Зависит от",{"type":22,"value":137},"Используется в",{"type":22,"value":139},"Внешние",{"m":141},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":143,"mainContent":144},"group\u002Ffoundations\u002Fequations\u002Fquadratic\u002F",{"fullId":145,"shortId":145,"contentRelativePath":146,"title":147,"bookTitle":15,"breadcrumbs":148,"lastmod":155,"description":156,"decoration":157,"stats":158,"connections":165,"contributions":234,"type":243,"children":244},"foundations\u002Fequations\u002Fquadratic","01-foundations\u002F02-equations\u002F03-quadratic","Квадратные уравнения",[149,151],{"icon":150,"title":15,"link":17},"book-outline",{"icon":152,"title":153,"link":154},"folder-open","Уравнения","\u002Fgroup\u002Ffoundations\u002Fequations\u002F","2026-05-01T18:59:52+03:00","\n    Полный разбор квадратных уравнений: квадратные трехчлены, выделение полного квадрата, дискриминант, формулы Виета, разложение на множители, применения в реальной жизни и даже решение в уме!\n  ","content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002Fdecoration.svg",{"materials":159,"elements":160},9,{"accent_term":161,"accent_statement":162,"accent_important":163,"problem":164},6,11,12,109,{"hardDependencies":166,"autoDependencies":202,"externals":212},[167,183],{"type":168,"reason":169,"contentType":170,"title":171,"link":172,"uniques":173},"hard","\n        Выделение полного квадрата заключается в \"запаковке\" квадратного трёхчлена либо в квадрат суммы, либо в квадрат разности.\n        Для понимания этого процесса нужно уметь пользоваться этими формулами!\n      ","topic","Формулы сокращенного умножения","\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F",[174,179],{"name":175,"title":176,"link":177,"schemaName":178},"squareSum","Формула квадрата суммы","\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F?element=square-sum","accent_statement",{"name":180,"title":181,"link":182,"schemaName":178},"squareDiff","Формула квадрата разности","\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F?element=square-diff",{"type":168,"reason":184,"contentType":170,"title":185,"link":186,"uniques":187},"Перед решением квадратных уравнений вы должны уметь решать элементарные. Иначе никак. Даже не пытайтесь.","Элементарные уравнения","\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F",[188,192,197],{"name":189,"title":190,"link":191,"schemaName":178},"sameActionRule","Правило одинакового действия","\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=same-action-rule",{"name":193,"title":194,"link":195,"schemaName":196},"alwaysGlobal","Действие всегда \"глобально\"","\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=always-global","accent_important",{"name":198,"title":199,"link":200,"schemaName":201},"equationSolution","Решение уравнения","\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F?element=equation-solution","accent_term",[203],{"type":204,"contentType":8,"title":205,"link":206,"uniques":207},"auto","Нулевые множители","\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F",[208],{"name":209,"title":210,"link":211,"schemaName":178},"zeroProductPropertyMethod","Метод нулевых множителей","\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-method",[213,222],{"type":214,"title":153,"items":215},"parent",[216],{"type":217,"title":218,"info":219,"link":220,"reason":221},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https:\u002F\u002Fddpu.edu.ua\u002Ffmk\u002Fstudentam\u002F3em\u002F10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":214,"title":15,"items":223},[224,230],{"type":225,"title":226,"info":227,"link":228,"reason":229},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":217,"title":231,"info":232,"reason":233},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[235,239],{"contributorId":236,"name":237,"avatarUrl":238},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png",{"contributorId":240,"name":241,"avatarUrl":242},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg","group",[245,276,310,348,439,509,553,604,659],{"type":170,"link":246,"title":247,"description":248,"decoration":249,"keyLinks":250,"stats":271},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F","Что это такое?","\n    Разберемся, что вообще такое квадратное уравнение и квадратный трехчлен.\n    Как эти термины появились, чем они похожи, а чем отличаются.\n    Научимся определять, является ли уравнение квадратным.\n  ","content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F1-what-is-it\u002Fdecoration.svg",[251,258,265],{"link":252,"schemaName":253,"title":254,"key":255,"seo":256,"description":257},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=problematic-equations","problems","Квадратные уравнения в жизни",{},{},"Примеры разнообразных жизненных ситуаций, которые сводятся к квадратным уравнениям.\n          Так станет понятно, почему вообще нужно уметь их решать.",{"link":259,"schemaName":201,"title":260,"key":261,"seo":262,"description":264},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=quadratic-polynomial","Квадратный трёхчлен",{},{"title":263},"Что такое квадратный трёхчлен?","Многочлен с максимальной степенью неизвестной, равной двум.\n          Выступает \"шаблоном\" или \"общим видом\" для всех квадратных уравнений.",{"link":266,"schemaName":201,"title":267,"key":268,"seo":269,"description":270},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=quadratic-equation","Квадратное уравнение",{},{},"Любое уравнение, которое преобразованиями без потери корней можно привести к виду квадратного трёхчлена.",{"elements":272},{"accent_term":273,"accent_important":274,"problem":275},2,1,5,{"type":170,"link":277,"title":278,"description":279,"decoration":280,"keyLinks":281,"stats":306},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F","Неполная форма","\n    Неполные квадратные уравнения -- простейшие формы квадратных уравнений, в которых отсутствуют коэффициент B, C или оба сразу.\n    Разберемся, как их правильно решать в каждом отдельном случае.\n  ","content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F2-incomplete\u002Fdecoration.svg",[282,289,297],{"link":283,"schemaName":201,"title":284,"key":285,"seo":286,"description":288},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=quadratic-missing-terms","Неполное квадратное уравнение",{},{"title":287},"Что такое неполное квадратное уравнение?","Квадратное уравнение, у которого равен нулю коэффициент B или C или оба сразу.",{"link":290,"schemaName":291,"title":292,"key":293,"seo":294,"description":296},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=reshenie-nepolnykh-kvadratnykh-uravneniy","heading","Решение таких уравнений",{},{"title":295},"Как решать неполные квадратные уравнения?","Подробный разбор решения всех видов неполных квадратных уравнений с выводом общих формул.",{"link":298,"schemaName":299,"title":300,"key":301,"seo":303,"description":305},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=all-formulas","diagram","Общие формулы неполных квадратных уравнений",{"title":302},"Общие формулы",{"title":304},"Общие формулы для решения неполных квадратных уравнений","Формулы для всех трёх типов неполных квадратных уравнений:\n          когда \"B\" и \"C\" равны нулю, когда \"C\" равен нулю и когда \"B\" равен нулю.",{"elements":307},{"accent_term":274,"accent_statement":308,"accent_important":274,"problem":309},3,7,{"type":170,"link":311,"title":312,"description":313,"decoration":314,"keyLinks":315,"stats":346},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F","Полный квадрат","\n    Процесс \"запаковки\" развёрнутого выражения в короткую скобку в квадрате.\n    С его помощью можно решить любое квадратное уравнение!\n    Разберёмся, как его проводить на подробных и наглядных примерах с визуализацией.\n  ","content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F3-completing-the-square\u002Fdecoration.svg",[316,323,330,338],{"link":317,"schemaName":201,"title":318,"key":319,"seo":320,"description":322},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=what-is-it","Выделение полного квадрата",{"title":247},{"title":321},"Что такое выделение полного квадрата?","\"Запаковка\" развёрнутого выражения в скобку в квадрате.",{"link":324,"schemaName":291,"title":325,"key":326,"seo":327,"description":329},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=zachem-etim-zanimatsya","Зачем это делать?",{},{"title":328},"Зачем выделять полный квадрат?","Выделение полного квадрата -- мощный инструмент для преобразования выражения и решения квадратных уравнений.",{"link":331,"schemaName":291,"title":332,"key":333,"seo":335,"description":337},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=reshenie-kvadratnykh-uravneniy","Решение квадратных уравнений",{"title":334},"Решение уравнений",{"title":336},"Решение квадратных уравнений через выделение полного квадрата","Выделение полного квадрата -- ключ к решению абсолютно любых квадратных уравнений.",{"link":339,"schemaName":340,"title":341,"key":342,"seo":343,"description":345},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=vizualizatsiya-protsessa","image","Визуализация процесса",{},{"title":344},"Визуализация выделения полного квадрата","Как в прямом смысле из фигур поменьше собирают или \"выделяют\" большой квадрат.",{"elements":347},{"accent_term":274,"accent_important":274,"problem":162},{"type":170,"link":349,"title":350,"description":351,"decoration":352,"keyLinks":353,"stats":436},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F","Формула корней","\n    Понятный вывод общей формулы корней квадратного уравнения с подробными объяснениями каждого шага.\n    Пояснение, что такое дискриминант, откуда он взялся и почему по нему можно узнать количество корней.\n  ","content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F4-quadratic-formula\u002Fdecoration.svg",[354,361,368,375,382,389,397,405,412,420,428],{"link":355,"schemaName":196,"title":356,"key":357,"seo":358,"description":360},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=general-formulas","Общие формулы корней",{},{"title":359},"Общие формулы корней уравнений","Общие формулы корней позволяют очень быстро решать сложные виды уравнений.",{"link":362,"schemaName":201,"title":363,"key":364,"seo":365,"description":367},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=discriminant","Дискриминант",{},{"title":366},"Дискриминант квадратного уравнения","Особое число, высчитываемое через коэффициенты квадратного уравнения, которое позволяет понять, сколько корней имеет это уравнение.",{"link":369,"schemaName":178,"title":370,"key":371,"seo":373,"description":374},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=formula","Формула корней квадратного уравнения",{"title":372},"Корни квадратного уравнения",{},"Общая формула, которая позволяет найти корни любого квадратного уравнения, если подставить в неё конкретные числа вместо буквенных коэффициентов.",{"link":376,"schemaName":201,"title":377,"key":378,"seo":379,"description":381},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=biquadratic","Биквадратное уравнение",{},{"title":380},"Что такое биквадратное уравнение?","Особый вид уравнений четвёртой степени, которые можно решить сведением к квадратному уравнению.",{"link":383,"schemaName":196,"title":384,"key":385,"seo":387,"description":388},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=nerazreshimost-uravneniy-vysshikh-stepeney","Пределы общих формул корней",{"title":386},"Пределы общих формул",{},"Для уравнений выше четвёртой степени не существует общих формул корней.",{"link":390,"schemaName":299,"title":391,"key":392,"seo":394,"description":396},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=algorithm","Алгоритм решения квадратного уравнения",{"title":393},"Алгоритм решения",{"title":395},"Алгоритм решения квадратных уравнений","Диаграмма, которая показывает, как решить абсолютно любое квадратное уравнение.",{"link":398,"schemaName":399,"title":400,"key":401,"seo":402,"description":404},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=vyvod-formuly-korney","table","Вывод формулы корней",{},{"title":403},"Вывод формулы корней квадратного уравнения","Пошаговый вывод формулы корней квадратного уравнения с пояснениями.",{"link":406,"schemaName":253,"title":407,"key":408,"seo":409,"description":411},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=even-b","Чётный коэффициент",{},{"title":410},"Квадратное уравнение с чётным коэффициентом","Общая и более простая формула корней квадратного уравнения с чётным коэффициентом B.",{"link":413,"schemaName":414,"title":415,"key":416,"seo":417,"description":419},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=sridharas-method","problem","Метод Сридхары",{},{"title":418},"Формула корней квадратного уравнения по методу Сридхары","Более простой способ вывести формулу корней квадратного уравнения, но с небольшим трюком.",{"link":421,"schemaName":253,"title":422,"key":423,"seo":424,"description":427},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=quadratic-in-f","Трёхчленное уравнение",{},{"title":425,"description":426},"Что такое трёхчленное уравнение?","Определение трёхчленных уравнений и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений из трёх членов с одинаковой \"неизвестной функцией\" в разных степенях, которые могут быть сведены к квадратному уравнению.",{"link":429,"schemaName":253,"title":430,"key":431,"seo":432,"description":435},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=palindromials","Возвратное уравнение",{},{"title":433,"description":434},"Что такое возвратное уравнение?","Определение возвратных уравнений (уравнений палиндромов) и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений, в которых коэффициенты повторяются зеркально относительно \"центра\" уравнения.",{"elements":437},{"accent_term":273,"accent_statement":274,"accent_important":273,"problem":438},14,{"type":170,"link":440,"title":441,"description":442,"decoration":443,"keyLinks":444,"stats":507},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F","Разложение на множители","\n    Запись квадратных трехчленов и квадратных уравнений в виде произведения множителей, а не суммы слагаемых.\n    Помогает быстро решать уравнения, упрощать сложные выражения и сразу видеть корни.\n  ","content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F5-factoring\u002Fdecoration.svg",[445,451,459,465,472,479,486,492,499],{"link":446,"schemaName":196,"title":447,"key":448,"seo":449,"description":450},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=i-plyus-i-umnozhenie-vazhny","И плюс, и умножение важны!",{},{},"В разных ситуациях надо уметь записывать выражения и через сумму, и через произведение множителей.",{"link":452,"schemaName":453,"title":454,"key":455,"seo":456,"description":458},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=why-factoring","list","Зачем это нужно?",{},{"title":457},"Чем полезно разложение квадратного трёхчлена на множители?","Разложение квадратных трёхчленов на множители позволяет упрощать выражения, сразу видеть их корни и даёт альтернативный способ решать квадратные уравнения.",{"link":460,"schemaName":291,"title":461,"key":462,"seo":463,"description":464},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=manual-factoring","Разложение \"вручную\"",{},{},"Методика разложения \"простых\" квадратных трёхчленов на множители вручную.",{"link":466,"schemaName":178,"title":467,"key":468,"seo":469,"description":471},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=general-factoring","Разложение в общем виде",{},{"title":470},"Формула разложения квадратного трёхчлена на множители","Если у квадратного трёхчлена есть корни, то его всегда можно разложить на множители с участием этих корней.",{"link":473,"schemaName":196,"title":474,"key":475,"seo":476,"description":478},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=quadratic-from-any","Любые числа это корни!",{},{"title":477},"Любая пара чисел является корнями квадратного трёхчлена","Из общей формулы разложения на множители следует, что любые два числа являются корнями какого-то квадратного трёхчлена.",{"link":480,"schemaName":291,"title":481,"key":482,"seo":483,"description":485},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=roots-plane","Плоскость корней",{},{"title":484},"Координатная плоскость корней квадратных уравнений","Геометрическая визуализация того факта, что абсолютно любые два числа являются корнями какого-то квадратного трёхчлена.",{"link":487,"schemaName":299,"title":488,"key":489,"seo":490,"description":491},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=varianty-razlozheniya","Варианты разложения",{},{},"Все возможные варианты разложения квадратного трёхчлена на множители.",{"link":493,"schemaName":399,"title":494,"key":495,"seo":496,"description":498},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=vyvod-formuly-razlozheniya","Вывод формулы разложения",{},{"title":497},"Вывод формулы разложения квадратного трёхчлена","Пошаговый вывод формулы разложения квадратного трёхчлена на множители с пояснениями.",{"link":500,"schemaName":253,"title":501,"key":502,"seo":504,"description":506},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=razlozhenie-bikvadratnykh-trekhchlenov","Разложение биквадратных трёхчленов",{"title":503},"Разложение биквадратных",{"title":505},"Разложение биквадратного трёхчлена на множители","Задачи на отработку разложения биквадратных трёхчленов на множители через промежуточную подстановку.",{"elements":508},{"accent_statement":274,"accent_important":273,"problem":163},{"type":8,"link":510,"title":511,"description":512,"decoration":513,"keyLinks":514,"stats":550},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fquadratic\u002Freal-world\u002F","В реальной жизни","\n    Примеры использования квадратных уравнений в самых разных областях:\n    в быту, в физике, в задачах на работу и на растворы, смеси и сплавы и, естественно, в самой математике.\n    Все задачи с подробными решениями и ответами.\n  ","content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F6-real-world\u002Fdecoration.svg",[515,522,529,536,543],{"link":516,"schemaName":291,"title":517,"key":518,"seo":519,"description":521},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fquadratic\u002Freal-world\u002F?element=bytovye-zadachi","Бытовые задачи",{},{"title":520},"Бытовые задачи на квадратные уравнения","Примеры жизненных бытовых задач, которые приводят к квадратным уравнениям с подробными решениями и ответами.",{"link":523,"schemaName":291,"title":524,"key":525,"seo":526,"description":528},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fquadratic\u002Freal-world\u002F?element=fizika","Физика",{},{"title":527},"Где используются квадратные уравнения в физике?","Примеры физических задач, которые сводятся к квадратным уравнениям, с подробными решениями и ответами.",{"link":530,"schemaName":291,"title":531,"key":532,"seo":533,"description":535},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fquadratic\u002Freal-world\u002F?element=rabota","Работа",{},{"title":534},"Квадратные уравнения в задачах про работу","Примеры задач про работу, которые решаются с помощью квадратных уравнений:\n          вспахивание поля, покраска забора, заполнение бака и так далее.",{"link":537,"schemaName":291,"title":538,"key":539,"seo":540,"description":542},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fquadratic\u002Freal-world\u002F?element=rastvory-smesi-splavy","Растворы, смеси, сплавы",{},{"title":541},"Квадратные уравнения в задачах про растворы, смеси и сплавы","Примеры задач про растворы, смеси и сплавы, которые решаются с помощью квадратных уравнений с подробными решениями и ответами.",{"link":544,"schemaName":291,"title":545,"key":546,"seo":547,"description":549},"\u002Fpage\u002Ffoundations\u002Fequations\u002Fquadratic\u002Freal-world\u002F?element=matematika","Математика",{},{"title":548},"Где используются квадратные уравнения в математике?","Примеры задач из алгебры и геометрии, которые сводятся к квадратным уравнениям, с подробными решениями и ответами.",{"elements":551},{"problem":552},25,{"type":170,"link":554,"title":555,"description":556,"decoration":557,"keyLinks":558,"stats":601},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F","Теорема Виета","\n    Две простые и очень полезные формулы, которые связывают корни и коэффициенты квадратного трёхчлена.\n    Они позволяют быстро проверять корни, составлять уравнения и изучать особые виды квадратных уравнений.\n  ","content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F7-vietas-formulas\u002Fdecoration.svg",[559,565,573,580,587,594],{"link":560,"schemaName":178,"title":555,"key":561,"seo":562,"description":564},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=vietas-formulas",{},{"title":563},"Как звучит теорема Виета?","Сумма корней квадратного трёхчлена равна -B\u002FA, а произведение корней равно C\u002FA.\n          Не существует других чисел, кроме корней, которые удовлетворяли бы этим формулам.",{"link":566,"schemaName":567,"title":568,"key":569,"seo":570,"description":572},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=eto-formuly-ili-teorema","paragraph","Это формулы или теорема?",{},{"title":571},"Как правильно \"формулы Виета\" или \"теорема Виета\"?","Можно и так, и так. Вас поймут в любом случае.\n              Но вообще \"формулы Виета\" это про сами равенства, а \"теорема Виета\" это вместе с утверждениями.",{"link":574,"schemaName":567,"title":575,"key":576,"seo":577,"description":579},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=pryamaya-i-obratnaya-teoremy","Прямая и обратная теоремы",{},{"title":578},"Обратная теорема Виета","Прямая это про само наличие формул, а обратная про то, что работают формулы только для корней.\n              Можно не париться.",{"link":581,"schemaName":567,"title":582,"key":583,"seo":584,"description":586},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=kak-zapomnit-naizust","Как запомнить наизусть?",{},{"title":585},"Как запомнить формулы Виета?","Запоминать не обязательно, они моментально выводятся раскрытием скобок в разложении на множители.",{"link":588,"schemaName":291,"title":589,"key":590,"seo":591,"description":593},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=primenenie-formul-vieta","Зачем нужна?",{},{"title":592},"Зачем нужны формулы Виета?","Формулы применяются для быстрой проверки корней, составления уравнений по корням и установления связи между коэффициентами.",{"link":595,"schemaName":299,"title":596,"key":597,"seo":598,"description":600},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=algoritm-vyvoda","Алгоритм вывода",{},{"title":599},"Быстрый алгоритм вывода формул Виета","Достаточно записать равенство стандартного вида квадратного трёхчлена и его разложения на множители.\n          Потом просто раскрыть скобки.",{"elements":602},{"accent_statement":274,"accent_important":308,"problem":603},17,{"type":170,"link":605,"title":606,"description":607,"decoration":608,"keyLinks":609,"stats":657},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F","Решение в уме","\n    Подробный разбор всех способов решения квадратных уравнений в уме.\n    Бесконечно генерируемые задачи на отработку как каждого способа по отдельности, так и всех способов сразу.\n  ","content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F8-mental-solving\u002Fdecoration.svg",[610,617,624,630,636,643,650],{"link":611,"schemaName":299,"title":612,"key":613,"seo":614,"description":616},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-incomplete","Решение неполных",{},{"title":615},"Решение неполных квадратных уравнений в уме","Все неполные квадратные уравнения решаются в уме при помощи одной из трех формул.\n          Не нужно ничего угадывать.\n          Находится решение элементарно.",{"link":618,"schemaName":178,"title":619,"key":620,"seo":621,"description":623},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-zero-sum","Нулевая сумма",{},{"title":622},"Решение квадратных уравнений в уме по сумме коэффициентов","Нулевая сумма коэффициентов позволяет моментально получить корни.\n          Это самый простой и полезный способ решать квадратные уравнения в уме.",{"link":625,"schemaName":178,"title":312,"key":626,"seo":627,"description":629},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-square",{},{"title":628},"Решение квадратных уравнений в уме через полный квадрат","Иногда квадратное уравнение можно целиком запаковать в квадрат суммы или разности.\n          В таком случае у него будет один корень, который находится элементарно.",{"link":631,"schemaName":178,"title":441,"key":632,"seo":633,"description":635},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-factoring",{},{"title":634},"Решение квадратных уравнений в уме через разложение на множители","Если квадратное уравнение приведённое (A = 1), то его можно попытаться разложить на множители в уме.\n          Для этого надо найти такие t и k, чтобы t + k = B и tk = C. Корнями тогда будут числа -t и -k.",{"link":637,"schemaName":178,"title":638,"key":639,"seo":640,"description":642},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-ato-c","Перенос A к C",{},{"title":641},"Как получить приведённое квадратное уравнение?","Простой метод получения приведённого квадратного уравнения в форме, позволяющей решить его в уме.\n          Для этого надо \"перенести\" коэффициент A к C.",{"link":644,"schemaName":299,"title":645,"key":646,"seo":647,"description":649},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all","Схема способов",{},{"title":648},"Способы решения квадратных уравнений в уме","Удобная схема с перечислением всех способов быстрого решения квадратных уравнений в уме.\n          Также даны подсказки по корням.",{"link":651,"schemaName":414,"title":652,"key":653,"seo":654,"description":656},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all-practice","Задачи на все способы",{},{"title":655},"Задачи на решение квадратных уравнений в уме","Бесконечно генерируемые задачи на отработку всех способов решения квадратных уравнений в уме:\n          нулевой суммы, полного квадрата, разложения на множители и переноса A к C.",{"elements":658},{"accent_statement":275,"accent_important":274,"problem":275},{"type":170,"link":660,"title":302,"description":661,"decoration":662,"keyLinks":663,"stats":685},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fformulas\u002F","\n    Наглядные схемы всех формул, понятий и методов решения квадратных уравнений, с учётом логики их вывода.\n    Набор смешанных задач, которые сводятся к квадратным трёхчленам и квадратным уравнениям.\n  ","content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F9-formulas\u002Fdecoration.svg",[664,671,678],{"link":665,"schemaName":299,"title":666,"key":667,"seo":668,"description":670},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fformulas\u002F?element=formulas","Схема формул",{},{"title":669},"Схема формул по квадратным уравнениям","Наглядная схема всех формул и понятий, связанных с квадратными уравнениями, с учётом логики их вывода.",{"link":672,"schemaName":299,"title":673,"key":674,"seo":675,"description":677},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fformulas\u002F?element=methods","Схема решений",{},{"title":676},"Схема способов решения квадратных уравнений","Наглядная схема всех способов решения квадратных уравнений: универсальный способ, неполные квадратные уравнения и способы решения в уме.",{"link":679,"schemaName":567,"title":680,"key":681,"seo":682,"description":684},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fformulas\u002F?element=mixed-problems","Смешанные задачи",{},{"title":683},"Смешанные задачи на квадратные уравнения","Смешанные задачи, которые так или иначе сводятся к квадратным трёхчленам или квадратным уравнениям.",{"elements":686},{"accent_important":274,"problem":687},13,{"contributorsCount":309,"sponsorsCount":275},{"shortBookId":5,"frontNav":690},{"type":14,"shortId":5,"title":15,"flags":691,"link":17,"children":692},{},[693,707],{"type":243,"separator":694,"shortId":695,"title":696,"flags":697,"link":698,"children":699},true,"foundations\u002Fpolynomials","Многочлены",{},"\u002Fgroup\u002Ffoundations\u002Fpolynomials\u002F",[700],{"type":170,"shortId":701,"title":171,"flags":702,"link":172,"parts":703},"foundations\u002Fpolynomials\u002Fspecial-products",{},[704,705,706],"article","summary","practice",{"type":243,"separator":694,"shortId":708,"title":153,"flags":709,"link":154,"children":710},"foundations\u002Fequations",{},[711,715,718],{"type":17