Fequations\u002Felementary\u002F",[174],{"type":175,"contentType":8,"title":176,"link":177,"uniques":178},"auto","Нулевые множители","\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F",[179],{"name":180,"title":181,"link":182,"schemaName":183},"zeroProductPropertyMethod","Метод нулевых множителей","\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-method","accent_statement",[185,194],{"type":186,"title":153,"items":187},"parent",[188],{"type":189,"title":190,"info":191,"link":192,"reason":193},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https:\u002F\u002Fddpu.edu.ua\u002Ffmk\u002Fstudentam\u002F3em\u002F10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":186,"title":15,"items":195},[196,202],{"type":197,"title":198,"info":199,"link":200,"reason":201},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":189,"title":203,"info":204,"reason":205},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[207,211],{"contributorId":208,"name":209,"avatarUrl":210},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png",{"contributorId":212,"name":213,"avatarUrl":214},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg","group",[217,248,281,319,410,479,529,584],{"type":170,"link":218,"title":219,"description":220,"keyLinks":221,"stats":243},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F","Что это такое?","\n    Разберемся, что вообще такое квадратное уравнение и квадратный трехчлен.\n    Как эти термины появились, чем они похожи, а чем отличаются.\n    Научимся определять, является ли уравнение квадратным.\n  ",[222,229,237],{"link":223,"schemaName":224,"title":225,"key":226,"seo":227,"description":228},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=problematic-equations","problems","Квадратные уравнения в жизни",{},{},"Примеры разнообразных жизненных ситуаций, которые сводятся к квадратным уравнениям.\n          Так станет понятно, почему вообще нужно уметь их решать.",{"link":230,"schemaName":231,"title":232,"key":233,"seo":234,"description":236},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=quadratic-polynomial","accent_term","Квадратный трёхчлен",{},{"title":235},"Что такое квадратный трёхчлен?","Многочлен с максимальной степенью неизвестной, равной двум.\n          Выступает \"шаблоном\" или \"общим видом\" для всех квадратных уравнений.",{"link":238,"schemaName":231,"title":239,"key":240,"seo":241,"description":242},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=quadratic-equation","Квадратное уравнение",{},{},"Любое уравнение, которое преобразованиями без потери корней можно привести к виду квадратного трёхчлена.",{"elements":244},{"accent_term":245,"accent_important":246,"problem":247},2,1,5,{"type":170,"link":249,"title":250,"description":251,"keyLinks":252,"stats":277},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F","Неполная форма","\n    Неполные квадратные уравнения — простейшие формы квадратных уравнений, в которых отсутствуют коэффициент B, C или оба сразу.\n    Разберемся, как их правильно решать в каждом отдельном случае.\n  ",[253,260,268],{"link":254,"schemaName":231,"title":255,"key":256,"seo":257,"description":259},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=quadratic-missing-terms","Неполное квадратное уравнение",{},{"title":258},"Что такое неполное квадратное уравнение?","Квадратное уравнение, у которого равен нулю коэффициент B или C или оба сразу.",{"link":261,"schemaName":262,"title":263,"key":264,"seo":265,"description":267},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=reshenie-nepolnykh-kvadratnykh-uravneniy","heading","Решение таких уравнений",{},{"title":266},"Как решать неполные квадратные уравнения?","Подробный разбор решения всех видов неполных квадратных уравнений с выводом общих формул.",{"link":269,"schemaName":270,"title":271,"key":272,"seo":274,"description":276},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=all-formulas","diagram","Общие формулы неполных квадратных уравнений",{"title":273},"Общие формулы",{"title":275},"Общие формулы для решения неполных квадратных уравнений","Формулы для всех трёх типов неполных квадратных уравнений:\n          когда \"B\" и \"C\" равны нулю, когда \"C\" равен нулю и когда \"B\" равен нулю.",{"elements":278},{"accent_term":246,"accent_statement":279,"accent_important":246,"problem":280},3,7,{"type":170,"link":282,"title":283,"description":284,"keyLinks":285,"stats":316},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F","Полный квадрат","\n    Процесс \"запаковки\" развёрнутого выражения в короткую скобку в квадрате.\n    С его помощью можно решить любое квадратное уравнение!\n    Разберёмся, как его проводить на подробных и наглядных примерах с визуализацией.\n  ",[286,293,300,308],{"link":287,"schemaName":231,"title":288,"key":289,"seo":290,"description":292},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=what-is-it","Выделение полного квадрата",{"title":219},{"title":291},"Что такое выделение полного квадрата?","\"Запаковка\" развёрнутого выражения в скобку в квадрате.",{"link":294,"schemaName":262,"title":295,"key":296,"seo":297,"description":299},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=zachem-etim-zanimatsya","Зачем это делать?",{},{"title":298},"Зачем выделять полный квадрат?","Выделение полного квадрата -- мощный инструмент для преобразования выражения и решения квадратных уравнений.",{"link":301,"schemaName":262,"title":302,"key":303,"seo":305,"description":307},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=reshenie-kvadratnykh-uravneniy","Решение квадратных уравнений",{"title":304},"Решение уравнений",{"title":306},"Решение квадратных уравнений через выделение полного квадрата","Выделение полного квадрата -- ключ к решению абсолютно любых квадратных уравнений.",{"link":309,"schemaName":310,"title":311,"key":312,"seo":313,"description":315},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=vizualizatsiya-protsessa","image","Визуализация процесса",{},{"title":314},"Визуализация выделения полного квадрата","Как в прямом смысле из фигур поменьше собирают или \"выделяют\" большой квадрат.",{"elements":317},{"accent_term":246,"accent_important":246,"problem":318},11,{"type":170,"link":320,"title":321,"description":322,"keyLinks":323,"stats":407},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F","Формула корней","\n    Понятный вывод общей формулы корней квадратного уравнения с подробными объяснениями каждого шага.\n    Пояснение, что такое дискриминант, откуда он взялся и почему по нему можно узнать количество корней.\n  ",[324,332,339,346,353,360,368,376,383,391,399],{"link":325,"schemaName":326,"title":327,"key":328,"seo":329,"description":331},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=general-formulas","accent_important","Общие формулы корней",{},{"title":330},"Общие формулы корней уравнений","Общие формулы корней позволяют очень быстро решать сложные виды уравнений.",{"link":333,"schemaName":231,"title":334,"key":335,"seo":336,"description":338},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=discriminant","Дискриминант",{},{"title":337},"Дискриминант квадратного уравнения","Особое число, высчитываемое через коэффициенты квадратного уравнения, которое позволяет понять, сколько корней имеет это уравнение.",{"link":340,"schemaName":183,"title":341,"key":342,"seo":344,"description":345},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=formula","Формула корней квадратного уравнения",{"title":343},"Корни квадратного уравнения",{},"Общая формула, которая позволяет найти корни любого квадратного уравнения, если подставить в неё конкретные числа вместо буквенных коэффициентов.",{"link":347,"schemaName":231,"title":348,"key":349,"seo":350,"description":352},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=biquadratic","Биквадратное уравнение",{},{"title":351},"Что такое биквадратное уравнение?","Особый вид уравнений четвёртой степени, которые можно решить сведением к квадратному уравнению.",{"link":354,"schemaName":326,"title":355,"key":356,"seo":358,"description":359},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=nerazreshimost-uravneniy-vysshikh-stepeney","Пределы общих формул корней",{"title":357},"Пределы общих формул",{},"Для уравнений выше четвёртой степени не существует общих формул корней.",{"link":361,"schemaName":270,"title":362,"key":363,"seo":365,"description":367},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=algorithm","Алгоритм решения квадратного уравнения",{"title":364},"Алгоритм решения",{"title":366},"Алгоритм решения квадратных уравнений","Диаграмма, которая показывает, как решить абсолютно любое квадратное уравнение.",{"link":369,"schemaName":370,"title":371,"key":372,"seo":373,"description":375},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=vyvod-formuly-korney","table","Вывод формулы корней",{},{"title":374},"Вывод формулы корней квадратного уравнения","Пошаговый вывод формулы корней квадратного уравнения с пояснениями.",{"link":377,"schemaName":224,"title":378,"key":379,"seo":380,"description":382},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=chetnyy-koeffitsient","Чётный коэффициент",{},{"title":381},"Квадратное уравнение с чётным коэффициентом","Общая и более простая формула корней квадратного уравнения с чётным коэффициентом B.",{"link":384,"schemaName":385,"title":386,"key":387,"seo":388,"description":390},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=sridharas-method","problem","Метод Сридхары",{},{"title":389},"Формула корней квадратного уравнения по методу Сридхары","Более простой способ вывести формулу корней квадратного уравнения, но с небольшим трюком.",{"link":392,"schemaName":224,"title":393,"key":394,"seo":395,"description":398},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=quadratic-in-f","Трёхчленное уравнение",{},{"title":396,"description":397},"Что такое трёхчленное уравнение?","Определение трёхчленных уравнений и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений из трёх членов с одинаковой \"неизвестной функцией\" в разных степенях, которые могут быть сведены к квадратному уравнению.",{"link":400,"schemaName":224,"title":401,"key":402,"seo":403,"description":406},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=palindromials","Возвратное уравнение",{},{"title":404,"description":405},"Что такое возвратное уравнение?","Определение возвратных уравнений (уравнений палиндромов) и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений, в которых коэффициенты повторяются зеркально относительно \"центра\" уравнения.",{"elements":408},{"accent_term":245,"accent_statement":246,"accent_important":245,"problem":409},14,{"type":170,"link":411,"title":412,"description":413,"keyLinks":414,"stats":477},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F","Разложение на множители","\n    Запись квадратных трехчленов и квадратных уравнений в виде произведения множителей, а не суммы слагаемых.\n    Помогает быстро решать уравнения, упрощать сложные выражения и сразу видеть корни.\n  ",[415,421,429,435,442,449,456,462,469],{"link":416,"schemaName":326,"title":417,"key":418,"seo":419,"description":420},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=i-plyus-i-umnozhenie-vazhny","И плюс, и умножение важны!",{},{},"В разных ситуациях надо уметь записывать выражения и через сумму, и через произведение множителей.",{"link":422,"schemaName":423,"title":424,"key":425,"seo":426,"description":428},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=why-factoring","list","Зачем это нужно?",{},{"title":427},"Чем полезно разложение квадратного трёхчлена на множители?","Разложение квадратных трёхчленов на множители позволяет упрощать выражения, сразу видеть их корни и даёт альтернативный способ решать квадратные уравнения.",{"link":430,"schemaName":262,"title":431,"key":432,"seo":433,"description":434},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=manual-factoring","Разложение \"вручную\"",{},{},"Методика разложения \"простых\" квадратных трёхчленов на множители вручную.",{"link":436,"schemaName":183,"title":437,"key":438,"seo":439,"description":441},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=general-factoring","Разложение в общем виде",{},{"title":440},"Формула разложения квадратного трёхчлена на множители","Если у квадратного трёхчлена есть корни, то его всегда можно разложить на множители с участием этих корней.",{"link":443,"schemaName":326,"title":444,"key":445,"seo":446,"description":448},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=quadratic-from-any","Любые числа это корни!",{},{"title":447},"Любая пара чисел является корнями квадратного трёхчлена","Из общей формулы разложения на множители следует, что любые два числа являются корнями какого-то квадратного трёхчлена.",{"link":450,"schemaName":262,"title":451,"key":452,"seo":453,"description":455},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=roots-plane","Плоскость корней",{},{"title":454},"Координатная плоскость корней квадратных уравнений","Геометрическая визуализация того факта, что абсолютно любые два числа являются корнями какого-то квадратного трёхчлена.",{"link":457,"schemaName":270,"title":458,"key":459,"seo":460,"description":461},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=varianty-razlozheniya","Варианты разложения",{},{},"Все возможные варианты разложения квадратного трёхчлена на множители.",{"link":463,"schemaName":370,"title":464,"key":465,"seo":466,"description":468},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=vyvod-formuly-razlozheniya","Вывод формулы разложения",{},{"title":467},"Вывод формулы разложения квадратного трёхчлена","Пошаговый вывод формулы разложения квадратного трёхчлена на множители с пояснениями.",{"link":470,"schemaName":224,"title":471,"key":472,"seo":474,"description":476},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=razlozhenie-bikvadratnykh-trekhchlenov","Разложение биквадратных трёхчленов",{"title":473},"Разложение биквадратных",{"title":475},"Разложение биквадратного трёхчлена на множители","Задачи на отработку разложения биквадратных трёхчленов на множители через промежуточную подстановку.",{"elements":478},{"accent_statement":246,"accent_important":245,"problem":318},{"type":170,"link":480,"title":481,"description":482,"keyLinks":483,"stats":526},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F","Теорема Виета","\n    Две простые и очень полезные формулы, которые связывают корни и коэффициенты квадратного трёхчлена.\n    Они позволяют быстро проверять корни, составлять уравнения и изучать особые виды квадратных уравнений.\n  ",[484,490,498,505,512,519],{"link":485,"schemaName":183,"title":481,"key":486,"seo":487,"description":489},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=vietas-formulas",{},{"title":488},"Как звучит теорема Виета?","Сумма корней квадратного трёхчлена равна -B\u002FA, а произведение корней равно C\u002FA.\n          Не существует других чисел, кроме корней, которые удовлетворяли бы этим формулам.",{"link":491,"schemaName":492,"title":493,"key":494,"seo":495,"description":497},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=eto-formuly-ili-teorema","paragraph","Это формулы или теорема?",{},{"title":496},"Как правильно \"формулы Виета\" или \"теорема Виета\"?","Можно и так, и так. Вас поймут в любом случае.\n              Но вообще \"формулы Виета\" это про сами равенства, а \"теорема Виета\" это вместе с утверждениями.",{"link":499,"schemaName":492,"title":500,"key":501,"seo":502,"description":504},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=pryamaya-i-obratnaya-teoremy","Прямая и обратная теоремы",{},{"title":503},"Обратная теорема Виета","Прямая это про само наличие формул, а обратная про то, что работают формулы только для корней.\n              Можно не париться.",{"link":506,"schemaName":492,"title":507,"key":508,"seo":509,"description":511},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=kak-zapomnit-naizust","Как запомнить наизусть?",{},{"title":510},"Как запомнить формулы Виета?","Запоминать не обязательно, они моментально выводятся раскрытием скобок в разложении на множители.",{"link":513,"schemaName":262,"title":514,"key":515,"seo":516,"description":518},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=primenenie-formul-vieta","Зачем нужна?",{},{"title":517},"Зачем нужны формулы Виета?","Формулы применяются для быстрой проверки корней, составления уравнений по корням и установления связи между коэффициентами.",{"link":520,"schemaName":270,"title":521,"key":522,"seo":523,"description":525},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=algoritm-vyvoda","Алгоритм вывода",{},{"title":524},"Быстрый алгоритм вывода формул Виета","Достаточно записать равенство стандартного вида квадратного трёхчлена и его разложения на множители.\n          Потом просто раскрыть скобки.",{"elements":527},{"accent_statement":246,"accent_important":279,"problem":528},17,{"type":170,"link":530,"title":531,"description":532,"keyLinks":533,"stats":581},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F","Решение в уме","\n    Подробный разбор всех способов решения квадратных уравнений в уме.\n    Бесконечно генерируемые задачи на отработку как каждого способа по отдельности, так и всех способов сразу.\n  ",[534,541,548,554,560,567,574],{"link":535,"schemaName":270,"title":536,"key":537,"seo":538,"description":540},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-incomplete","Решение неполных",{},{"title":539},"Решение неполных квадратных уравнений в уме","Все неполные квадратные уравнения решаются в уме при помощи одной из трех формул.\n          Не нужно ничего угадывать.\n          Находится решение элементарно.",{"link":542,"schemaName":183,"title":543,"key":544,"seo":545,"description":547},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-zero-sum","Нулевая сумма",{},{"title":546},"Решение квадратных уравнений в уме по сумме коэффициентов","Нулевая сумма коэффициентов позволяет моментально получить корни.\n          Это самый простой и полезный способ решать квадратные уравнения в уме.",{"link":549,"schemaName":183,"title":283,"key":550,"seo":551,"description":553},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-square",{},{"title":552},"Решение квадратных уравнений в уме через полный квадрат","Иногда квадратное уравнение можно целиком запаковать в квадрат суммы или разности.\n          В таком случае у него будет один корень, который находится элементарно.",{"link":555,"schemaName":183,"title":412,"key":556,"seo":557,"description":559},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-factoring",{},{"title":558},"Решение квадратных уравнений в уме через разложение на множители","Если квадратное уравнение приведённое (A = 1), то его можно попытаться разложить на множители в уме.\n          Для этого надо найти такие t и k, чтобы t + k = B и tk = C. Корнями тогда будут числа -t и -k.",{"link":561,"schemaName":183,"title":562,"key":563,"seo":564,"description":566},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-ato-c","Перенос A к C",{},{"title":565},"Как получить приведённое квадратное уравнение?","Простой метод получения приведённого квадратного уравнения в форме, позволяющей решить его в уме.\n          Для этого надо \"перенести\" коэффициент A к C.",{"link":568,"schemaName":270,"title":569,"key":570,"seo":571,"description":573},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all","Схема способов",{},{"title":572},"Способы решения квадратных уравнений в уме","Удобная схема с перечислением всех способов быстрого решения квадратных уравнений в уме.\n          Также даны подсказки по корням.",{"link":575,"schemaName":385,"title":576,"key":577,"seo":578,"description":580},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all-practice","Задачи на все способы",{},{"title":579},"Задачи на решение квадратных уравнений в уме","Бесконечно генерируемые задачи на отработку всех способов решения квадратных уравнений в уме:\n          нулевой суммы, полного квадрата, разложения на множители и переноса A к C.",{"elements":582},{"accent_statement":583,"accent_important":246,"problem":247},4,{"type":170,"link":585,"title":273,"description":586,"keyLinks":587,"stats":609},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fformulas\u002F","\n    Наглядные схемы всех формул, понятий и методов решения квадратных уравнений, с учётом логики их вывода.\n    Набор смешанных задач, которые сводятся к квадратным трёхчленам и квадратным уравнениям.\n  ",[588,595,602],{"link":589,"schemaName":270,"title":590,"key":591,"seo":592,"description":594},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fformulas\u002F?element=formulas","Схема формул",{},{"title":593},"Схема формул по квадратным уравнениям","Наглядная схема всех формул и понятий, связанных с квадратными уравнениями, с учётом логики их вывода.",{"link":596,"schemaName":270,"title":597,"key":598,"seo":599,"description":601},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fformulas\u002F?element=methods","Схема решений",{},{"title":600},"Схема способов решения квадратных уравнений","Наглядная схема всех способов решения квадратных уравнений: универсальный способ, неполные квадратные уравнения и способы решения в уме.",{"link":603,"schemaName":492,"title":604,"key"