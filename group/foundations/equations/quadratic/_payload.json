tions\u002Felementary\u002F",[172],{"type":173,"contentType":8,"title":174,"link":175,"uniques":176},"auto","Нулевые множители","\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F",[177],{"name":178,"title":179,"link":180,"schemaName":181},"zeroProductPropertyMethod","Метод нулевых множителей","\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-method","accent_statement",[183,192],{"type":184,"title":153,"items":185},"parent",[186],{"type":187,"title":188,"info":189,"link":190,"reason":191},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https:\u002F\u002Fddpu.edu.ua\u002Ffmk\u002Fstudentam\u002F3em\u002F10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":184,"title":15,"items":193},[194,200],{"type":195,"title":196,"info":197,"link":198,"reason":199},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":187,"title":201,"info":202,"reason":203},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[205],{"contributorId":206,"name":207,"avatarUrl":208},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png","group",[211,242,275,313,404,473],{"type":168,"link":212,"title":213,"description":214,"keyLinks":215,"stats":237},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F","Что это такое?","\n    Разберемся, что вообще такое квадратное уравнение и квадратный трехчлен.\n    Как эти термины появились, чем они похожи, а чем отличаются.\n    Научимся определять, является ли уравнение квадратным.\n  ",[216,223,231],{"link":217,"schemaName":218,"title":219,"key":220,"seo":221,"description":222},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=problematic-equations","problems","Квадратные уравнения в жизни",{},{},"Примеры разнообразных жизненных ситуаций, которые сводятся к квадратным уравнениям.\n          Так станет понятно, почему вообще нужно уметь их решать.",{"link":224,"schemaName":225,"title":226,"key":227,"seo":228,"description":230},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=quadratic-polynomial","accent_term","Квадратный трёхчлен",{},{"title":229},"Что такое квадратный трёхчлен?","Многочлен с максимальной степенью неизвестной, равной двум.\n          Выступает \"шаблоном\" или \"общим видом\" для всех квадратных уравнений.",{"link":232,"schemaName":225,"title":233,"key":234,"seo":235,"description":236},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=quadratic-equation","Квадратное уравнение",{},{},"Любое уравнение, которое преобразованиями без потери корней можно привести к виду квадратного трёхчлена.",{"elements":238},{"accent_term":239,"accent_important":240,"problem":241},2,1,5,{"type":168,"link":243,"title":244,"description":245,"keyLinks":246,"stats":271},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F","Неполная форма","\n    Неполные квадратные уравнения — простейшие формы квадратных уравнений, в которых отсутствуют коэффициент B, C или оба сразу.\n    Разберемся, как их правильно решать в каждом отдельном случае.\n  ",[247,254,262],{"link":248,"schemaName":225,"title":249,"key":250,"seo":251,"description":253},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=quadratic-missing-terms","Неполное квадратное уравнение",{},{"title":252},"Что такое неполное квадратное уравнение?","Квадратное уравнение, у которого равен нулю коэффициент B или C или оба сразу.",{"link":255,"schemaName":256,"title":257,"key":258,"seo":259,"description":261},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=reshenie-nepolnykh-kvadratnykh-uravneniy","heading","Решение таких уравнений",{},{"title":260},"Как решать неполные квадратные уравнения?","Подробный разбор решения всех видов неполных квадратных уравнений с выводом общих формул.",{"link":263,"schemaName":264,"title":265,"key":266,"seo":268,"description":270},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=all-formulas","diagram","Общие формулы неполных квадратных уравнений",{"title":267},"Общие формулы",{"title":269},"Общие формулы для решения неполных квадратных уравнений","Формулы для всех трёх типов неполных квадратных уравнений:\n          когда \"B\" и \"C\" равны нулю, когда \"C\" равен нулю и когда \"B\" равен нулю.",{"elements":272},{"accent_term":240,"accent_statement":273,"accent_important":240,"problem":274},3,7,{"type":168,"link":276,"title":277,"description":278,"keyLinks":279,"stats":310},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F","Полный квадрат","\n    Процесс \"запаковки\" развёрнутого выражения в короткую скобку в квадрате.\n    С его помощью можно решить любое квадратное уравнение!\n    Разберёмся, как его проводить на подробных и наглядных примерах с визуализацией.\n  ",[280,287,294,302],{"link":281,"schemaName":225,"title":282,"key":283,"seo":284,"description":286},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=what-is-it","Выделение полного квадрата",{"title":213},{"title":285},"Что такое выделение полного квадрата?","\"Запаковка\" развёрнутого выражения в скобку в квадрате.",{"link":288,"schemaName":256,"title":289,"key":290,"seo":291,"description":293},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=zachem-etim-zanimatsya","Зачем это делать?",{},{"title":292},"Зачем выделять полный квадрат?","Выделение полного квадрата -- мощный инструмент для преобразования выражения и решения квадратных уравнений.",{"link":295,"schemaName":256,"title":296,"key":297,"seo":299,"description":301},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=reshenie-kvadratnykh-uravneniy","Решение квадратных уравнений",{"title":298},"Решение уравнений",{"title":300},"Решение квадратных уравнений через выделение полного квадрата","Выделение полного квадрата -- ключ к решению абсолютно любых квадратных уравнений.",{"link":303,"schemaName":304,"title":305,"key":306,"seo":307,"description":309},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=vizualizatsiya-protsessa","image","Визуализация процесса",{},{"title":308},"Визуализация выделения полного квадрата","Как в прямом смысле из фигур поменьше собирают или \"выделяют\" большой квадрат.",{"elements":311},{"accent_term":240,"accent_important":240,"problem":312},11,{"type":168,"link":314,"title":315,"description":316,"keyLinks":317,"stats":401},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F","Формула корней","\n    Понятный вывод общей формулы корней квадратного уравнения с подробными объяснениями каждого шага.\n    Пояснение, что такое дискриминант, откуда он взялся и почему по нему можно узнать количество корней.\n  ",[318,326,333,340,347,354,362,370,377,385,393],{"link":319,"schemaName":320,"title":321,"key":322,"seo":323,"description":325},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=general-formulas","accent_important","Общие формулы корней",{},{"title":324},"Общие формулы корней уравнений","Общие формулы корней позволяют очень быстро решать сложные виды уравнений.",{"link":327,"schemaName":225,"title":328,"key":329,"seo":330,"description":332},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=discriminant","Дискриминант",{},{"title":331},"Дискриминант квадратного уравнения","Особое число, высчитываемое через коэффициенты квадратного уравнения, которое позволяет понять, сколько корней имеет это уравнение.",{"link":334,"schemaName":181,"title":335,"key":336,"seo":338,"description":339},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=formula","Формула корней квадратного уравнения",{"title":337},"Корни квадратного уравнения",{},"Общая формула, которая позволяет найти корни любого квадратного уравнения, если подставить в неё конкретные числа вместо буквенных коэффициентов.",{"link":341,"schemaName":225,"title":342,"key":343,"seo":344,"description":346},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=biquadratic","Биквадратное уравнение",{},{"title":345},"Что такое биквадратное уравнение?","Особый вид уравнений четвёртой степени, которые можно решить сведением к квадратному уравнению.",{"link":348,"schemaName":320,"title":349,"key":350,"seo":352,"description":353},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=nerazreshimost-uravneniy-vysshikh-stepeney","Пределы общих формул корней",{"title":351},"Пределы общих формул",{},"Для уравнений выше четвёртой степени не существует общих формул корней.",{"link":355,"schemaName":264,"title":356,"key":357,"seo":359,"description":361},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=algorithm","Алгоритм решения квадратного уравнения",{"title":358},"Алгоритм решения",{"title":360},"Алгоритм решения квадратных уравнений","Диаграмма, которая показывает, как решить абсолютно любое квадратное уравнение.",{"link":363,"schemaName":364,"title":365,"key":366,"seo":367,"description":369},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=vyvod-formuly-korney","table","Вывод формулы корней",{},{"title":368},"Вывод формулы корней квадратного уравнения","Пошаговый вывод формулы корней квадратного уравнения с пояснениями.",{"link":371,"schemaName":218,"title":372,"key":373,"seo":374,"description":376},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=chetnyy-koeffitsient","Чётный коэффициент",{},{"title":375},"Квадратное уравнение с чётным коэффициентом","Общая и более простая формула корней квадратного уравнения с чётным коэффициентом B.",{"link":378,"schemaName":379,"title":380,"key":381,"seo":382,"description":384},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=sridharas-method","problem","Метод Сридхары",{},{"title":383},"Формула корней квадратного уравнения по методу Сридхары","Более простой способ вывести формулу корней квадратного уравнения, но с небольшим трюком.",{"link":386,"schemaName":218,"title":387,"key":388,"seo":389,"description":392},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=quadratic-in-f","Трёхчленное уравнение",{},{"title":390,"description":391},"Что такое трёхчленное уравнение?","Определение трёхчленных уравнений и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений из трёх членов с одинаковой \"неизвестной функцией\" в разных степенях, которые могут быть сведены к квадратному уравнению.",{"link":394,"schemaName":218,"title":395,"key":396,"seo":397,"description":400},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=palindromials","Возвратное уравнение",{},{"title":398,"description":399},"Что такое возвратное уравнение?","Определение возвратных уравнений (уравнений палиндромов) и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений, в которых коэффициенты повторяются зеркально относительно \"центра\" уравнения.",{"elements":402},{"accent_term":239,"accent_statement":240,"accent_important":239,"problem":403},14,{"type":168,"link":405,"title":406,"description":407,"keyLinks":408,"stats":471},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F","Разложение на множители","\n    Запись квадратных трехчленов и квадратных уравнений в виде произведения множителей, а не суммы слагаемых.\n    Помогает быстро решать уравнения, упрощать сложные выражения и сразу видеть корни.\n  ",[409,415,423,429,436,443,450,456,463],{"link":410,"schemaName":320,"title":411,"key":412,"seo":413,"description":414},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=i-plyus-i-umnozhenie-vazhny","И плюс, и умножение важны!",{},{},"В разных ситуациях надо уметь записывать выражения и через сумму, и через произведение множителей.",{"link":416,"schemaName":417,"title":418,"key":419,"seo":420,"description":422},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=why-factoring","list","Зачем это нужно?",{},{"title":421},"Чем полезно разложение квадратного трёхчлена на множители?","Разложение квадратных трёхчленов на множители позволяет упрощать выражения, сразу видеть их корни и даёт альтернативный способ решать квадратные уравнения.",{"link":424,"schemaName":256,"title":425,"key":426,"seo":427,"description":428},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=manual-factoring","Разложение \"вручную\"",{},{},"Методика разложения \"простых\" квадратных трёхчленов на множители вручную.",{"link":430,"schemaName":181,"title":431,"key":432,"seo":433,"description":435},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=general-factoring","Разложение в общем виде",{},{"title":434},"Формула разложения квадратного трёхчлена на множители","Если у квадратного трёхчлена есть корни, то его всегда можно разложить на множители с участием этих корней.",{"link":437,"schemaName":320,"title":438,"key":439,"seo":440,"description":442},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=quadratic-from-any","Любые числа это корни!",{},{"title":441},"Любая пара чисел является корнями квадратного трёхчлена","Из общей формулы разложения на множители следует, что любые два числа являются корнями какого-то квадратного трёхчлена.",{"link":444,"schemaName":256,"title":445,"key":446,"seo":447,"description":449},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=roots-plane","Плоскость корней",{},{"title":448},"Координатная плоскость корней квадратных уравнений","Геометрическая визуализация того факта, что абсолютно любые два числа являются корнями какого-то квадратного трёхчлена.",{"link":451,"schemaName":264,"title":452,"key":453,"seo":454,"description":455},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=varianty-razlozheniya","Варианты разложения",{},{},"Все возможные варианты разложения квадратного трёхчлена на множители.",{"link":457,"schemaName":364,"title":458,"key":459,"seo":460,"description":462},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=vyvod-formuly-razlozheniya","Вывод формулы разложения",{},{"title":461},"Вывод формулы разложения квадратного трёхчлена","Пошаговый вывод формулы разложения квадратного трёхчлена на множители с пояснениями.",{"link":464,"schemaName":218,"title":465,"key":466,"seo":468,"description":470},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=razlozhenie-bikvadratnykh-trekhchlenov","Разложение биквадратных трёхчленов",{"title":467},"Разложение биквадратных",{"title":469},"Разложение биквадратного трёхчлена на множители","Задачи на отработку разложения биквадратных трёхчленов на множители через промежуточную подстановку.",{"elements":472},{"accent_statement":240,"accent_important":239,"problem":312},{"type":168,"link":474,"title":475,"description":476,"keyLinks":477,"stats":520},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F","Теорема Виета","\n    Две простые и очень полезные формулы, которые связывают корни и коэффициенты квадратного трёхчлена.\n    Они позволяют быстро проверять корни, составлять уравнения и изучать особые виды квадратных уравнений.\n  ",[478,484,492,499,506,513],{"link":479,"schemaName":181,"title":475,"key":480,"seo":481,"description":483},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=vietas-formulas",{},{"title":482},"Как звучит теорема Виета?","Сумма корней квадратного трёхчлена равна -B\u002FA, а произведение корней равно C\u002FA.\n          Не существует других чисел, кроме корней, которые удовлетворяли бы этим формулам.",{"link":485,"schemaName":486,"title":487,"key":488,"seo":489,"description":491},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=eto-formuly-ili-teorema","paragraph","Это формулы или теорема?",{},{"title":490},"Как правильно \"формулы Виета\" или \"теорема Виета\"?","Можно и так, и так. Вас поймут в любом случае.\n              Но вообще \"формулы Виета\" это про сами равенства, а \"теорема Виета\" это вместе с утверждениями.",{"link":493,"schemaName":486,"title":494,"key":495,"seo":496,"description":498},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=pryamaya-i-obratnaya-teoremy","Прямая и обратная теоремы",{},{"title":497},"Обратная теорема Виета","Прямая это про само наличие формул, а обратная про то, что работают формулы только для корней.\n              Можно не париться.",{"link":500,"schemaName":486,"title":501,"key":502,"seo":503,"description":505},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=kak-zapomnit-naizust","Как запомнить наизусть?",{},{"title":504},"Как запомнить формулы Виета?","Запоминать не обязательно, они моментально выводятся раскрытием скобок в разложении на множители.",{"link":507,"schemaName":256,"title":508,"key":509,"seo":510,"description":512},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=primenenie-formul-vieta","Зачем нужна?",{},{"title":511},"Зачем нужны формулы Виета?","Формулы применяются для быстрой проверки корней, составления уравнений по корням и установления связи между коэффициентами.",{"link":514,"schemaName":264,"title":515,"key":516,"seo":517,"description":519},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=algoritm-vyvoda","Алгоритм вывода",{},{"title":518},"Быстрый алгоритм вывода формул Виета","Достаточно записать равенство стандартного вида квадратного трёхчлена и его разложения на множители.\n          Потом просто раскрыть скобки.",{"elements":521},{"accent_statement":240,"accent_important":273,"problem":522},17,{"contributorsCount":274,"sponsorsCount":241},{"shortBookId":5,"frontNav":525},{"type":14,"shortId":5,"title":15,"flags":526,"link":17,"children":527},{},[528],{"type":209,"separator":529,"shortId":530,"title":153,"flags":531,"link":154,"children":532},true,"foundations\u002Fequations",{},[533,540,543],{"type":168,"shortId":534,"title":169,"flags":535,"link":170,"parts":536},"foundations\u002Fequations\u002Felementary",{},[537,538,539],"article","summary","practice",{"type":8,"shortId":541,"title":174,"flags":542,"link":175},"foundations\u002Fequations\u002Fzero-product-property",{},{"type":209,"separator":544,"shortId":145,"title":147,"flags":545,"link":546,"children":547},false,{},"\u002Fgroup\u002Ffoundations\u002Fequations\u002Fquadratic\u002F",[548,552,556,560,564,568],{"type":168,"shortId":549,"title":213,"flags":550,"link":212,"parts":551},"foundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it",{},[537,538