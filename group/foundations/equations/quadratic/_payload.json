ем они похожи, а чем отличаются.\n    Научимся определять, является ли уравнение квадратным.\n  ",[222,229,237],{"link":223,"schemaName":224,"title":225,"key":226,"seo":227,"description":228},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=problematic-equations","problems","Квадратные уравнения в жизни",{},{},"Примеры разнообразных жизненных ситуаций, которые сводятся к квадратным уравнениям.\n          Так станет понятно, почему вообще нужно уметь их решать.",{"link":230,"schemaName":231,"title":232,"key":233,"seo":234,"description":236},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=quadratic-polynomial","accent_term","Квадратный трёхчлен",{},{"title":235},"Что такое квадратный трёхчлен?","Многочлен с максимальной степенью неизвестной, равной двум.\n          Выступает \"шаблоном\" или \"общим видом\" для всех квадратных уравнений.",{"link":238,"schemaName":231,"title":239,"key":240,"seo":241,"description":242},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=quadratic-equation","Квадратное уравнение",{},{},"Любое уравнение, которое преобразованиями без потери корней можно привести к виду квадратного трёхчлена.",{"elements":244},{"accent_term":245,"accent_important":246,"problem":247},2,1,5,{"type":170,"link":249,"title":250,"description":251,"keyLinks":252,"stats":277},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F","Неполная форма","\n    Неполные квадратные уравнения — простейшие формы квадратных уравнений, в которых отсутствуют коэффициент B, C или оба сразу.\n    Разберемся, как их правильно решать в каждом отдельном случае.\n  ",[253,260,268],{"link":254,"schemaName":231,"title":255,"key":256,"seo":257,"description":259},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=quadratic-missing-terms","Неполное квадратное уравнение",{},{"title":258},"Что такое неполное квадратное уравнение?","Квадратное уравнение, у которого равен нулю коэффициент B или C или оба сразу.",{"link":261,"schemaName":262,"title":263,"key":264,"seo":265,"description":267},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=reshenie-nepolnykh-kvadratnykh-uravneniy","heading","Решение таких уравнений",{},{"title":266},"Как решать неполные квадратные уравнения?","Подробный разбор решения всех видов неполных квадратных уравнений с выводом общих формул.",{"link":269,"schemaName":270,"title":271,"key":272,"seo":274,"description":276},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=all-formulas","diagram","Общие формулы неполных квадратных уравнений",{"title":273},"Общие формулы",{"title":275},"Общие формулы для решения неполных квадратных уравнений","Формулы для всех трёх типов неполных квадратных уравнений:\n          когда \"B\" и \"C\" равны нулю, когда \"C\" равен нулю и когда \"B\" равен нулю.",{"elements":278},{"accent_term":246,"accent_statement":279,"accent_important":246,"problem":280},3,7,{"type":170,"link":282,"title":283,"description":284,"keyLinks":285,"stats":316},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F","Полный квадрат","\n    Процесс \"запаковки\" развёрнутого выражения в короткую скобку в квадрате.\n    С его помощью можно решить любое квадратное уравнение!\n    Разберёмся, как его проводить на подробных и наглядных примерах с визуализацией.\n  ",[286,293,300,308],{"link":287,"schemaName":231,"title":288,"key":289,"seo":290,"description":292},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=what-is-it","Выделение полного квадрата",{"title":219},{"title":291},"Что такое выделение полного квадрата?","\"Запаковка\" развёрнутого выражения в скобку в квадрате.",{"link":294,"schemaName":262,"title":295,"key":296,"seo":297,"description":299},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=zachem-etim-zanimatsya","Зачем это делать?",{},{"title":298},"Зачем выделять полный квадрат?","Выделение полного квадрата -- мощный инструмент для преобразования выражения и решения квадратных уравнений.",{"link":301,"schemaName":262,"title":302,"key":303,"seo":305,"description":307},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=reshenie-kvadratnykh-uravneniy","Решение квадратных уравнений",{"title":304},"Решение уравнений",{"title":306},"Решение квадратных уравнений через выделение полного квадрата","Выделение полного квадрата -- ключ к решению абсолютно любых квадратных уравнений.",{"link":309,"schemaName":310,"title":311,"key":312,"seo":313,"description":315},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=vizualizatsiya-protsessa","image","Визуализация процесса",{},{"title":314},"Визуализация выделения полного квадрата","Как в прямом смысле из фигур поменьше собирают или \"выделяют\" большой квадрат.",{"elements":317},{"accent_term":246,"accent_important":246,"problem":162},{"type":170,"link":319,"title":320,"description":321,"keyLinks":322,"stats":406},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F","Формула корней","\n    Понятный вывод общей формулы корней квадратного уравнения с подробными объяснениями каждого шага.\n    Пояснение, что такое дискриминант, откуда он взялся и почему по нему можно узнать количество корней.\n  ",[323,331,338,345,352,359,367,375,382,390,398],{"link":324,"schemaName":325,"title":326,"key":327,"seo":328,"description":330},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=general-formulas","accent_important","Общие формулы корней",{},{"title":329},"Общие формулы корней уравнений","Общие формулы корней позволяют очень быстро решать сложные виды уравнений.",{"link":332,"schemaName":231,"title":333,"key":334,"seo":335,"description":337},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=discriminant","Дискриминант",{},{"title":336},"Дискриминант квадратного уравнения","Особое число, высчитываемое через коэффициенты квадратного уравнения, которое позволяет понять, сколько корней имеет это уравнение.",{"link":339,"schemaName":183,"title":340,"key":341,"seo":343,"description":344},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=formula","Формула корней квадратного уравнения",{"title":342},"Корни квадратного уравнения",{},"Общая формула, которая позволяет найти корни любого квадратного уравнения, если подставить в неё конкретные числа вместо буквенных коэффициентов.",{"link":346,"schemaName":231,"title":347,"key":348,"seo":349,"description":351},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=biquadratic","Биквадратное уравнение",{},{"title":350},"Что такое биквадратное уравнение?","Особый вид уравнений четвёртой степени, которые можно решить сведением к квадратному уравнению.",{"link":353,"schemaName":325,"title":354,"key":355,"seo":357,"description":358},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=nerazreshimost-uravneniy-vysshikh-stepeney","Пределы общих формул корней",{"title":356},"Пределы общих формул",{},"Для уравнений выше четвёртой степени не существует общих формул корней.",{"link":360,"schemaName":270,"title":361,"key":362,"seo":364,"description":366},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=algorithm","Алгоритм решения квадратного уравнения",{"title":363},"Алгоритм решения",{"title":365},"Алгоритм решения квадратных уравнений","Диаграмма, которая показывает, как решить абсолютно любое квадратное уравнение.",{"link":368,"schemaName":369,"title":370,"key":371,"seo":372,"description":374},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=vyvod-formuly-korney","table","Вывод формулы корней",{},{"title":373},"Вывод формулы корней квадратного уравнения","Пошаговый вывод формулы корней квадратного уравнения с пояснениями.",{"link":376,"schemaName":224,"title":377,"key":378,"seo":379,"description":381},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=even-b","Чётный коэффициент",{},{"title":380},"Квадратное уравнение с чётным коэффициентом","Общая и более простая формула корней квадратного уравнения с чётным коэффициентом B.",{"link":383,"schemaName":384,"title":385,"key":386,"seo":387,"description":389},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=sridharas-method","problem","Метод Сридхары",{},{"title":388},"Формула корней квадратного уравнения по методу Сридхары","Более простой способ вывести формулу корней квадратного уравнения, но с небольшим трюком.",{"link":391,"schemaName":224,"title":392,"key":393,"seo":394,"description":397},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=quadratic-in-f","Трёхчленное уравнение",{},{"title":395,"description":396},"Что такое трёхчленное уравнение?","Определение трёхчленных уравнений и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений из трёх членов с одинаковой \"неизвестной функцией\" в разных степенях, которые могут быть сведены к квадратному уравнению.",{"link":399,"schemaName":224,"title":400,"key":401,"seo":402,"description":405},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=palindromials","Возвратное уравнение",{},{"title":403,"description":404},"Что такое возвратное уравнение?","Определение возвратных уравнений (уравнений палиндромов) и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений, в которых коэффициенты повторяются зеркально относительно \"центра\" уравнения.",{"elements":407},{"accent_term":245,"accent_statement":246,"accent_important":245,"problem":408},14,{"type":170,"link":410,"title":411,"description":412,"keyLinks":413,"stats":476},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F","Разложение на множители","\n    Запись квадратных трехчленов и квадратных уравнений в виде произведения множителей, а не суммы слагаемых.\n    Помогает быстро решать уравнения, упрощать сложные выражения и сразу видеть корни.\n  ",[414,420,428,434,441,448,455,461,468],{"link":415,"schemaName":325,"title":416,"key":417,"seo":418,"description":419},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=i-plyus-i-umnozhenie-vazhny","И плюс, и умножение важны!",{},{},"В разных ситуациях надо уметь записывать выражения и через сумму, и через произведение множителей.",{"link":421,"schemaName":422,"title":423,"key":424,"seo":425,"description":427},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=why-factoring","list","Зачем это нужно?",{},{"title":426},"Чем полезно разложение квадратного трёхчлена на множители?","Разложение квадратных трёхчленов на множители позволяет упрощать выражения, сразу видеть их корни и даёт альтернативный способ решать квадратные уравнения.",{"link":429,"schemaName":262,"title":430,"key":431,"seo":432,"description":433},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=manual-factoring","Разложение \"вручную\"",{},{},"Методика разложения \"простых\" квадратных трёхчленов на множители вручную.",{"link":435,"schemaName":183,"title":436,"key":437,"seo":438,"description":440},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=general-factoring","Разложение в общем виде",{},{"title":439},"Формула разложения квадратного трёхчлена на множители","Если у квадратного трёхчлена есть корни, то его всегда можно разложить на множители с участием этих корней.",{"link":442,"schemaName":325,"title":443,"key":444,"seo":445,"description":447},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=quadratic-from-any","Любые числа это корни!",{},{"title":446},"Любая пара чисел является корнями квадратного трёхчлена","Из общей формулы разложения на множители следует, что любые два числа являются корнями какого-то квадратного трёхчлена.",{"link":449,"schemaName":262,"title":450,"key":451,"seo":452,"description":454},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=roots-plane","Плоскость корней",{},{"title":453},"Координатная плоскость корней квадратных уравнений","Геометрическая визуализация того факта, что абсолютно любые два числа являются корнями какого-то квадратного трёхчлена.",{"link":456,"schemaName":270,"title":457,"key":458,"seo":459,"description":460},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=varianty-razlozheniya","Варианты разложения",{},{},"Все возможные варианты разложения квадратного трёхчлена на множители.",{"link":462,"schemaName":369,"title":463,"key":464,"seo":465,"description":467},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=vyvod-formuly-razlozheniya","Вывод формулы разложения",{},{"title":466},"Вывод формулы разложения квадратного трёхчлена","Пошаговый вывод формулы разложения квадратного трёхчлена на множители с пояснениями.",{"link":469,"schemaName":224,"title":470,"key":471,"seo":473,"description":475},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=razlozhenie-bikvadratnykh-trekhchlenov","Разложение биквадратных трёхчленов",{"title":472},"Разложение биквадратных",{"title":474},"Разложение биквадратного трёхчлена на множители","Задачи на отработку разложения биквадратных трёхчленов на множители через промежуточную подстановку.",{"elements":477},{"accent_statement":246,"accent_important":245,"problem":163},{"type":170,"link":479,"title":480,"description":481,"keyLinks":482,"stats":525},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F","Теорема Виета","\n    Две простые и очень полезные формулы, которые связывают корни и коэффициенты квадратного трёхчлена.\n    Они позволяют быстро проверять корни, составлять уравнения и изучать особые виды квадратных уравнений.\n  ",[483,489,497,504,511,518],{"link":484,"schemaName":183,"title":480,"key":485,"seo":486,"description":488},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=vietas-formulas",{},{"title":487},"Как звучит теорема Виета?","Сумма корней квадратного трёхчлена равна -B\u002FA, а произведение корней равно C\u002FA.\n          Не существует других чисел, кроме корней, которые удовлетворяли бы этим формулам.",{"link":490,"schemaName":491,"title":492,"key":493,"seo":494,"description":496},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=eto-formuly-ili-teorema","paragraph","Это формулы или теорема?",{},{"title":495},"Как правильно \"формулы Виета\" или \"теорема Виета\"?","Можно и так, и так. Вас поймут в любом случае.\n              Но вообще \"формулы Виета\" это про сами равенства, а \"теорема Виета\" это вместе с утверждениями.",{"link":498,"schemaName":491,"title":499,"key":500,"seo":501,"description":503},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=pryamaya-i-obratnaya-teoremy","Прямая и обратная теоремы",{},{"title":502},"Обратная теорема Виета","Прямая это про само наличие формул, а обратная про то, что работают формулы только для корней.\n              Можно не париться.",{"link":505,"schemaName":491,"title":506,"key":507,"seo":508,"description":510},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=kak-zapomnit-naizust","Как запомнить наизусть?",{},{"title":509},"Как запомнить формулы Виета?","Запоминать не обязательно, они моментально выводятся раскрытием скобок в разложении на множители.",{"link":512,"schemaName":262,"title":513,"key":514,"seo":515,"description":517},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=primenenie-formul-vieta","Зачем нужна?",{},{"title":516},"Зачем нужны формулы Виета?","Формулы применяются для быстрой проверки корней, составления уравнений по корням и установления связи между коэффициентами.",{"link":519,"schemaName":270,"title":520,"key":521,"seo":522,"description":524},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=algoritm-vyvoda","Алгоритм вывода",{},{"title":523},"Быстрый алгоритм вывода формул Виета","Достаточно записать равенство стандартного вида квадратного трёхчлена и его разложения на множители.\n          Потом просто раскрыть скобки.",{"elements":526},{"accent_statement":246,"accent_important":279,"problem":527},17,{"type":170,"link":529,"title":530,"description":531,"keyLinks":532,"stats":580},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F","Решение в уме","\n    Подробный разбор всех способов решения квадратных уравнений в уме.\n    Бесконечно генерируемые задачи на отработку как каждого способа по отдельности, так и всех способов сразу.\n  ",[533,540,547,553,559,566,573],{"link":534,"schemaName":270,"title":535,"key":536,"seo":537,"description":539},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-incomplete","Решение неполных",{},{"title":538},"Решение неполных квадратных уравнений в уме","Все неполные квадратные уравнения решаются в уме при помощи одной из трех формул.\n          Не нужно ничего угадывать.\n          Находится решение элементарно.",{"link":541,"schemaName":183,"title":542,"key":543,"seo":544,"description":546},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-zero-sum","Нулевая сумма",{},{"title":545},"Решение квадратных уравнений в уме по сумме коэффициентов","Нулевая сумма коэффициентов позволяет моментально получить корни.\n          Это самый простой и полезный способ решать квадратные уравнения в уме.",{"link":548,"schemaName":183,"title":283,"key":549,"seo":550,"description":552},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-square",{},{"title":551},"Решение квадратных уравнений в уме через полный квадрат","Иногда квадратное уравнение можно целиком запаковать в квадрат суммы или разности.\n          В таком случае у него будет один корень, который находится элементарно.",{"link":554,"schemaName":183,"title":411,"key":555,"seo":556,"description":558},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-factoring",{},{"title":557},"Решение квадратных уравнений в уме через разложение на множители","Если квадратное уравнение приведённое (A = 1), то его можно попытаться разложить на множители в уме.\n          Для этого надо найти такие t и k, чтобы t + k = B и tk = C. Корнями тогда будут числа -t и -k.",{"link":560,"schemaName":183,"title":561,"key":562,"seo":563,"description":565},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-ato-c","Перенос A к C",{},{"title":564},"Как получить приведённое квадратное уравнение?","Простой метод получения приведённого квадратного уравнения в форме, позволяющей решить его в уме.\n          Для этого надо \"перенести\" коэффициент A к C.",{"link":567,"schemaName":270,"title":568,"key":569,"seo":570,"description":572},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all","Схема способов",{},{"title":571},"Способы решения квадратных уравнений в уме","Удобная схема с перечислением всех способов быстрого решения квадратных уравнений в уме.\n          Также даны подсказки по корням.",{"link":574,"schemaName":384,"title":575,"key":576,"seo":577,"description":579},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all-practice","Задачи на все способы",{},{"title":578},"Задачи на решение квадратных уравнений в уме","Бесконечно генерируемые задачи на отработку всех способов решения квадратных уравнений в уме:\n          нулевой суммы, полного квадрата, разложения на множители и переноса A к C.",{"elements":581},{"accent_statement":247,"accent_important":246,"problem":247},{"type":170,"link":583,"title":273,"description":584,"keyLinks":585,"stats":607},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fformulas\u002F","\n    Наглядные схемы всех формул, понятий и методов решения квадратных уравнений, с учётом логики их вывода.\n    Набор смешанных задач, которые сводятся к квадратным трёхчленам и квадратным уравнениям.\n  ",[586,593,600],{"link":587,"schemaName":270,"title":588,"key":589,"seo":590,"description":592},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fformulas\u002F?element=formulas","Схема формул",{},{"title":591},"Схема формул по квадратным уравнениям","Наглядная схема всех формул и понятий, связанных с квадратными уравнениями, с учётом логики их вывода.",{"link":594,"schemaName":270,"title":595,"key":596,"seo":597,"description":599},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fformulas\u002F?element=methods","Схема решений",{},{"title":598},"Схема способов решения квадратных уравнений","Наглядная схема всех способов решения квадратных уравнений: универсальный способ, неполные квадратные уравнения и способы решения в уме.",{"link":601,"schemaName":491,"title":602,"key":603,"seo":604,"description":606},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fformulas\u002F?element=mixed-problems","Смешанные задачи",{},{"title":605},"Смешанные задачи на квадратные уравнения","Смешанные задачи, которые так или иначе сводятся к квадратным трёхчленам или квадратным уравнениям.",{"elements":608},{"accent_important":246,"problem":609},13,{"contributorsCount":280,"sponsorsCount":247},{"shortBookId":5,"frontNav":612},{"type":14,"shortId":5,"title":15,"flags":613,"link":17,"children":614},{},[615],{"type":215,"separator":616,"shortId":617,"title":153,"flags":618,"link":154,"children":619},true,"foundations\u002Fequations",{},[620,627,630],{"type":170,"shortId":621,"title":171,"flags":622,"link":172,"parts":623},"foundations\u002Fequations\u002Felementary",{},[624,625,626],"article","summary","practice",{"type":8,"shortId":628,"title":176,"flags":629,"link":177},"foundations\u002Fequations\u002Fzero-product-property",{},{"type":215,"separator":631,"shortId":145,"title":147,"flags":632,"link":633,"children":634},false,{},"\u002Fgroup\u002Ffoundations\u002Fequations\u002Fquadratic\u002F",[635,639,643,647,651,655,659,663],{"type":170,"shortId":636,"title":219,"flags":637,"link":218,"parts":638},"foundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it",{},[624,625,626],{"type":170,"shortId":640,"title":250,"flags":641,"link":249,"parts":642},"foundations\u002Fequations\u002Fquadratic\u002Fincomplete",{},[624,625,626],{"type":170,"shortId":644,"title":283,"flags":645,"link":282,"parts":646},"foundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square",{},[624,625,626],{"type":170,"shortId":648,"title":320,"flags":649,"link":319,"parts":650},"foundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula",{},[624,625,626],{"type":170,"shortId":652,"title":411,"flags":653,"link":410,"parts":654},"foundations\u002Fequations\u002Fquadratic\u002Ffactoring",{},[624,625,626],{"type":170,"shortId":656,"title":480,"flags":657,"link":479,"parts":658}