Fequations\u002Felementary\u002F",[174],{"type":175,"contentType":8,"title":176,"link":177,"uniques":178},"auto","Нулевые множители","\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F",[179],{"name":180,"title":181,"link":182,"schemaName":183},"zeroProductPropertyMethod","Метод нулевых множителей","\u002Fpage\u002Ffoundations\u002Fequations\u002Fzero-product-property\u002F?element=zero-product-property-method","accent_statement",[185,194],{"type":186,"title":153,"items":187},"parent",[188],{"type":189,"title":190,"info":191,"link":192,"reason":193},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https:\u002F\u002Fddpu.edu.ua\u002Ffmk\u002Fstudentam\u002F3em\u002F10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":186,"title":15,"items":195},[196,202],{"type":197,"title":198,"info":199,"link":200,"reason":201},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":189,"title":203,"info":204,"reason":205},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[207,211],{"contributorId":208,"name":209,"avatarUrl":210},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png",{"contributorId":212,"name":213,"avatarUrl":214},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg","group",[217,248,280,317,408,477,527],{"type":170,"link":218,"title":219,"description":220,"keyLinks":221,"stats":243},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F","Что это такое?","\n    Разберемся, что вообще такое квадратное уравнение и квадратный трехчлен.\n    Как эти термины появились, чем они похожи, а чем отличаются.\n    Научимся определять, является ли уравнение квадратным.\n  ",[222,229,237],{"link":223,"schemaName":224,"title":225,"key":226,"seo":227,"description":228},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=problematic-equations","problems","Квадратные уравнения в жизни",{},{},"Примеры разнообразных жизненных ситуаций, которые сводятся к квадратным уравнениям.\n          Так станет понятно, почему вообще нужно уметь их решать.",{"link":230,"schemaName":231,"title":232,"key":233,"seo":234,"description":236},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=quadratic-polynomial","accent_term","Квадратный трёхчлен",{},{"title":235},"Что такое квадратный трёхчлен?","Многочлен с максимальной степенью неизвестной, равной двум.\n          Выступает \"шаблоном\" или \"общим видом\" для всех квадратных уравнений.",{"link":238,"schemaName":231,"title":239,"key":240,"seo":241,"description":242},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F?element=quadratic-equation","Квадратное уравнение",{},{},"Любое уравнение, которое преобразованиями без потери корней можно привести к виду квадратного трёхчлена.",{"elements":244},{"accent_term":245,"accent_important":246,"problem":247},2,1,5,{"type":170,"link":249,"title":250,"description":251,"keyLinks":252,"stats":277},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F","Неполная форма","\n    Неполные квадратные уравнения — простейшие формы квадратных уравнений, в которых отсутствуют коэффициент B, C или оба сразу.\n    Разберемся, как их правильно решать в каждом отдельном случае.\n  ",[253,260,268],{"link":254,"schemaName":231,"title":255,"key":256,"seo":257,"description":259},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=quadratic-missing-terms","Неполное квадратное уравнение",{},{"title":258},"Что такое неполное квадратное уравнение?","Квадратное уравнение, у которого равен нулю коэффициент B или C или оба сразу.",{"link":261,"schemaName":262,"title":263,"key":264,"seo":265,"description":267},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=reshenie-nepolnykh-kvadratnykh-uravneniy","heading","Решение таких уравнений",{},{"title":266},"Как решать неполные квадратные уравнения?","Подробный разбор решения всех видов неполных квадратных уравнений с выводом общих формул.",{"link":269,"schemaName":270,"title":271,"key":272,"seo":274,"description":276},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fincomplete\u002F?element=all-formulas","diagram","Общие формулы неполных квадратных уравнений",{"title":273},"Общие формулы",{"title":275},"Общие формулы для решения неполных квадратных уравнений","Формулы для всех трёх типов неполных квадратных уравнений:\n          когда \"B\" и \"C\" равны нулю, когда \"C\" равен нулю и когда \"B\" равен нулю.",{"elements":278},{"accent_term":246,"accent_statement":279,"accent_important":246,"problem":159},3,{"type":170,"link":281,"title":282,"description":283,"keyLinks":284,"stats":315},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F","Полный квадрат","\n    Процесс \"запаковки\" развёрнутого выражения в короткую скобку в квадрате.\n    С его помощью можно решить любое квадратное уравнение!\n    Разберёмся, как его проводить на подробных и наглядных примерах с визуализацией.\n  ",[285,292,299,307],{"link":286,"schemaName":231,"title":287,"key":288,"seo":289,"description":291},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=what-is-it","Выделение полного квадрата",{"title":219},{"title":290},"Что такое выделение полного квадрата?","\"Запаковка\" развёрнутого выражения в скобку в квадрате.",{"link":293,"schemaName":262,"title":294,"key":295,"seo":296,"description":298},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=zachem-etim-zanimatsya","Зачем это делать?",{},{"title":297},"Зачем выделять полный квадрат?","Выделение полного квадрата -- мощный инструмент для преобразования выражения и решения квадратных уравнений.",{"link":300,"schemaName":262,"title":301,"key":302,"seo":304,"description":306},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=reshenie-kvadratnykh-uravneniy","Решение квадратных уравнений",{"title":303},"Решение уравнений",{"title":305},"Решение квадратных уравнений через выделение полного квадрата","Выделение полного квадрата -- ключ к решению абсолютно любых квадратных уравнений.",{"link":308,"schemaName":309,"title":310,"key":311,"seo":312,"description":314},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F?element=vizualizatsiya-protsessa","image","Визуализация процесса",{},{"title":313},"Визуализация выделения полного квадрата","Как в прямом смысле из фигур поменьше собирают или \"выделяют\" большой квадрат.",{"elements":316},{"accent_term":246,"accent_important":246,"problem":163},{"type":170,"link":318,"title":319,"description":320,"keyLinks":321,"stats":405},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F","Формула корней","\n    Понятный вывод общей формулы корней квадратного уравнения с подробными объяснениями каждого шага.\n    Пояснение, что такое дискриминант, откуда он взялся и почему по нему можно узнать количество корней.\n  ",[322,330,337,344,351,358,366,374,381,389,397],{"link":323,"schemaName":324,"title":325,"key":326,"seo":327,"description":329},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=general-formulas","accent_important","Общие формулы корней",{},{"title":328},"Общие формулы корней уравнений","Общие формулы корней позволяют очень быстро решать сложные виды уравнений.",{"link":331,"schemaName":231,"title":332,"key":333,"seo":334,"description":336},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=discriminant","Дискриминант",{},{"title":335},"Дискриминант квадратного уравнения","Особое число, высчитываемое через коэффициенты квадратного уравнения, которое позволяет понять, сколько корней имеет это уравнение.",{"link":338,"schemaName":183,"title":339,"key":340,"seo":342,"description":343},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=formula","Формула корней квадратного уравнения",{"title":341},"Корни квадратного уравнения",{},"Общая формула, которая позволяет найти корни любого квадратного уравнения, если подставить в неё конкретные числа вместо буквенных коэффициентов.",{"link":345,"schemaName":231,"title":346,"key":347,"seo":348,"description":350},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=biquadratic","Биквадратное уравнение",{},{"title":349},"Что такое биквадратное уравнение?","Особый вид уравнений четвёртой степени, которые можно решить сведением к квадратному уравнению.",{"link":352,"schemaName":324,"title":353,"key":354,"seo":356,"description":357},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=nerazreshimost-uravneniy-vysshikh-stepeney","Пределы общих формул корней",{"title":355},"Пределы общих формул",{},"Для уравнений выше четвёртой степени не существует общих формул корней.",{"link":359,"schemaName":270,"title":360,"key":361,"seo":363,"description":365},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=algorithm","Алгоритм решения квадратного уравнения",{"title":362},"Алгоритм решения",{"title":364},"Алгоритм решения квадратных уравнений","Диаграмма, которая показывает, как решить абсолютно любое квадратное уравнение.",{"link":367,"schemaName":368,"title":369,"key":370,"seo":371,"description":373},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=vyvod-formuly-korney","table","Вывод формулы корней",{},{"title":372},"Вывод формулы корней квадратного уравнения","Пошаговый вывод формулы корней квадратного уравнения с пояснениями.",{"link":375,"schemaName":224,"title":376,"key":377,"seo":378,"description":380},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=chetnyy-koeffitsient","Чётный коэффициент",{},{"title":379},"Квадратное уравнение с чётным коэффициентом","Общая и более простая формула корней квадратного уравнения с чётным коэффициентом B.",{"link":382,"schemaName":383,"title":384,"key":385,"seo":386,"description":388},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=sridharas-method","problem","Метод Сридхары",{},{"title":387},"Формула корней квадратного уравнения по методу Сридхары","Более простой способ вывести формулу корней квадратного уравнения, но с небольшим трюком.",{"link":390,"schemaName":224,"title":391,"key":392,"seo":393,"description":396},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=quadratic-in-f","Трёхчленное уравнение",{},{"title":394,"description":395},"Что такое трёхчленное уравнение?","Определение трёхчленных уравнений и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений из трёх членов с одинаковой \"неизвестной функцией\" в разных степенях, которые могут быть сведены к квадратному уравнению.",{"link":398,"schemaName":224,"title":399,"key":400,"seo":401,"description":404},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F?element=palindromials","Возвратное уравнение",{},{"title":402,"description":403},"Что такое возвратное уравнение?","Определение возвратных уравнений (уравнений палиндромов) и примеры с подробным разбором их решения через сведение к квадратным уравнениям.","Особый вид уравнений, в которых коэффициенты повторяются зеркально относительно \"центра\" уравнения.",{"elements":406},{"accent_term":245,"accent_statement":246,"accent_important":245,"problem":407},14,{"type":170,"link":409,"title":410,"description":411,"keyLinks":412,"stats":475},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F","Разложение на множители","\n    Запись квадратных трехчленов и квадратных уравнений в виде произведения множителей, а не суммы слагаемых.\n    Помогает быстро решать уравнения, упрощать сложные выражения и сразу видеть корни.\n  ",[413,419,427,433,440,447,454,460,467],{"link":414,"schemaName":324,"title":415,"key":416,"seo":417,"description":418},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=i-plyus-i-umnozhenie-vazhny","И плюс, и умножение важны!",{},{},"В разных ситуациях надо уметь записывать выражения и через сумму, и через произведение множителей.",{"link":420,"schemaName":421,"title":422,"key":423,"seo":424,"description":426},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=why-factoring","list","Зачем это нужно?",{},{"title":425},"Чем полезно разложение квадратного трёхчлена на множители?","Разложение квадратных трёхчленов на множители позволяет упрощать выражения, сразу видеть их корни и даёт альтернативный способ решать квадратные уравнения.",{"link":428,"schemaName":262,"title":429,"key":430,"seo":431,"description":432},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=manual-factoring","Разложение \"вручную\"",{},{},"Методика разложения \"простых\" квадратных трёхчленов на множители вручную.",{"link":434,"schemaName":183,"title":435,"key":436,"seo":437,"description":439},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=general-factoring","Разложение в общем виде",{},{"title":438},"Формула разложения квадратного трёхчлена на множители","Если у квадратного трёхчлена есть корни, то его всегда можно разложить на множители с участием этих корней.",{"link":441,"schemaName":324,"title":442,"key":443,"seo":444,"description":446},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=quadratic-from-any","Любые числа это корни!",{},{"title":445},"Любая пара чисел является корнями квадратного трёхчлена","Из общей формулы разложения на множители следует, что любые два числа являются корнями какого-то квадратного трёхчлена.",{"link":448,"schemaName":262,"title":449,"key":450,"seo":451,"description":453},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=roots-plane","Плоскость корней",{},{"title":452},"Координатная плоскость корней квадратных уравнений","Геометрическая визуализация того факта, что абсолютно любые два числа являются корнями какого-то квадратного трёхчлена.",{"link":455,"schemaName":270,"title":456,"key":457,"seo":458,"description":459},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=varianty-razlozheniya","Варианты разложения",{},{},"Все возможные варианты разложения квадратного трёхчлена на множители.",{"link":461,"schemaName":368,"title":462,"key":463,"seo":464,"description":466},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=vyvod-formuly-razlozheniya","Вывод формулы разложения",{},{"title":465},"Вывод формулы разложения квадратного трёхчлена","Пошаговый вывод формулы разложения квадратного трёхчлена на множители с пояснениями.",{"link":468,"schemaName":224,"title":469,"key":470,"seo":472,"description":474},"\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=razlozhenie-bikvadratnykh-trekhchlenov","Разложение биквадратных трёхчленов",{"title":471},"Разложение биквадратных",{"title":473},"Разложение биквадратного трёхчлена на множители","Задачи на отработку разложения биквадратных трёхчленов на множители через промежуточную подстановку.",{"elements":476},{"accent_statement":246,"accent_important":245,"problem":163},{"type":170,"link":478,"title":479,"description":480,"keyLinks":481,"stats":524},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F","Теорема Виета","\n    Две простые и очень полезные формулы, которые связывают корни и коэффициенты квадратного трёхчлена.\n    Они позволяют быстро проверять корни, составлять уравнения и изучать особые виды квадратных уравнений.\n  ",[482,488,496,503,510,517],{"link":483,"schemaName":183,"title":479,"key":484,"seo":485,"description":487},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=vietas-formulas",{},{"title":486},"Как звучит теорема Виета?","Сумма корней квадратного трёхчлена равна -B\u002FA, а произведение корней равно C\u002FA.\n          Не существует других чисел, кроме корней, которые удовлетворяли бы этим формулам.",{"link":489,"schemaName":490,"title":491,"key":492,"seo":493,"description":495},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=eto-formuly-ili-teorema","paragraph","Это формулы или теорема?",{},{"title":494},"Как правильно \"формулы Виета\" или \"теорема Виета\"?","Можно и так, и так. Вас поймут в любом случае.\n              Но вообще \"формулы Виета\" это про сами равенства, а \"теорема Виета\" это вместе с утверждениями.",{"link":497,"schemaName":490,"title":498,"key":499,"seo":500,"description":502},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=pryamaya-i-obratnaya-teoremy","Прямая и обратная теоремы",{},{"title":501},"Обратная теорема Виета","Прямая это про само наличие формул, а обратная про то, что работают формулы только для корней.\n              Можно не париться.",{"link":504,"schemaName":490,"title":505,"key":506,"seo":507,"description":509},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=kak-zapomnit-naizust","Как запомнить наизусть?",{},{"title":508},"Как запомнить формулы Виета?","Запоминать не обязательно, они моментально выводятся раскрытием скобок в разложении на множители.",{"link":511,"schemaName":262,"title":512,"key":513,"seo":514,"description":516},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=primenenie-formul-vieta","Зачем нужна?",{},{"title":515},"Зачем нужны формулы Виета?","Формулы применяются для быстрой проверки корней, составления уравнений по корням и установления связи между коэффициентами.",{"link":518,"schemaName":270,"title":519,"key":520,"seo":521,"description":523},"\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=algoritm-vyvoda","Алгоритм вывода",{},{"title":522},"Быстрый алгоритм вывода формул Виета","Достаточно записать равенство стандартного вида квадратного трёхчлена и его разложения на множители.\n          Потом просто раскрыть скобки.",{"elements":525},{"accent_statement":246,"accent_important":279,"problem":526},17,{"type":170,"link":528,"title":529,"description":530,"keyLinks":531,"stats":579},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F","Решение в уме","\n    Подробный разбор всех способов решения квадратных уравнений в уме.\n    Бесконечно генерируемые задачи на отработку как каждого способа по отдельности, так и всех способов сразу.\n  ",[532,539,546,552,558,565,572],{"link":533,"schemaName":270,"title":534,"key":535,"seo":536,"description":538},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-incomplete","Решение неполных",{},{"title":537},"Решение неполных квадратных уравнений в уме","Все неполные квадратные уравнения решаются в уме при помощи одной из трех формул.\n          Не нужно ничего угадывать.\n          Находится решение элементарно.",{"link":540,"schemaName":183,"title":541,"key":542,"seo":543,"description":545},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-zero-sum","Нулевая сумма",{},{"title":544},"Решение квадратных уравнений в уме по сумме коэффициентов","Нулевая сумма коэффициентов позволяет моментально получить корни.\n          Это самый простой и полезный способ решать квадратные уравнения в уме.",{"link":547,"schemaName":183,"title":282,"key":548,"seo":549,"description":551},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-square",{},{"title":550},"Решение квадратных уравнений в уме через полный квадрат","Иногда квадратное уравнение можно целиком запаковать в квадрат суммы или разности.\n          В таком случае у него будет один корень, который находится элементарно.",{"link":553,"schemaName":183,"title":410,"key":554,"seo":555,"description":557},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-factoring",{},{"title":556},"Решение квадратных уравнений в уме через разложение на множители","Если квадратное уравнение приведённое (A = 1), то его можно попытаться разложить на множители в уме.\n          Для этого надо найти такие t и k, чтобы t + k = B и tk = C. Корнями тогда будут числа -t и -k.",{"link":559,"schemaName":183,"title":560,"key":561,"seo":562,"description":564},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-ato-c","Перенос A к C",{},{"title":563},"Как получить приведённое квадратное уравнение?","Простой метод получения приведённого квадратного уравнения в форме, позволяющей решить его в уме.\n          Для этого надо \"перенести\" коэффициент A к C.",{"link":566,"schemaName":270,"title":567,"key":568,"seo":569,"description":571},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all","Схема способов",{},{"title":570},"Способы решения квадратных уравнений в уме","Удобная схема с перечислением всех способов быстрого решения квадратных уравнений в уме.\n          Также даны подсказки по корням.",{"link":573,"schemaName":383,"title":574,"key":575,"seo":576,"description":578},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all-practice","Задачи на все способы",{},{"title":577},"Задачи на решение квадратных уравнений в уме","Бесконечно генерируемые задачи на отработку всех способов решения квадратных уравнений в уме:\n          нулевой суммы, полного квадрата, разложения на множители и переноса A к C.",{"elements":580},{"accent_statement":581,"accent_important":246,"problem":247},4,{"contributorsCount":159,"sponsorsCount":247},{"shortBookId":5,"frontNav":584},{"type":14,"shortId":5,"title":15,"flags":585,"link":17,"children":586},{},[587],{"type":215,"separator":588,"shortId":589,"title":153,"flags":590,"link":154,"children":591},true,"foundations\u002Fequations",{},[592,599,602],{"type":170,"shortId":593,"title":171,"flags":594,"link":172,"parts":595},"foundations\u002Fequations\u002Felementary",{},[596,597,598],"article","summary","practice",{"type":8,"shortId":600,"title":176,"flags":601,"link":177},"foundations\u002Fequations\u002Fzero-product-property",{},{"type":215,"separator":603,"shortId":145,"title":147,"flags":604,"link":605,"children":606},false,{},"\u002Fgroup\u002Ffoundations\u002Fequations\u002Fquadratic\u002F",[607,611,615,619,623,627,631],{"type":170,"shortId":608,"title":219,"flags":609,"link":218,"parts":610},"foundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it",{},[596,597,598],{"type":170,"shortId":612,"title":250,"flags":613,"link":249,"parts":614},"foundations\u002Fequations\u002Fquadratic\u002Fincomplete",{},[596,597,598],{"type":170,"shortId":616,"title":282,"flags":617,"link":281,"parts":618},"foundations\u002Fequations\u002