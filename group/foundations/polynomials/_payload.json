,"Поиск",{"type":22,"value":44},"Материалы",{"type":22,"value":46},"Ключевые элементы",{"type":22,"value":48},"Статистика",{"type":22,"value":50},"Темная",{"type":22,"value":30},{"type":22,"value":53},"Языки",{"type":22,"value":55},"Системная",{"type":22,"value":57},"Статья",{"type":22,"value":59},"Настройки",{"type":22,"value":61},"Собрано",{"type":22,"value":63},"Конспект",{"type":22,"value":65},"Контент",{"type":22,"value":67},"Задачи",{"type":22,"value":69},"Erudit",{"type":22,"value":71},"Вы собираетесь перейти на страницу контента:",{"type":22,"value":73},"Добавить перевод",{"type":22,"value":75},"Главная страница",{"type":22,"value":77},"Авторы",{"type":22,"value":79},"Спонсоры",{"type":22,"value":81},"Поиск по сайту...",{"type":22,"value":83},"Ищем еще...",{"type":22,"value":85},"Ничего не найдено",{"type":22,"value":87},"Больше результатов нет",{"type":22,"value":89},"Контента нет.",{"type":22,"value":91},"К оглавлению",{"type":22,"value":93},"Об учебнике",{"type":22,"value":95},"Разработка",{"type":22,"value":97},"Профиль",{"type":22,"value":99},"Дополнение",{"type":22,"value":101},"Список людей, которые внесли вклад в материалы проекта: предложили ценные идеи, вносили корректировки в существующий материал или же написали собственный!",{"type":22,"value":103},"Вы тоже можете помочь проекту, внести свой вклад и попасть на эту страницу!",{"type":22,"value":105},"Стать автором",{"type":22,"value":107},"Список людей и организаций, которые поддерживают проект финансово. Благодаря им проект может существовать и развиваться. Если вы хотите помочь проекту, то тоже можете стать спонсором и попасть на эту страницу!",{"type":22,"value":109},"Пока что авторов нет. Вы можете стать первым!",{"type":22,"value":111},"Стать спонсором",{"type":22,"value":113},"Вклад",{"type":22,"value":115},"Пока что спонсоров нет. Вы можете стать первым!",{"type":22,"value":117},"Редактор",{"type":27,"value":119},"(name) => `Персональная страница автора \"${name}\" с данными о вкладе в проект.`",{"type":22,"value":121},"Путь",{"type":22,"value":123},"Начать изучение!",{"type":22,"value":125},"Связи",{"type":22,"value":127},"Обновлено",{"type":22,"value":129},"Собственные",{"type":22,"value":131},"Из",{"type":22,"value":133},"Надо знать",{"type":22,"value":135},"Зависит от",{"type":22,"value":137},"Используется в",{"type":22,"value":139},"Внешние",{"m":141},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":143,"mainContent":144},"group\u002Ffoundations\u002Fpolynomials\u002F",{"fullId":145,"shortId":145,"contentRelativePath":146,"title":147,"bookTitle":15,"breadcrumbs":148,"lastmod":151,"description":152,"stats":153,"connections":159,"contributions":191,"type":196,"children":197},"foundations\u002Fpolynomials","01-foundations\u002F01-polynomials","Многочлены",[149],{"icon":150,"title":15,"link":17},"book-outline","2026-05-01T18:59:52+03:00","\n    Базовые знания об основных алгебраических понятиях -- одночленах и многочленах.\n    Научимся приводить их к стандартной форме, преобразовывать, раскладывать на множители и выполнять другие операции.\n  ",{"materials":154,"elements":155},1,{"accent_term":154,"accent_statement":156,"accent_important":157,"problem":158},5,2,28,{"dependents":160,"externals":176},[161],{"type":162,"contentType":163,"title":164,"link":165,"uniques":166},"auto","topic","Выделение полного квадрата","\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F",[167,172],{"name":168,"title":169,"link":170,"schemaName":171},"squareSum","Формула квадрата суммы","\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F?element=square-sum","accent_statement",{"name":173,"title":174,"link":175,"schemaName":171},"squareDiff","Формула квадрата разности","\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F?element=square-diff",[177],{"type":178,"title":15,"items":179},"parent",[180,186],{"type":181,"title":182,"info":183,"link":184,"reason":185},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":187,"title":188,"info":189,"reason":190},"physical","Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[192],{"contributorId":193,"name":194,"avatarUrl":195},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png","group",[198],{"type":163,"link":199,"title":200,"description":201,"decoration":202,"keyLinks":203,"stats":264},"\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F","Формулы сокращенного умножения","\n    Квадрат суммы и разности, разность квадратов, куб суммы и разности -- очень полезные формулы, которые позволяют быстро раскладывать или запаковывать выражения со степенями (квадратами, кубами).\n  ","content\u002F01-foundations\u002F01-polynomials\u002F01-special-products\u002Fdecoration.svg",[204,212,217,222,230,236,242,248,256],{"link":205,"schemaName":206,"title":207,"key":208,"seo":210,"description":211},"\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F?element=what-are-special-products","accent_term","Формулы сокращённого умножения",{"title":209},"Что такое ФСУ?",{},"Формулы, которые позволяют быстро \"разворачивать\" компактные выражения со степенями в какое-то разложение или\n          наоборот, \"сворачивать\" длинные суммы в компактную форму. Эти формулы нужны, чтобы не тратить время на рутинные\n          вычисления вручную.",{"link":170,"schemaName":171,"title":213,"key":214,"seo":215,"description":216},"Квадрат суммы",{},{},"Одна из формул сокращенного умножения (ФСУ): (a+b)² = a² + 2ab + b².\n          Позволяет быстро раскрывать скобки или же наоборот, запаковывать в них уже разложенные выражения.",{"link":175,"schemaName":171,"title":218,"key":219,"seo":220,"description":221},"Квадрат разности",{},{},"Одна из формул сокращенного умножения (ФСУ): (a-b)² = a² - 2ab + b².\n          Позволяет быстро раскрывать скобки или же наоборот, запаковывать в них уже разложенные выражения.",{"link":223,"schemaName":224,"title":225,"key":226,"seo":227,"description":229},"\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F?element=fast-square","problems","Быстрые квадраты",{},{"title":228},"Как быстро возвести число в квадрат в уме?","Универсальный метод быстрого возведения в квадрат любого числа с помощью формул квадрата суммы и разности.\n          Для небольших чисел в пределах 100 можно выполнять этот процесс даже в уме!",{"link":231,"schemaName":171,"title":232,"key":233,"seo":234,"description":235},"\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F?element=diff-of-squares","Разность квадратов",{},{},"Одна из формул сокращенного умножения (ФСУ): a² - b² = (a + b)(a - b).\n          Позволяет вдвое снизить или увеличить степень.\n          Используется для упрощения выражений.",{"link":237,"schemaName":171,"title":238,"key":239,"seo":240,"description":241},"\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F?element=cube-sum","Куб суммы",{},{},"Одна из формул сокращенного умножения (ФСУ): (a + b)³ = a³ + 3a²b + 3ab² + b³.\n          Позволяет быстро разложить куб суммы двух выражений.\n          Используется для упрощения выражений и решения уравнений.",{"link":243,"schemaName":171,"title":244,"key":245,"seo":246,"description":247},"\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F?element=cube-diff","Куб разности",{},{},"Одна из формул сокращенного умножения (ФСУ): (a - b)³ = a³ - 3a²b + 3ab² - b³.\n          Позволяет быстро разложить куб разности двух выражений.\n          Используется для упрощения выражений и решения уравнений.",{"link":249,"schemaName":250,"title":251,"key":252,"seo":253,"description":255},"\u002Farticle\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F?element=memorization-tips","list","Как запомнить ФСУ?",{},{"title":254},"Как запомнить формулы сокращенного умножения?","Набор советов и приемов, которые помогут наизусть запомнить формулы сокращенного умножения (ФСУ) и не путаться в них.",{"link":257,"schemaName":258,"title":259,"key":260,"seo":262,"description":263},"\u002Fsummary\u002Ffoundations\u002Fpolynomials\u002Fspecial-products\u002F?element=special-products-table","table","Таблица формул сокращенного умножения",{"title":261},"Таблица ФСУ",{},"Единая таблица со всеми формулами сокращенного умножения.",{"elements":265},{"accent_term":154,"accent_statement":156,"accent_important":157,"problem":158},{"contributorsCount":267,"sponsorsCount":156},7,{"shortBookId":5,"frontNav":269},{"type":14,"shortId":5,"title":15,"flags":270,"link":17,"children":271},{},[272,284],{"type":196,"separator":273,"shortId":145,"title":147,"flags":274,"link":275,"children":276},true,{},"\u002Fgroup\u002Ffoundations\u002Fpolynomials\u002F",[277],{"type":163,"shortId":278,"title":200,"flags":279,"link":199,"parts":280},"foundations\u002Fpolynomials\u002Fspecial-products",{},[281,282,283],"article","summary","practice",{"type":196,"separator":273,"shortId":285,"title":286,"flags":287,"link":288,"children":289},"foundations\u002Fequations","Уравнения",{},"\u002Fgroup\u002Ffoundations\u002Fequations\u002F",[290,296,301],{"type":163,"shortId":291,"title":292,"flags":293,"link":294,"parts":295},"foundations\u002Fequations\u002Felementary","Элементарные уравнения",{},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F",[281,282,283],{"type":8,"shortId":297,"title":298,"flags":299,"link":300},"foundations\u002Fequations\u002Fzero-product-property","Нулевые множители",{},