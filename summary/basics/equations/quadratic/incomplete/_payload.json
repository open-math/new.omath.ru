":22,"value":38},"Светлая",{"type":22,"value":40},"Категория",{"type":22,"value":42},"Поиск",{"type":22,"value":44},"Материалы",{"type":22,"value":46},"Ключевые элементы",{"type":22,"value":48},"Статистика",{"type":22,"value":50},"Темная",{"type":22,"value":30},{"type":22,"value":53},"Языки",{"type":22,"value":55},"Системная",{"type":22,"value":57},"Статья",{"type":22,"value":59},"Настройки",{"type":22,"value":61},"Собрано",{"type":22,"value":63},"Конспект",{"type":22,"value":65},"Контент",{"type":22,"value":67},"Практика",{"type":22,"value":69},"Erudit",{"type":22,"value":71},"Вы собираетесь перейти на страницу контента:",{"type":22,"value":73},"Добавить перевод",{"type":22,"value":75},"Главная страница",{"type":22,"value":77},"Авторы",{"type":22,"value":79},"Спонсоры",{"type":22,"value":81},"Поиск по сайту...",{"type":22,"value":83},"Ищем еще...",{"type":22,"value":85},"Ничего не найдено",{"type":22,"value":87},"Больше результатов нет",{"type":22,"value":89},"Контента нет.",{"type":22,"value":91},"К оглавлению",{"type":22,"value":93},"Об учебнике",{"type":22,"value":95},"Разработка",{"type":22,"value":97},"Профиль",{"type":22,"value":99},"Дополнение",{"type":22,"value":101},"Список людей, которые внесли вклад в материалы проекта: предложили ценные идеи, вносили корректировки в существующий материал или же написали собственный!",{"type":22,"value":103},"Вы тоже можете помочь проекту, внести свой вклад и попасть на эту страницу!",{"type":22,"value":105},"Стать автором",{"type":22,"value":107},"Список людей и организаций, которые поддерживают проект финансово. Благодаря им проект может существовать и развиваться. Если вы хотите помочь проекту, то тоже можете стать спонсором и попасть на эту страницу!",{"type":22,"value":109},"Пока что авторов нет. Вы можете стать первым!",{"type":22,"value":111},"Стать спонсором",{"type":22,"value":113},"Вклад",{"type":22,"value":115},"Пока что спонсоров нет. Вы можете стать первым!",{"type":22,"value":117},"Редактор",{"type":27,"value":119},"(name) => `Персональная страница автора \"${name}\" с данными о вкладе в проект.`",{"type":22,"value":121},"Начать изучение!",{"type":22,"value":123},"Связи",{"type":22,"value":125},"Собственные",{"type":22,"value":127},"Из",{"type":22,"value":129},"Надо знать",{"type":22,"value":131},"Зависит от",{"type":22,"value":133},"Используется в",{"type":22,"value":135},"Внешние",{"type":27,"value":137},"(contentTitle) => `Понятное и интересное объяснение темы «${contentTitle}». Показательные примеры, важные свойства, интересные факты, применение в жизни, понятные доказательства. Здесь вы точно разберетесь!`",{"type":27,"value":139},"(contentTitle) => `Конспект темы «${contentTitle}»: ключевые определения, теоремы, свойства и примеры их использвания. Все самое важное и в кратком виде!`",{"type":27,"value":141},"(contentTitle) => `Разнообразные задачи с подсказками и ответами по теме «${contentTitle}». Интересные условия, подсказки и подробные решения. Превратите знания в навык!`",{"m":143},"function m(number, one, two, five, includeNumber = true) {\n  const text = [five, one, two, two, two, five][number % 100 > 10 && number % 100 \u003C 20 ? 0 : Math.min(number % 10, 5)];\n  return includeNumber ? `${number} ${text}` : text;\n}",{"contentPath":145,"mainContent":146},"summary\u002Fbasics\u002Fequations\u002Fquadratic\u002Fincomplete\u002F",{"fullId":147,"shortId":147,"contentRelativePath":148,"title":149,"bookTitle":15,"breadcrumbs":150,"description":160,"decoration":161,"stats":162,"connections":167,"contributions":229,"type":171,"part":235,"parts":236,"prose":239,"storage":381,"snippets":393,"toc":422},"basics\u002Fequations\u002Fquadratic\u002Fincomplete","01-basics\u002F02-equations\u002F02-quadratic\u002F2-incomplete","Неполные квадратные уравнения",[151,153,157],{"icon":152,"title":15,"link":17},"book-outline",{"icon":154,"title":155,"link":156},"folder-open","Уравнения","\u002Fgroup\u002Fbasics\u002Fequations\u002F",{"icon":154,"title":158,"link":159},"Квадра