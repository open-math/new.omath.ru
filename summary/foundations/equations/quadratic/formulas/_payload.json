br \u002F>$$ x = - \\frac{B}{2A} $$\"]\n          twoRoots[\"Два корня:\u003Cbr \u002F>$$ x_{1,2} = \\frac{-B \\pm \\sqrt{D}}{2A} $$\"]\n\n          factoring[\"\n            **Разложение на множители**\n            $$ A(x - x_1)(x - x_2) $$\n          \"]\n\n          vietasFormulas[\"\n            **Формулы Виета**\n            $$\n              \\begin{cases}\n                x_1 + x_2 = -\\frac{B}{A} \\\\\n                x_1 \\cdot x_2 = \\frac{C}{A}\n              \\end{cases}\n            $$\n          \"]\n\n          quadraticTrinomial -->|\"Трёхчлен равен $0$\"| quadraticEquation\n          quadraticEquation -->|\"Выделение&nbsp;полного&nbsp;квадрата\u003Cbr \u002F>(преобразовывая уравнение)\"| discriminant\n\n          discriminant -->|\"$D \u003C 0$\"| noRoots\n          discriminant -->|\"$D = 0$\"| oneRoot\n          discriminant -->|\"$D > 0$\"| twoRoots\n\n          twoRoots --> factoring\n\n          quadraticTrinomial -->|\"Выделение&nbsp;полного&nbsp;квадрата\u003Cbr \u002F>(эквивалентные&nbsp;преобразования)\"| factoring\n\n          factoring -->|Раскрытие скобок| vietasFormulas\n      ",{"__TSPROSE_proseElement":174,"schema":284,"children":286},{"name":285,"type":281,"linkable":272,"__TSPROSE_schema":174},"caption",[287,290],{"__TSPROSE_proseElement":174,"schema":288,"data":289},{"name":280,"type":281,"linkable":272,"__TSPROSE_schema":174},"Общая схема понятий и формул по квадратным уравнениям",{"__TSPROSE_proseElement":174,"schema":291,"children":293},{"name":292,"type":281,"linkable":272,"__TSPROSE_schema":174},"captionSecondary",[294],{"__TSPROSE_proseElement":174,"schema":295,"data":296},{"name":280,"type":281,"linkable":272,"__TSPROSE_schema":174},"Стрелки указывают порядок логики вывода","formulas",{"__TSPROSE_proseElement":174,"schema":299},{"name":300,"type":271,"linkable":272,"__TSPROSE_schema":174},"hr",{"__TSPROSE_proseElement":174,"schema":302,"children":303,"id":313},{"name":276,"type":271,"linkable":174,"__TSPROSE_schema":174},[30