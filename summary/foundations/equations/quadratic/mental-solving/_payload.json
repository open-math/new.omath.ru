ions\u002Fquadratic\u002Ffactoring\u002F",[200,205],{"name":201,"title":202,"link":203,"schemaName":204},"oneRootOne","Один корень один","\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=one-root-one","problems",{"name":206,"title":207,"link":208,"schemaName":209},"manualFactoring","Разложение \"вручную\"","\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=manual-factoring","heading",{"type":183,"contentType":187,"title":211,"link":212,"uniques":213},"Теорема Виета","\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F",[214],{"name":215,"title":211,"link":216,"schemaName":217},"vietasFormulas","\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=vietas-formulas","accent_statement",[219,228],{"type":220,"title":165,"items":221},"parent",[222],{"type":223,"title":224,"info":225,"link":226,"reason":227},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https:\u002F\u002Fddpu.edu.ua\u002Ffmk\u002Fstudentam\u002F3em\u002F10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":220,"title":15,"items":229},[230,236],{"type":231,"title":232,"info":233,"link":234,"reason":235},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":223,"title":237,"info":238,"reason":239},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[241,246],{"contributorId":242,"name":243,"avatarUrl":244,"description":245},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png","Идея и основной контент.",{"contributorId":247,"name":248,"avatarUrl":249,"description":250},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg","Метод решения \"Перенос A к C\".","summary",[253,251],"article",{"__TSPROSE_proseElement":174,"schema":255,"children":259},{"name":256,"type":257,"linkable":258,"__TSPROSE_schema":174},"mix","block",false,[260,277,280,300],{"__TSPROSE_proseElement":174,"schema":261,"children":263,"id":276},{"name":262,"type":257,"linkable":174,"__TSPROSE_schema":174},"diagram",[264,269],{"__TSPROSE_proseElement":174,"schema":265,"data":268},{"name":266,"type":267,"linkable":258,"__TSPROSE_schema":174},"text","inliner","\n        flowchart TD\n          methods[\"**Решение в уме**\u003Cbr \u002F>Неполные квадратные\"]\n\n          methods --> methodB0[\"\n            **B равен 0**\n            $$ \\begin{aligned} Ax^2 + C = 0 \\\\ 5x^2 - 20 = 0 \\end{aligned} $$\n          \"]\n          methodB0 --> rootsB0[\"$$x_{1,2} = \\pm\\sqrt{-\\frac{C}{A}}$$\"]\n\n          methods --> methodC0[\"\n            **C равен 0**\n            $$ \\begin{aligned} Ax^2 + Bx = 0 \\\\ 3x^2 + 12x = 0 \\end{aligned} $$\n          \"]\n          methodC0 --> root1C0[\"$$x_1 = 0$$\"]\n          methodC0 -->|1-я формула Виета| root2C0[\"$$x_2 = -\\frac{B}{A}$$\"]\n\n          methods --> methodBC0[\"\n            **B и C равны 0**\n            $$ \\begin{aligned} Ax^2 = 0 \\\\ 4x^2 = 0 \\end{aligned} $$\n          \"]\n          methodBC0 --> rootBC0[\"$$x_1 = x_2 = 0$$\"]\n\n        class methodB0,methodC0,methodBC0 fill\n      ",{"__TSPROSE_proseElement":174,"schema":270,"children":272},{"name":271,"type":267,"linkable":258,"__TSPROSE_schema":174},"caption",[273],{"__TSPROSE_proseElement":174,"schema":274,"data":275},{"name":266,"type":267,"linkable":258,"__TSPROSE_schema":174},"Схема способов решения неполных квадратных уравнений в уме","reshenie-nepolnykh",{"__TSPROSE_proseElement":174,"schema":278},{"name":279,"type":257,"linkable":258,"__TSPROSE_schema":174},"hr",{"__TSPROSE_proseElement":174,"schema":281,"children":282,"id":299},{"name":262,"type":257,"linkable":174,"__TSPROSE_schema":174},[283,286],{"__TSPROSE_proseElement":174,"schema":284,"data":285},{"name":266,"type":267,"linkable":258,"__TSPROSE_schema":174},"\n        flowchart LR\n          methods[\"**Решение в уме**\u003Cbr \u002F>$$ Ax^2 + Bx + C = 0 $$\"]\n\n          methods --> methodZeroSum[\"\n            **1. Нулевая сумма**\n            $$ \\begin{aligned} A \\pm B + C = 0 \\\\ 2x^2 + 3x - 5 = 0 \\end{aligned} $$\n          \"]\n          methodZeroSum --> methodZeroSumRoot1[\"$$ x_1 = \\pm 1 $$\"]\n          methodZeroSum -->|2-я формула Виета| methodZeroSumRoot2[\"$$ x_2 = \\pm \\frac{C}{A} $$\"]\n\n          methods --> methodSquare[\"\n            **2. Полный квадрат**\n            $$ \\begin{aligned} (Kx)^2 \\pm 2 \\cdot Kx \\cdot T + (T)^2 \\\\ 4x^2 + 12x + 9 = 0 \\end{aligned} $$\n          \"]\n          methodSquare -->|$A$ всегда внизу\u003Cbr \u002F> $A \\rightarrow K$ тоже внизу| methodSquareRoot[\"$$ x_1 = x_2 = \\mp \\frac{T}{K} $$\"]\n\n          methods --> methodFactoring[\"\n            **3. Разложение на множители**\n            $$ \\begin{aligned} x^2 + (t + k)x + tk = 0 \\\\ x^2 + 8x + 15 = 0 \\end{aligned} $$\n          \"]\n          methodFactoring -->|Минус перед $t$| methodFactoringRoot1[\"$$ x_1 = -t $$\"]\n          methodFactoring -->|Минус перед $k$| methodFactoringRoot2[\"$$ x_2 = -k $$\"]\n\n          methods --> methodAtoC[\"\n            **4. Перенос A к C**\n            $$ \\begin{aligned} x^2 + Bx + AC = 0 \\\\ 3x^2 - 17x - 6 = 0 \\end{aligned} $$\n          \"]\n          methodAtoC -->|$A$ всегда внизу\u003Cbr \u002F>Делим корни на $A$| methodAtoCRoots[\"$$ x_{1,2} = \\frac{x'_{1,2}}{A} $$\"]\n\n          class methodZeroSum,methodSquare,methodFactoring,methodAtoC fill\n      ",{"__TSPROSE_proseElement":174,"schema":287,"children":288},{"name":271,"type":267,"linkable":258,"__TSPROSE_schema":174},[289,292],{"__TSPROSE_proseElement":174,"schema":290,"data":291},{"name":266,"type":267,"linkable":258,"__TSPROSE_schema":174},"Схема способов решения квадратных уравнений в уме",{"__TSPROSE_proseElement":174,"schema":293,"children":295},{"name":294,"type":267,"linkable":258,"__TSPROSE_schema":174},"captionSecondary",[296],{"__TSPROSE_proseElement":174,"schema":297,"data":298},{"name":266,"type":267,"linkable":258,"__TSPROSE_schema":174},"В порядке возрастания сложности","skhema-sposobov",{"__TSPROSE_proseElement":174,"schema":301,"data":303,"storageKey":309,"children":310,"id":341},{"name":302,"type":257,"linkable":174,"__TSPROSE_schema":174},"problem",{"info":304,"scriptUniques":308},{"title":305,"level":306,"attributes":307},"Задачи на решение квадратных уравнений в уме","medium",[],{},"problemScript:content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F7-mental-solving\u002Fscripts\u002Fmixed",[311,322,329],{"__TSPROSE_proseElement":174,"schema":312,"children":314},{"name":313,"type":257,"linkable":258,"__TSPROSE_schema":174},"problemDescription",[315],{"__TSPROSE_proseElement":174,"schema":316,"data":318,"storageKey":320,"id":321},{"name":317,"type":257,"linkable":174,"__TSPROSE_schema":174},"blockMath",{"katex":319,"freeze":258},"2x^2 - x - 5 = 0","$$ 2x^2 - x - 5 = 0 $$","blockMath-znOe1tOSl",{"__TSPROSE_proseElement":174,"schema":323,"data":325},{"name":324,"type":257,"linkable":258,"__TSPROSE_schema":174},"problemCheck",{"label":326,"serializedValidator":327},"Решается в уме?",{"type":328,"answer":258},"boolean",{"__TSPROSE_proseElement":174,"schema":330,"children":332},{"name":331,"type":257,"linkable":258,"__TSPROSE_schema":174},"problemAnswer",[333],{"__TSPROSE_proseElement":174,"schema":334,"children":336,"id":340},{"name":335,"type":257,"linkable":174,"__TSPROSE_schema":174},"paragraph",[337],{"__TSPROSE_proseElement":174,"schema":338,"data":339},{"name":266,"type":267,"linkable":258,"__TSPROSE_schema":174},"Ни один из методов решения в уме не подходит для этого уравнения.","paragraph-kMHjgovbG","zadachi-na-reshenie-kvadratnykh-uravneniy-v-ume",{"problemScript:content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F7-mental-solving\u002Fscripts\u002Fmixed":343,"$$ 2x^2 - x - 5 = 0 $$":345},{"resolvedScriptSrc":344},"\u002Fapi\u002FproblemScript\u002Fcontent\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F7-mental-solving\u002Fscripts\u002Fmixed.js",null,[347,354,361,368,375,382,389],{"link":348,"schemaName":262,"title":349,"key":350,"seo":351,"description":353},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-incomplete","Решение неполных",{},{"title":352},"Решение неполных квадратных уравнений в уме","Все неполные квадратные уравнения решаются в уме при помощи одной из трех формул.\n          Не нужно ничего угадывать.\n          Находится решение элементарно.",{"link":355,"schemaName":217,"title":356,"key":357,"seo":358,"description":360},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-zero-sum","Нулевая сумма",{},{"title":359},"Решение квадратных уравнений в уме по сумме коэффициентов","Нулевая сумма коэффициентов позволяет моментально получить корни.\n          Это самый простой и полезный способ решать квадратные уравнения в уме.",{"link":362,"schemaName":217,"title":363,"key":364,"seo":365,"description":367},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-square","Полный квадрат",{},{"title":366},"Решение квадратных уравнений в уме через полный квадрат","Иногда квадратное уравнение можно целиком запаковать в квадрат суммы или разности.\n          В таком случае у него будет один корень, который находится элементарно.",{"link":369,"schemaName":217,"title":370,"key":371,"seo":372,"description":374},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-factoring","Разложение на множители",{},{"title":373},"Решение квадратных уравнений в уме через разложение на множители","Если квадратное уравнение приведённое (A = 1), то его можно попытаться разложить на множители в уме.\n          Для этого надо найти такие t и k, чтобы t + k = B и tk = C. Корнями тогда будут числа -t и -k.",{"link":376,"schemaName":217,"title":377,"key":378,"seo":379,"description":381},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-ato-c","Перенос A к C",{},{"title":380},"Как получить приведённое квадратное уравнение?","Простой метод получения приведённого квадратного уравнения в форме, позволяющей решить его в уме.\n          Для этого надо \"перенести\" коэффициент A к C.",{"link":383,"schemaName":262,"title":384,"key":385,"seo":386,"description":388},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all","Схема способов",{},{"title":387},"Способы решения квадратных уравнений в уме","Удобная схема с перечислением всех способов быстрого решения квадратных уравнений в уме.\n          Также даны подсказки по корням.",{"link":390,"schemaName":302,"title":391,"key":392,"seo":393,"description":394},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all-practice","Задачи на все способы",{},{"title":305},"Бесконечно генерируемые задачи на отработку всех способов решения квадратных уравнений в уме:\n          нулевой суммы, полного квадрата, разложения на множители и переноса A к C.",[396,399,400],{"type":397,"schemaName":262,"title":398,"elementId":276},"element","Способы решения неполных уравнений в уме",{"type":397,"schemaName":262,"title":387,"elementId":299},{"type":397,"schemaName":302,"title":305,"elementId":341},{"contributorsCount":402,"sponsorsCount":179},7,{"shortBookId":5,"frontNav":404},{"type":14,"shortId":5,"title":15,"flags":405,"link":17,"children":406},{},[407],{"type":408,"separator":174,"shortId":409,"title":165,"flags":4