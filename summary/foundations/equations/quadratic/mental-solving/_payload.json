ions\u002Fequations\u002Fquadratic\u002Ffactoring\u002F",[199,204],{"name":200,"title":201,"link":202,"schemaName":203},"oneRootOne","Один корень один","\u002Fpractice\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=one-root-one","problems",{"name":205,"title":206,"link":207,"schemaName":208},"manualFactoring","Разложение \"вручную\"","\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Ffactoring\u002F?element=manual-factoring","heading",{"type":182,"contentType":186,"title":210,"link":211,"uniques":212},"Теорема Виета","\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F",[213],{"name":214,"title":210,"link":215,"schemaName":216},"vietasFormulas","\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fvietas-formulas\u002F?element=vietas-formulas","accent_statement",[218],{"type":182,"contentType":186,"title":219,"link":220,"uniques":221},"Формулы квадратных уравнений","\u002Fsummary\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fformulas\u002F",[222,226],{"name":223,"title":224,"link":225,"schemaName":216},"methodAtoC","Перенос A к C","\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-ato-c",{"name":227,"title":228,"link":229,"schemaName":216},"methodZeroSum","Нулевая сумма","\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-zero-sum",[231,240],{"type":232,"title":165,"items":233},"parent",[234],{"type":235,"title":236,"info":237,"link":238,"reason":239},"physical","Задачи на составление уравнений и методы их решения","Крамор В. С., (Школьный курс математики)","https:\u002F\u002Fddpu.edu.ua\u002Ffmk\u002Fstudentam\u002F3em\u002F10.pdf","Больше 300 задач на сведение жизненных ситуаций к уравнениям вместе с решениями и ответами.",{"type":232,"title":15,"items":241},[242,248],{"type":243,"title":244,"info":245,"link":246,"reason":247},"web","LibreTexts Mathematics","Открытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":235,"title":249,"info":250,"reason":251},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[253,258],{"contributorId":254,"name":255,"avatarUrl":256,"description":257},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png","Идея и основной контент.",{"contributorId":259,"name":260,"avatarUrl":261,"description":262},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg","Метод решения \"Перенос A к C\".","summary",[265,263],"article",{"__TSPROSE_proseElement":174,"schema":267,"children":271},{"name":268,"type":269,"linkable":270,"__TSPROSE_schema":174},"mix","block",false,[272,289,292,312],{"__TSPROSE_proseElement":174,"schema":273,"children":275,"id":288},{"name":274,"type":269,"linkable":174,"__TSPROSE_schema":174},"diagram",[276,281],{"__TSPROSE_proseElement":174,"schema":277,"data":280},{"name":278,"type":279,"linkable":270,"__TSPROSE_schema":174},"text","inliner","\n        flowchart TD\n          methods[\"**Решение в уме**\u003Cbr \u002F>Неполные квадратные\"]\n\n          methods --> methodB0[\"\n            **B равен 0**\n            $$ \\begin{aligned} Ax^2 + C = 0 \\\\ 5x^2 - 20 = 0 \\end{aligned} $$\n          \"]\n          methodB0 --> rootsB0[\"$$x_{1,2} = \\pm\\sqrt{-\\frac{C}{A}}$$\"]\n\n          methods --> methodC0[\"\n            **C равен 0**\n            $$ \\begin{aligned} Ax^2 + Bx = 0 \\\\ 3x^2 + 12x = 0 \\end{aligned} $$\n          \"]\n          methodC0 --> root1C0[\"$$x_1 = 0$$\"]\n          methodC0 -->|1-я формула Виета| root2C0[\"$$x_2 = -\\frac{B}{A}$$\"]\n\n          methods --> methodBC0[\"\n            **B и C равны 0**\n            $$ \\begin{aligned} Ax^2 = 0 \\\\ 4x^2 = 0 \\end{aligned} $$\n          \"]\n          methodBC0 --> rootBC0[\"$$x_1 = x_2 = 0$$\"]\n\n        class methodB0,methodC0,methodBC0 fill\n      ",{"__TSPROSE_proseElement":174,"schema":282,"children":284},{"name":283,"type":279,"linkable":270,"__TSPROSE_schema":174},"caption",[285],{"__TSPROSE_proseElement":174,"schema":286,"data":287},{"name":278,"type":279,"linkable":270,"__TSPROSE_schema":174},"Схема способов решения неполных квадратных уравнений в уме","reshenie-nepolnykh",{"__TSPROSE_proseElement":174,"schema":290},{"name":291,"type":269,"linkable":270,"__TSPROSE_schema":174},"hr",{"__TSPROSE_proseElement":174,"schema":293,"children":294,"id":311},{"name":274,"type":269,"linkable":174,"__TSPROSE_schema":174},[295,298],{"__TSPROSE_proseElement":174,"schema":296,"data":297},{"name":278,"type":279,"linkable":270,"__TSPROSE_schema":174},"\n        flowchart LR\n          methods[\"**Решение в уме**\u003Cbr \u002F>$$ Ax^2 + Bx + C = 0 $$\"]\n\n          methods --> methodZeroSum[\"\n            **1. Нулевая сумма**\n            $$ \\begin{aligned} A \\pm B + C = 0 \\\\ 2x^2 + 3x - 5 = 0 \\end{aligned} $$\n          \"]\n          methodZeroSum --> methodZeroSumRoot1[\"$$ x_1 = \\pm 1 $$\"]\n          methodZeroSum -->|2-я формула Виета| methodZeroSumRoot2[\"$$ x_2 = \\pm \\frac{C}{A} $$\"]\n\n          methods --> methodSquare[\"\n            **2. Полный квадрат**\n            $$ \\begin{aligned} (Kx)^2 \\pm 2 \\cdot Kx \\cdot T + (T)^2 \\\\ 4x^2 + 12x + 9 = 0 \\end{aligned} $$\n          \"]\n          methodSquare -->|$A$ всегда внизу\u003Cbr \u002F> $A \\rightarrow K$ тоже внизу| methodSquareRoot[\"$$ x_1 = x_2 = \\mp \\frac{T}{K} $$\"]\n\n          methods --> methodFactoring[\"\n            **3. Разложение на множители**\n            $$ \\begin{aligned} x^2 + (t + k)x + tk = 0 \\\\ x^2 + 8x + 15 = 0 \\end{aligned} $$\n          \"]\n          methodFactoring -->|Минус перед $t$| methodFactoringRoot1[\"$$ x_1 = -t $$\"]\n          methodFactoring -->|Минус перед $k$| methodFactoringRoot2[\"$$ x_2 = -k $$\"]\n\n          methods --> methodAtoC[\"\n            **4. Перенос A к C**\n            $$ \\begin{aligned} x'^2 + Bx' + AC = 0 \\\\ 3x^2 - 17x - 6 = 0 \\end{aligned} $$\n          \"]\n          methodAtoC -->|$A$ всегда внизу\u003Cbr \u002F>Делим корни на $A$| methodAtoCRoots[\"$$ x_{1,2} = \\frac{x'_{1,2}}{A} $$\"]\n\n          class methodZeroSum,methodSquare,methodFactoring,methodAtoC fill\n      ",{"__TSPROSE_proseElement":174,"schema":299,"children":300},{"name":283,"type":279,"linkable":270,"__TSPROSE_schema":174},[301,304],{"__TSPROSE_proseElement":174,"schema":302,"data":303},{"name":278,"type":279,"linkable":270,"__TSPROSE_schema":174},"Схема способов решения квадратных уравнений в уме",{"__TSPROSE_proseElement":174,"schema":305,"children":307},{"name":306,"type":279,"linkable":270,"__TSPROSE_schema":174},"captionSecondary",[308],{"__TSPROSE_proseElement":174,"schema":309,"data":310},{"name":278,"type":279,"linkable":270,"__TSPROSE_schema":174},"В порядке возрастания сложности","skhema-sposobov",{"__TSPROSE_proseElement":174,"schema":313,"data":315,"storageKey":321,"children":322,"id":353},{"name":314,"type":269,"linkable":174,"__TSPROSE_schema":174},"problem",{"info":316,"scriptUniques":320},{"title":317,"level":318,"attributes":319},"Задачи на решение квадратных уравнений в уме","medium",[],{},"problemScript:content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F8-mental-solving\u002Fscripts\u002Fmixed",[323,334,341],{"__TSPROSE_proseElement":174,"schema":324,"children":326},{"name":325,"type":269,"linkable":270,"__TSPROSE_schema":174},"problemDescription",[327],{"__TSPROSE_proseElement":174,"schema":328,"data":330,"storageKey":332,"id":333},{"name":329,"type":269,"linkable":174,"__TSPROSE_schema":174},"blockMath",{"katex":331,"freeze":270},"2x^2 - x - 5 = 0","$$ 2x^2 - x - 5 = 0 $$","blockMath-znOe1tOSl",{"__TSPROSE_proseElement":174,"schema":335,"data":337},{"name":336,"type":269,"linkable":270,"__TSPROSE_schema":174},"problemCheck",{"label":338,"serializedValidator":339},"Решается в уме?",{"type":340,"answer":270},"boolean",{"__TSPROSE_proseElement":174,"schema":342,"children":344},{"name":343,"type":269,"linkable":270,"__TSPROSE_schema":174},"problemAnswer",[345],{"__TSPROSE_proseElement":174,"schema":346,"children":348,"id":352},{"name":347,"type":269,"linkable":174,"__TSPROSE_schema":174},"paragraph",[349],{"__TSPROSE_proseElement":174,"schema":350,"data":351},{"name":278,"type":279,"linkable":270,"__TSPROSE_schema":174},"Ни один из методов решения в уме не подходит для этого уравнения.","paragraph-kMHjgovbG","zadachi-na-reshenie-kvadratnykh-uravneniy-v-ume",{"problemScript:content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F8-mental-solving\u002Fscripts\u002Fmixed":355,"$$ 2x^2 - x - 5 = 0 $$":357},{"resolvedScriptSrc":356},"\u002Fapi\u002FproblemScript\u002Fcontent\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F8-mental-solving\u002Fscripts\u002Fmixed.js",null,[359,366,371,378,385,390,397],{"link":360,"schemaName":274,"title":361,"key":362,"seo":363,"description":365},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-incomplete","Решение неполных",{},{"title":364},"Решение неполных квадратных уравнений в уме","Все неполные квадратные уравнения решаются в уме при помощи одной из трех формул.\n          Не нужно ничего угадывать.\n          Находится решение элементарно.",{"link":229,"schemaName":216,"title":228,"key":367,"seo":368,"description":370},{},{"title":369},"Решение квадратных уравнений в уме по сумме коэффициентов","Нулевая сумма коэффициентов позволяет моментально получить корни.\n          Это самый простой и полезный способ решать квадратные уравнения в уме.",{"link":372,"schemaName":216,"title":373,"key":374,"seo":375,"description":377},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-square","Полный квадрат",{},{"title":376},"Решение квадратных уравнений в уме через полный квадрат","Иногда квадратное уравнение можно целиком запаковать в квадрат суммы или разности.\n          В таком случае у него будет один корень, который находится элементарно.",{"link":379,"schemaName":216,"title":380,"key":381,"seo":382,"description":384},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-factoring","Разложение на множители",{},{"title":383},"Решение квадратных уравнений в уме через разложение на множители","Если квадратное уравнение приведённое (A = 1), то его можно попытаться разложить на множители в уме.\n          Для этого надо найти такие t и k, чтобы t + k = B и tk = C. Корнями тогда будут числа -t и -k.",{"link":225,"schemaName":216,"title":224,"key":386,"seo":387,"description":389},{},{"title":388},"Как получить приведённое квадратное уравнение?","Простой метод получения приведённого квадратного уравнения в форме, позволяющей решить его в уме.\n          Для этого надо \"перенести\" коэффициент A к C.",{"link":391,"schemaName":274,"title":392,"key":393,"seo":394,"description":396},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all","Схема способов",{},{"title":395},"Способы решения квадратных уравнений в уме","Удобная схема с перечислением всех способов быстрого решения квадратных уравнений в уме.\n          Также даны подсказки по корням.",{"link":398,"schemaName":314,"title":399,"key":400,"seo":401,"description":402},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all-practice","Задачи на все способы",{},{"title":317},"Бесконечно генерируемые задачи на отработку всех способов решения квадратных уравнений в уме:\n          нулевой суммы, полного квадрата, разложения на множители и переноса A к C.",[404,407,408],{"type":405,"schemaName":274,"title":406,"elementId":288},"element","Способы решения неполных уравнений в уме",{"type":405,"schemaName":274,"title":395,"elementId":311},{"type":405,"schemaName":314,"title":317,"elementId":353},{"contributorsCount":410,"sponsorsCount":177},7,{"shortBookId":5,"frontNav":412},{"type":14,"shortId":5,"title":15,"flags":413,"link":17,"children":414},{},[415],{"type":416,"separator":174,"shortId":417,"title":165,"flags":418,"link":166,"children":419},"group","foundations\u002Fequations",{},[420,427,430],{"type":186,"shortId":421,"title":422,"flags":423,"link":424,"parts":425},"foundations\u002Fequations\u002Felementary","Элементарные уравнения",{},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F",[265,263,426],"practice",{"type":8,"shortId":428,"title":183,"flags":429,"link":184},"foundations\u002Fequations\u002Fzero-product-property",{},{"type":416,"separator":270,"shortId":431,"title":168,"flags":432,"link":169,"children":433},"foundations\u002Fequations\u002Fquadratic",{},[434,440,445,450,456,460,465,469,474],{"type":186,"shortId":435,"title":436,"flags":437,"link":438,"parts":439},"foundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it","Что это такое?",{},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F",[265,263,426],{"type":186,"shortId":441,"title":442,"flags":443,"link":188,"parts":444},"foundations\u002Fequations\u002Fquadratic\u002Fincomplete","Неполная форма",{},[265,263,426],{"type":186,"shortId":446,"title":373,"flags":447,"link":448,"parts":449},"foundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square",{},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F",[265,263,426],{"type":186,"shortId":451,"title":452,"flags":453,"link":454,"parts":455},"foundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula","Формула корней",{},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F",[265,263,426],{"type":186,"shortId":457,"title":380,"flags":458,"link":197,"parts":459},"founda