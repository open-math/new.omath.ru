ытая и бесплатная онлайн-коллекция учебных материалов по математике.","https:\u002F\u002Fmath.libretexts.org\u002F","Большое количество материалов и много типовых задач на отработку.",{"type":236,"title":250,"info":251,"reason":252},"Математика. 6 класс","Мерзляк А.Г., Полонский В.Б., Якир М.С.","Огромное количество самых разных задач, от элементарнейших до довольно хитрых.",[254,259],{"contributorId":255,"name":256,"avatarUrl":257,"description":258},"gwynerva","Пётр Радько","\u002Ffile\u002Fcontributors\u002Fgwynerva\u002Favatar.png","Идея и основной контент.",{"contributorId":260,"name":261,"avatarUrl":262,"description":263},"nagibin","Николай Нагибин","\u002Ffile\u002Fcontributors\u002Fnagibin\u002Favatar.jpg","Метод решения \"Перенос A к C\".","summary",[266,264],"article",{"__TSPROSE_proseElement":174,"schema":268,"children":272},{"name":269,"type":270,"linkable":271,"__TSPROSE_schema":174},"mix","block",false,[273,290,293,313],{"__TSPROSE_proseElement":174,"schema":274,"children":276,"id":289},{"name":275,"type":270,"linkable":174,"__TSPROSE_schema":174},"diagram",[277,282],{"__TSPROSE_proseElement":174,"schema":278,"data":281},{"name":279,"type":280,"linkable":271,"__TSPROSE_schema":174},"text","inliner","\n        flowchart TD\n          methods[\"**Решение в уме**\u003Cbr \u002F>Неполные квадратные\"]\n\n          methods --> methodB0[\"\n            **B равен 0**\n            $$ \\begin{aligned} Ax^2 + C = 0 \\\\ 5x^2 - 20 = 0 \\end{aligned} $$\n          \"]\n          methodB0 --> rootsB0[\"$$x_{1,2} = \\pm\\sqrt{-\\frac{C}{A}}$$\"]\n\n          methods --> methodC0[\"\n            **C равен 0**\n            $$ \\begin{aligned} Ax^2 + Bx = 0 \\\\ 3x^2 + 12x = 0 \\end{aligned} $$\n          \"]\n          methodC0 --> root1C0[\"$$x_1 = 0$$\"]\n          methodC0 -->|1-я формула Виета| root2C0[\"$$x_2 = -\\frac{B}{A}$$\"]\n\n          methods --> methodBC0[\"\n            **B и C равны 0**\n            $$ \\begin{aligned} Ax^2 = 0 \\\\ 4x^2 = 0 \\end{aligned} $$\n          \"]\n          methodBC0 --> rootBC0[\"$$x_1 = x_2 = 0$$\"]\n\n        class methodB0,methodC0,methodBC0 fill\n      ",{"__TSPROSE_proseElement":174,"schema":283,"children":285},{"name":284,"type":280,"linkable":271,"__TSPROSE_schema":174},"caption",[286],{"__TSPROSE_proseElement":174,"schema":287,"data":288},{"name":279,"type":280,"linkable":271,"__TSPROSE_schema":174},"Схема способов решения неполных квадратных уравнений в уме","reshenie-nepolnykh",{"__TSPROSE_proseElement":174,"schema":291},{"name":292,"type":270,"linkable":271,"__TSPROSE_schema":174},"hr",{"__TSPROSE_proseElement":174,"schema":294,"children":295,"id":312},{"name":275,"type":270,"linkable":174,"__TSPROSE_schema":174},[296,299],{"__TSPROSE_proseElement":174,"schema":297,"data":298},{"name":279,"type":280,"linkable":271,"__TSPROSE_schema":174},"\n        flowchart LR\n          methods[\"**Решение в уме**\u003Cbr \u002F>$$ Ax^2 + Bx + C = 0 $$\"]\n\n          methods --> methodZeroSum[\"\n            **1. Нулевая сумма**\n            $$ \\begin{aligned} A \\pm B + C = 0 \\\\ 2x^2 + 3x - 5 = 0 \\end{aligned} $$\n          \"]\n          methodZeroSum --> methodZeroSumRoot1[\"$$ x_1 = \\pm 1 $$\"]\n          methodZeroSum -->|2-я формула Виета| methodZeroSumRoot2[\"$$ x_2 = \\pm \\frac{C}{A} $$\"]\n\n          methods --> methodSquare[\"\n            **2. Полный квадрат**\n            $$ \\begin{aligned} (Kx)^2 \\pm 2 \\cdot Kx \\cdot T + (T)^2 \\\\ 4x^2 + 12x + 9 = 0 \\end{aligned} $$\n          \"]\n          methodSquare -->|$A$ всегда внизу\u003Cbr \u002F> $A \\rightarrow K$ тоже внизу| methodSquareRoot[\"$$ x_1 = x_2 = \\mp \\frac{T}{K} $$\"]\n\n          methods --> methodFactoring[\"\n            **3. Разложение на множители**\n            $$ \\begin{aligned} x^2 + (t + k)x + tk = 0 \\\\ x^2 + 8x + 15 = 0 \\end{aligned} $$\n          \"]\n          methodFactoring -->|Минус перед $t$| methodFactoringRoot1[\"$$ x_1 = -t $$\"]\n          methodFactoring -->|Минус перед $k$| methodFactoringRoot2[\"$$ x_2 = -k $$\"]\n\n          methods --> methodAtoC[\"\n            **4. Перенос A к C**\n            $$ \\begin{aligned} x'^2 + Bx' + AC = 0 \\\\ 3x^2 - 17x - 6 = 0 \\end{aligned} $$\n          \"]\n          methodAtoC -->|$A$ всегда внизу\u003Cbr \u002F>Делим корни на $A$| methodAtoCRoots[\"$$ x_{1,2} = \\frac{x'_{1,2}}{A} $$\"]\n\n          class methodZeroSum,methodSquare,methodFactoring,methodAtoC fill\n      ",{"__TSPROSE_proseElement":174,"schema":300,"children":301},{"name":284,"type":280,"linkable":271,"__TSPROSE_schema":174},[302,305],{"__TSPROSE_proseElement":174,"schema":303,"data":304},{"name":279,"type":280,"linkable":271,"__TSPROSE_schema":174},"Схема способов решения квадратных уравнений в уме",{"__TSPROSE_proseElement":174,"schema":306,"children":308},{"name":307,"type":280,"linkable":271,"__TSPROSE_schema":174},"captionSecondary",[309],{"__TSPROSE_proseElement":174,"schema":310,"data":311},{"name":279,"type":280,"linkable":271,"__TSPROSE_schema":174},"В порядке возрастания сложности","skhema-sposobov",{"__TSPROSE_proseElement":174,"schema":314,"data":316,"storageKey":322,"children":323,"id":354},{"name":315,"type":270,"linkable":174,"__TSPROSE_schema":174},"problem",{"info":317,"scriptUniques":321},{"title":318,"level":319,"attributes":320},"Задачи на решение квадратных уравнений в уме","medium",[],{},"problemScript:content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F7-mental-solving\u002Fscripts\u002Fmixed",[324,335,342],{"__TSPROSE_proseElement":174,"schema":325,"children":327},{"name":326,"type":270,"linkable":271,"__TSPROSE_schema":174},"problemDescription",[328],{"__TSPROSE_proseElement":174,"schema":329,"data":331,"storageKey":333,"id":334},{"name":330,"type":270,"linkable":174,"__TSPROSE_schema":174},"blockMath",{"katex":332,"freeze":271},"2x^2 - x - 5 = 0","$$ 2x^2 - x - 5 = 0 $$","blockMath-znOe1tOSl",{"__TSPROSE_proseElement":174,"schema":336,"data":338},{"name":337,"type":270,"linkable":271,"__TSPROSE_schema":174},"problemCheck",{"label":339,"serializedValidator":340},"Решается в уме?",{"type":341,"answer":271},"boolean",{"__TSPROSE_proseElement":174,"schema":343,"children":345},{"name":344,"type":270,"linkable":271,"__TSPROSE_schema":174},"problemAnswer",[346],{"__TSPROSE_proseElement":174,"schema":347,"children":349,"id":353},{"name":348,"type":270,"linkable":174,"__TSPROSE_schema":174},"paragraph",[350],{"__TSPROSE_proseElement":174,"schema":351,"data":352},{"name":279,"type":280,"linkable":271,"__TSPROSE_schema":174},"Ни один из методов решения в уме не подходит для этого уравнения.","paragraph-kMHjgovbG","zadachi-na-reshenie-kvadratnykh-uravneniy-v-ume",{"problemScript:content\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F7-mental-solving\u002Fscripts\u002Fmixed":356,"$$ 2x^2 - x - 5 = 0 $$":358},{"resolvedScriptSrc":357},"\u002Fapi\u002FproblemScript\u002Fcontent\u002F01-foundations\u002F02-equations\u002F03-quadratic\u002F7-mental-solving\u002Fscripts\u002Fmixed.js",null,[360,367,372,379,386,391,398],{"link":361,"schemaName":275,"title":362,"key":363,"seo":364,"description":366},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-incomplete","Решение неполных",{},{"title":365},"Решение неполных квадратных уравнений в уме","Все неполные квадратные уравнения решаются в уме при помощи одной из трех формул.\n          Не нужно ничего угадывать.\n          Находится решение элементарно.",{"link":230,"schemaName":217,"title":229,"key":368,"seo":369,"description":371},{},{"title":370},"Решение квадратных уравнений в уме по сумме коэффициентов","Нулевая сумма коэффициентов позволяет моментально получить корни.\n          Это самый простой и полезный способ решать квадратные уравнения в уме.",{"link":373,"schemaName":217,"title":374,"key":375,"seo":376,"description":378},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-square","Полный квадрат",{},{"title":377},"Решение квадратных уравнений в уме через полный квадрат","Иногда квадратное уравнение можно целиком запаковать в квадрат суммы или разности.\n          В таком случае у него будет один корень, который находится элементарно.",{"link":380,"schemaName":217,"title":381,"key":382,"seo":383,"description":385},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=method-factoring","Разложение на множители",{},{"title":384},"Решение квадратных уравнений в уме через разложение на множители","Если квадратное уравнение приведённое (A = 1), то его можно попытаться разложить на множители в уме.\n          Для этого надо найти такие t и k, чтобы t + k = B и tk = C. Корнями тогда будут числа -t и -k.",{"link":226,"schemaName":217,"title":225,"key":387,"seo":388,"description":390},{},{"title":389},"Как получить приведённое квадратное уравнение?","Простой метод получения приведённого квадратного уравнения в форме, позволяющей решить его в уме.\n          Для этого надо \"перенести\" коэффициент A к C.",{"link":392,"schemaName":275,"title":393,"key":394,"seo":395,"description":397},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all","Схема способов",{},{"title":396},"Способы решения квадратных уравнений в уме","Удобная схема с перечислением всех способов быстрого решения квадратных уравнений в уме.\n          Также даны подсказки по корням.",{"link":399,"schemaName":315,"title":400,"key":401,"seo":402,"description":403},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fmental-solving\u002F?element=methods-all-practice","Задачи на все способы",{},{"title":318},"Бесконечно генерируемые задачи на отработку всех способов решения квадратных уравнений в уме:\n          нулевой суммы, полного квадрата, разложения на множители и переноса A к C.",[405,408,409],{"type":406,"schemaName":275,"title":407,"elementId":289},"element","Способы решения неполных уравнений в уме",{"type":406,"schemaName":275,"title":396,"elementId":312},{"type":406,"schemaName":315,"title":318,"elementId":354},{"contributorsCount":411,"sponsorsCount":179},7,{"shortBookId":5,"frontNav":413},{"type":14,"shortId":5,"title":15,"flags":414,"link":17,"children":415},{},[416],{"type":417,"separator":174,"shortId":418,"title":165,"flags":419,"link":166,"children":420},"group","foundations\u002Fequations",{},[421,428,431],{"type":187,"shortId":422,"title":423,"flags":424,"link":425,"parts":426},"foundations\u002Fequations\u002Felementary","Элементарные уравнения",{},"\u002Farticle\u002Ffoundations\u002Fequations\u002Felementary\u002F",[266,264,427],"practice",{"type":8,"shortId":429,"title":184,"flags":430,"link":185},"foundations\u002Fequations\u002Fzero-product-property",{},{"type":417,"separator":271,"shortId":432,"title":168,"flags":433,"link":169,"children":434},"foundations\u002Fequations\u002Fquadratic",{},[435,441,446,451,457,461,465,470],{"type":187,"shortId":436,"title":437,"flags":438,"link":439,"parts":440},"foundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it","Что это такое?",{},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fwhat-is-it\u002F",[266,264,427],{"type":187,"shortId":442,"title":443,"flags":444,"link":189,"parts":445},"foundations\u002Fequations\u002Fquadratic\u002Fincomplete","Неполная форма",{},[266,264,427],{"type":187,"shortId":447,"title":374,"flags":448,"link":449,"parts":450},"foundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square",{},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fcompleting-the-square\u002F",[266,264,427],{"type":187,"shortId":452,"title":453,"flags":454,"link":455,"parts":456},"foundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula","Формула корней",{},"\u002Farticle\u002Ffoundations\u002Fequations\u002Fquadratic\u002Fquadratic-formula\u002F",[266,264,427],{"type":187,"shortId":458,"title":381,"flags":459,"link":198,"parts":460},"foundati